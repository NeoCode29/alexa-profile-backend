<script>
function parseLinesToArray(str) {
	return (str || '').split('\n').map(s => s.trim()).filter(Boolean);
}

// ========================
// SERVICE INFO HANDLERS
// ========================
function openEditServiceModal(svc) {
	document.getElementById('editSvcId').value = svc.id;
	document.getElementById('editSvcTitle').value = svc.title;
	document.getElementById('editSvcSubtitle').value = svc.subtitle || '';
	document.getElementById('editSvcDescription').value = svc.description || '';
	document.getElementById('editSvcFullDesc').value = svc.fullDesc || svc.description || '';
	document.getElementById('editSvcIcon').value = svc.icon || 'FaLaptopCode';

	let featArr = [];
	try { featArr = typeof svc.features === 'string' ? JSON.parse(svc.features) : (svc.features || []); } catch (e) {}
	document.getElementById('editSvcFeaturesInput').value = featArr.join('\n');

	new bootstrap.Modal(document.getElementById('editServiceModal')).show();
}

async function submitEditService() {
	const id = document.getElementById('editSvcId').value;
	const featuresArr = parseLinesToArray(document.getElementById('editSvcFeaturesInput').value);

	const data = {
		title: document.getElementById('editSvcTitle').value,
		subtitle: document.getElementById('editSvcSubtitle').value,
		description: document.getElementById('editSvcDescription').value,
		heroDesc: document.getElementById('editSvcFullDesc').value,
		fullDesc: document.getElementById('editSvcFullDesc').value,
		icon: document.getElementById('editSvcIcon').value,
		features: featuresArr
	};

	try {
		const res = await fetch(`/api/services/${id}`, {
			method: 'PUT',
			headers: { 'Content-Type': 'application/json' },
			body: JSON.stringify(data)
		});
		const result = await res.json();
		if (result.success) {
			Swal.fire({ icon: 'success', title: 'Tersimpan', text: result.message, timer: 1500, showConfirmButton: false }).then(() => location.reload());
		} else {
			Swal.fire('Gagal', result.message || 'Gagal memperbarui layanan', 'error');
		}
	} catch (e) {
		Swal.fire('Error', 'Terjadi kesalahan koneksi server', 'error');
	}
}

// ========================
// PACKAGES HANDLERS
// ========================
function openAddPackageModal(serviceId) {
	document.getElementById('addPkgName').value = '';
	document.getElementById('addPkgPrice').value = '';
	document.getElementById('addPkgFeaturesInput').value = '';
	document.getElementById('addPkgIsPopularSwitch').checked = false;
	new bootstrap.Modal(document.getElementById('addPackageModal')).show();
}

async function submitCreatePackage() {
	const serviceId = document.getElementById('pkgServiceId').value;
	const name = document.getElementById('addPkgName').value;
	const price = document.getElementById('addPkgPrice').value;
	const isPopular = document.getElementById('addPkgIsPopularSwitch').checked;
	const featuresArr = parseLinesToArray(document.getElementById('addPkgFeaturesInput').value);

	if (!name || !price) {
		return Swal.fire('Perhatian', 'Nama Paket dan Harga wajib diisi', 'warning');
	}

	const res = await fetch('/api/services/packages', {
		method: 'POST',
		headers: { 'Content-Type': 'application/json' },
		body: JSON.stringify({ serviceId, name, price, isPopular, features: featuresArr })
	});
	const result = await res.json();
	if (result.success) {
		Swal.fire({ icon: 'success', title: 'Paket Ditambahkan', timer: 1500, showConfirmButton: false }).then(() => location.reload());
	} else {
		Swal.fire('Gagal', result.message, 'error');
	}
}

function openEditPackageModal(pkg) {
	document.getElementById('editPkgId').value = pkg.id;
	document.getElementById('editPkgName').value = pkg.name;
	document.getElementById('editPkgPrice').value = pkg.price;
	document.getElementById('editPkgIsPopularSwitch').checked = !!pkg.isPopular;

	let featArr = [];
	try { featArr = typeof pkg.features === 'string' ? JSON.parse(pkg.features) : (pkg.features || []); } catch (e) {}
	document.getElementById('editPkgFeaturesInput').value = featArr.join('\n');

	new bootstrap.Modal(document.getElementById('editPackageModal')).show();
}

async function submitEditPackage() {
	const id = document.getElementById('editPkgId').value;
	const data = {
		name: document.getElementById('editPkgName').value,
		price: document.getElementById('editPkgPrice').value,
		isPopular: document.getElementById('editPkgIsPopularSwitch').checked,
		features: parseLinesToArray(document.getElementById('editPkgFeaturesInput').value)
	};

	const res = await fetch(`/api/services/packages/${id}`, {
		method: 'PUT',
		headers: { 'Content-Type': 'application/json' },
		body: JSON.stringify(data)
	});
	const result = await res.json();
	if (result.success) {
		Swal.fire({ icon: 'success', title: 'Paket Diperbarui', timer: 1500, showConfirmButton: false }).then(() => location.reload());
	} else {
		Swal.fire('Gagal', result.message, 'error');
	}
}

async function deletePackageAction(id) {
	const confirm = await Swal.fire({
		title: 'Hapus Paket?',
		text: 'Paket harga ini akan dihapus dari divisi ini.',
		icon: 'warning',
		showCancelButton: true,
		confirmButtonColor: '#d33',
		confirmButtonText: 'Ya, Hapus'
	});
	if (confirm.isConfirmed) {
		const res = await fetch(`/api/services/packages/${id}`, { method: 'DELETE' });
		const result = await res.json();
		if (result.success) location.reload();
	}
}

