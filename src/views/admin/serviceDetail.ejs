<script>
function parseLinesToArray(str) {
	return (str || '').split('\n').map(s => s.trim()).filter(Boolean);
}

// ========================
// KEY FEATURES DYNAMIC BUILDER
// ========================
function renderDynamicFeaturesList(featuresArr) {
	const container = document.getElementById('dynamicFeaturesList');
	if (!container) return;
	container.innerHTML = '';
	if (!featuresArr || featuresArr.length === 0) {
		addDynamicFeatureRow();
		return;
	}
	featuresArr.forEach(feat => {
		let title = typeof feat === 'object' && feat !== null ? (feat.title || '') : (typeof feat === 'string' ? feat.split('|')[0].trim() : '');
		let desc = typeof feat === 'object' && feat !== null ? (feat.desc || '') : (typeof feat === 'string' && feat.split('|').length > 1 ? feat.split('|').slice(1).join('|').trim() : '');
		addDynamicFeatureRow(title, desc);
	});
}

function addDynamicFeatureRow(title = '', desc = '') {
	const container = document.getElementById('dynamicFeaturesList');
	if (!container) return;
	const row = document.createElement('div');
	row.className = 'feature-row-item p-3 border rounded-3 bg-light position-relative';
	row.innerHTML = `
		<button type="button" class="btn btn-sm text-danger position-absolute top-0 end-0 m-2" onclick="this.closest('.feature-row-item').remove()" title="Hapus Keunggulan">
			<i class="ti ti-trash fs-5"></i>
		</button>
		<div class="mb-2 pe-4">
			<label class="form-label small fw-bold text-dark mb-1">Judul Keunggulan <span class="text-danger">*</span></label>
			<input type="text" class="form-control form-control-sm feature-item-title" placeholder="Contoh: BANDWIDTH DEDICATED 1:1" value="${title.replace(/"/g, '&quot;')}">
		</div>
		<div>
			<label class="form-label small fw-bold text-dark mb-1">Deskripsi Penjelasan</label>
			<textarea class="form-control form-control-sm feature-item-desc" rows="2" placeholder="Contoh: Kecepatan upload dan download simetris tanpa terbagi...">${desc}</textarea>
		</div>
	`;
	container.appendChild(row);
}

function collectDynamicFeatures() {
	const items = [];
	document.querySelectorAll('#dynamicFeaturesList .feature-row-item').forEach(row => {
		const titleInput = row.querySelector('.feature-item-title');
		const descInput = row.querySelector('.feature-item-desc');
		if (titleInput && titleInput.value.trim()) {
			items.push({
				title: titleInput.value.trim(),
				desc: descInput ? descInput.value.trim() : ''
			});
		}
	});
	return items;
}

// ========================
// SERVICE INFO HANDLERS
// ========================
function openEditServiceModal(svc) {
	document.getElementById('editSvcId').value = svc.id;
	document.getElementById('editSvcTitle').value = svc.title;
	document.getElementById('editSvcSubtitle').value = svc.subtitle || '';
	document.getElementById('editSvcDescription').value = svc.description || '';
	document.getElementById('editSvcFullDesc').value = svc.fullDesc || svc.description || '';
	document.getElementById('editSvcIcon').value = svc.icon || 'FaLaptopCode';

	let featArr = [];
	try { featArr = typeof svc.features === 'string' ? JSON.parse(svc.features) : (svc.features || []); } catch (e) {}
	renderDynamicFeaturesList(featArr);

	new bootstrap.Modal(document.getElementById('editServiceModal')).show();
}

async function submitEditService() {
	const id = document.getElementById('editSvcId').value;
	const featuresArr = collectDynamicFeatures();

	const data = {
		title: document.getElementById('editSvcTitle').value,
		subtitle: document.getElementById('editSvcSubtitle').value,
		description: document.getElementById('editSvcDescription').value,
		heroDesc: document.getElementById('editSvcFullDesc').value,
		fullDesc: document.getElementById('editSvcFullDesc').value,
		icon: document.getElementById('editSvcIcon').value,
		features: featuresArr
	};

	try {
		const res = await fetch(`/api/services/${id}`, {
			method: 'PUT',
			headers: { 'Content-Type': 'application/json' },
			body: JSON.stringify(data)
		});
		const result = await res.json();
		if (result.success) {
			Swal.fire({ icon: 'success', title: 'Perubahan Disimpan', timer: 1500, showConfirmButton: false }).then(() => location.reload());
		} else {
			Swal.fire('Gagal', result.message || 'Gagal memperbarui layanan', 'error');
		}
	} catch (e) {
		Swal.fire('Error', 'Terjadi kesalahan koneksi server', 'error');
	}
}

// ========================
// IMAGE UPLOAD HANDLER
// ========================
async function handlePortfolioImageUpload(fileInput, targetInputId, previewId) {
	if (!fileInput.files || !fileInput.files[0]) return;
	const file = fileInput.files[0];
	const formData = new FormData();
	formData.append('image', file);

	Swal.fire({
		title: 'Mengunggah Gambar...',
		text: 'Mohon tunggu, gambar sedang diproses dan dioptimasi ke format WebP',
		allowOutsideClick: false,
		didOpen: () => { Swal.showLoading(); }
	});

	try {
		const res = await fetch('/api/upload', { method: 'POST', body: formData });
		const result = await res.json();
		Swal.close();

		if (result.success) {
			document.getElementById(targetInputId).value = result.url;
			const previewBox = document.getElementById(previewId);
			if (previewBox) {
				previewBox.style.display = 'block';
				previewBox.innerHTML = `<img src="${result.url}" class="img-fluid rounded border shadow-sm" style="max-height: 150px;">`;
			}
		} else {
			Swal.fire('Gagal Unggah', result.message || 'Terjadi kesalahan saat mengunggah gambar.', 'error');
		}
	} catch (err) {
		Swal.close();
		Swal.fire('Error', 'Gagal menghubungi server untuk mengunggah gambar.', 'error');
	}
}

// ========================
// PACKAGES HANDLERS
// ========================
function openAddPackageModal(serviceId) {
	document.getElementById('addPkgName').value = '';
	document.getElementById('addPkgPrice').value = '';
	document.getElementById('addPkgFeaturesInput').value = '';
	document.getElementById('addPkgIsPopularSwitch').checked = false;
	new bootstrap.Modal(document.getElementById('addPackageModal')).show();
}

async function submitCreatePackage() {
	const serviceId = document.getElementById('pkgServiceId').value;
	const name = document.getElementById('addPkgName').value;
	const price = document.getElementById('addPkgPrice').value;
	const isPopular = document.getElementById('addPkgIsPopularSwitch').checked;
	const featuresArr = parseLinesToArray(document.getElementById('addPkgFeaturesInput').value);

	if (!name || !price) {
		return Swal.fire('Perhatian', 'Nama Paket dan Harga wajib diisi', 'warning');
	}

	const res = await fetch('/api/services/packages', {
		method: 'POST',
		headers: { 'Content-Type': 'application/json' },
		body: JSON.stringify({ serviceId, name, price, isPopular, features: featuresArr })
	});
	const result = await res.json();
	if (result.success) {
		Swal.fire({ icon: 'success', title: 'Paket Ditambahkan', timer: 1500, showConfirmButton: false }).then(() => location.reload());
	} else {
		Swal.fire('Gagal', result.message, 'error');
	}
}

function openEditPackageModal(pkg) {
	document.getElementById('editPkgId').value = pkg.id;
	document.getElementById('editPkgName').value = pkg.name;
	document.getElementById('editPkgPrice').value = pkg.price;
	document.getElementById('editPkgIsPopularSwitch').checked = !!pkg.isPopular;

	let featArr = [];
	try { featArr = typeof pkg.features === 'string' ? JSON.parse(pkg.features) : (pkg.features || []); } catch (e) {}
	document.getElementById('editPkgFeaturesInput').value = featArr.join('\n');

	new bootstrap.Modal(document.getElementById('editPackageModal')).show();
}

async function submitEditPackage() {
	const id = document.getElementById('editPkgId').value;
	const name = document.getElementById('editPkgName').value;
	const price = document.getElementById('editPkgPrice').value;
	const isPopular = document.getElementById('editPkgIsPopularSwitch').checked;
	const featuresArr = parseLinesToArray(document.getElementById('editPkgFeaturesInput').value);

	const res = await fetch(`/api/services/packages/${id}`, {
		method: 'PUT',
		headers: { 'Content-Type': 'application/json' },
		body: JSON.stringify({ name, price, isPopular, features: featuresArr })
	});
	const result = await res.json();
	if (result.success) {
		Swal.fire({ icon: 'success', title: 'Paket Diperbarui', timer: 1500, showConfirmButton: false }).then(() => location.reload());
	} else {
		Swal.fire('Gagal', result.message, 'error');
	}
}

async function deletePackageAction(id) {
	const confirm = await Swal.fire({
		title: 'Hapus Paket?',
		text: 'Paket harga ini akan dihapus permanen.',
		icon: 'warning',
		showCancelButton: true,
		confirmButtonColor: '#d33',
		confirmButtonText: 'Ya, Hapus'
	});
	if (confirm.isConfirmed) {
		const res = await fetch(`/api/services/packages/${id}`, { method: 'DELETE' });
		const result = await res.json();
		if (result.success) location.reload();
	}
}

