<div class="d-flex justify-content-between align-items-center mb-4">
	<div class="d-flex align-items-center">
		<a href="/admin/services" class="btn btn-light border me-3 d-flex align-items-center">
			<i class="bi bi-arrow-left me-2"></i> Daftar Divisi
		</a>
		<div>
			<h4 class="fw-bold mb-1 text-dark">Ruang Kelola Divisi: <%= service.title %></h4>
			<p class="text-muted small mb-0"><%= service.subtitle || 'Manajemen lengkap spesifikasi, paket harga, portofolio & ulasan' %></p>
		</div>
	</div>
	<div class="d-flex gap-2">
		<button class="btn btn-outline-primary d-flex align-items-center" onclick="openEditServiceModal(<%= JSON.stringify(service) %>)">
			<i class="bi bi-pencil-square me-2"></i> Edit Info & Keunggulan Divisi
		</button>
	</div>
</div>

<!-- Overview Info Card -->
<div class="card border-0 shadow-sm rounded-4 mb-4 overflow-hidden">
	<div class="card-body p-4">
		<div class="row align-items-center">
			<div class="col-md-7 border-end pe-md-4">
				<div class="d-flex align-items-center mb-3">
					<span class="badge bg-primary bg-opacity-10 text-primary px-3 py-2 rounded-pill fw-bold text-uppercase me-3">
						<%= service.id %> DIVISION
					</span>
					<span class="text-muted small"><i class="bi bi-clock me-1"></i> Terakhir diperbarui: <%= new Date(service.updatedAt).toLocaleDateString('id-ID') %></span>
				</div>
				<h5 class="fw-bold text-dark mb-2"><%= service.title %> — <%= service.subtitle %></h5>
				<p class="text-muted mb-3 small"><%= service.heroDesc || service.description %></p>
				<p class="text-secondary small mb-0"><%= service.fullDesc || service.description %></p>
			</div>
			<div class="col-md-5 ps-md-4 mt-3 mt-md-0">
				<h6 class="fw-bold small text-uppercase text-dark mb-3"><i class="bi bi-stars text-warning me-1"></i> Key Features / Keunggulan Divisi</h6>
				<% if (features && features.length > 0) { %>
					<ul class="list-unstyled mb-0 small">
						<% features.forEach(function(feat) { %>
							<li class="mb-2 d-flex align-items-start">
								<i class="bi bi-check-circle-fill text-success me-2 mt-1 flex-shrink-0"></i>
								<span><%= feat %></span>
							</li>
						<% }); %>
					</ul>
				<% } else { %>
					<p class="text-muted small mb-0 fst-italic">Belum ada daftar keunggulan divisi yang diisi.</p>
				<% } %>
			</div>
		</div>
	</div>
</div>

<!-- Tabs Navigation -->
<ul class="nav nav-pills gap-2 mb-4 p-2 bg-white rounded-3 shadow-sm border" id="serviceDetailTab" role="tablist">
	<li class="nav-item" role="presentation">
		<button class="nav-link active fw-medium px-4 py-2" id="packages-tab" data-bs-toggle="pill" data-bs-target="#packages-pane" type="button" role="tab">
			<i class="bi bi-tag me-2"></i>Paket Harga & Investasi
			<span class="badge bg-primary ms-2 rounded-pill"><%= service.packages ? service.packages.length : 0 %></span>
		</button>
	</li>
	<li class="nav-item" role="presentation">
		<button class="nav-link fw-medium px-4 py-2" id="portfolios-tab" data-bs-toggle="pill" data-bs-target="#portfolios-pane" type="button" role="tab">
			<i class="bi bi-images me-2"></i>Showcase Proyek
			<span class="badge bg-secondary ms-2 rounded-pill"><%= portfolios ? portfolios.length : 0 %></span>
		</button>
	</li>
	<li class="nav-item" role="presentation">
		<button class="nav-link fw-medium px-4 py-2" id="testimonials-tab" data-bs-toggle="pill" data-bs-target="#testimonials-pane" type="button" role="tab">
			<i class="bi bi-chat-quote me-2"></i>Testimoni & Komentar Klien
			<span class="badge bg-secondary ms-2 rounded-pill"><%= testimonials ? testimonials.length : 0 %></span>
		</button>
	</li>
</ul>

<div class="tab-content" id="serviceDetailTabContent">
	<!-- ========================
	     TAB 1: PAKET HARGA
	======================== -->
	<div class="tab-pane fade show active" id="packages-pane" role="tabpanel">
		<div class="card border-0 shadow-sm rounded-4 p-4">
			<div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom">
				<div>
					<h5 class="fw-bold mb-1">Daftar Paket Harga & Fitur Paket</h5>
					<p class="text-muted small mb-0">Paket penawaran harga yang tampil pada halaman detail dan halaman layanan</p>
				</div>
				<button class="btn btn-primary d-flex align-items-center px-4" onclick="openAddPackageModal('<%= service.id %>')">
					<i class="bi bi-plus-lg me-2"></i> Tambah Paket Harga
				</button>
			</div>

			<% if (service.packages && service.packages.length > 0) { %>
				<div class="row g-4">
					<% service.packages.forEach(function(pkg) { %>
						<% 
							let pkgFeatures = [];
							try { pkgFeatures = typeof pkg.features === 'string' ? JSON.parse(pkg.features) : (pkg.features || []); } catch(e){}
						%>
						<div class="col-md-4">
							<div class="card h-100 border rounded-4 <%= pkg.isPopular ? 'border-primary border-2 shadow-sm' : '' %>">
								<div class="card-header bg-white border-bottom p-4 d-flex justify-content-between align-items-start">
									<div>
										<h5 class="fw-bold mb-1 text-dark"><%= pkg.name %></h5>
										<h4 class="fw-bold text-primary mb-0"><%= pkg.price %></h4>
									</div>
									<% if (pkg.isPopular) { %>
										<span class="badge bg-primary rounded-pill px-3 py-1">POPULAR</span>
									<% } %>
								</div>
								<div class="card-body p-4 d-flex flex-column justify-content-between">
									<div class="mb-4">
										<h6 class="fw-bold small text-uppercase text-muted mb-3">Spesifikasi & Fitur:</h6>
										<% if (pkgFeatures.length > 0) { %>
											<ul class="list-unstyled mb-0 small">
												<% pkgFeatures.forEach(function(pf) { %>
													<li class="mb-2 d-flex align-items-start">
														<i class="bi bi-check-circle text-primary me-2 mt-1"></i>
														<span><%= pf %></span>
													</li>
												<% }); %>
											</ul>
										<% } else { %>
											<p class="text-muted small mb-0">Belum ada fitur paket dicantumkan.</p>
										<% } %>
									</div>
									<div class="d-flex gap-2 pt-3 border-top">
										<button class="btn btn-sm btn-light border w-100 d-flex align-items-center justify-content-center" onclick='openEditPackageModal(<%= JSON.stringify(pkg) %>)'>
											<i class="bi bi-pencil me-1"></i> Edit Paket
										</button>
										<button class="btn btn-sm btn-outline-danger" title="Hapus Paket" onclick="deletePackageAction('<%= pkg.id %>')">
											<i class="bi bi-trash"></i>
										</button>
									</div>
								</div>
							</div>
						</div>
					<% }); %>
				</div>
			<% } else { %>
				<div class="text-center py-5 text-muted">
					<i class="bi bi-tag fs-1 mb-3 d-block text-secondary"></i>
					<p class="mb-0">Belum ada paket harga untuk divisi ini.</p>
				</div>
			<% } %>
		</div>
	</div>

	<!-- ========================
	     TAB 2: SHOWCASE PROYEK
	======================== -->
	<div class="tab-pane fade" id="portfolios-pane" role="tabpanel">
		<div class="card border-0 shadow-sm rounded-4 p-4">
			<div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom">
				<div>
					<h5 class="fw-bold mb-1">Galeri Showcase Proyek & Portofolio</h5>
					<p class="text-muted small mb-0">Daftar implementasi proyek sukses atau studi kasus divisi ini</p>
				</div>
				<button class="btn btn-primary d-flex align-items-center px-4" onclick="openAddPortfolioModal('<%= service.id %>')">
					<i class="bi bi-plus-lg me-2"></i> Tambah Proyek
				</button>
			</div>

			<% if (portfolios && portfolios.length > 0) { %>
				<div class="row g-4">
					<% portfolios.forEach(function(port, idx) { %>
						<div class="col-md-4">
							<div class="card h-100 border rounded-4 overflow-hidden">
								<% if (port.image) { %>
									<img src="<%= port.image %>" class="card-img-top" alt="<%= port.title %>" style="height: 180px; object-fit: cover;">
								<% } else { %>
									<div class="bg-light text-center py-5 text-muted small">Tanpa Gambar Preview</div>
								<% } %>
								<div class="card-body p-4 d-flex flex-column justify-content-between">
									<div>
										<span class="badge bg-secondary bg-opacity-10 text-secondary mb-2"><%= port.category || service.title %></span>
										<h6 class="fw-bold text-dark mb-2"><%= port.title %></h6>
										<p class="text-muted small mb-0"><%= port.desc || 'Tidak ada deskripsi tambahan' %></p>
									</div>
									<div class="d-flex gap-2 pt-3 mt-3 border-top">
										<button class="btn btn-sm btn-light border w-100 d-flex align-items-center justify-content-center" onclick="openEditPortfolioModal('<%= service.id %>', '<%= port.id || idx %>', `<%= port.title %>`, `<%= port.category || '' %>`, `<%= port.image || '' %>`, `<%= port.desc || '' %>`)">
											<i class="bi bi-pencil me-1"></i> Edit Proyek
										</button>
										<button class="btn btn-sm btn-outline-danger" title="Hapus Proyek" onclick="deletePortfolioAction('<%= service.id %>', '<%= port.id || idx %>', `<%= port.title %>`)">
											<i class="bi bi-trash"></i>
										</button>
									</div>
								</div>
							</div>
						</div>
					<% }); %>
				</div>
			<% } else { %>
				<div class="text-center py-5 text-muted">
					<i class="bi bi-images fs-1 mb-3 d-block text-secondary"></i>
					<p class="mb-0">Belum ada showcase proyek untuk divisi ini.</p>
				</div>
			<% } %>
		</div>
	</div>

	<!-- ========================
	     TAB 3: TESTIMONI KLIEN
	======================== -->
	<div class="tab-pane fade" id="testimonials-pane" role="tabpanel">
		<div class="card border-0 shadow-sm rounded-4 p-4">
			<div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom">
				<div>
					<h5 class="fw-bold mb-1">Testimoni & Komentar Klien Divisi</h5>
					<p class="text-muted small mb-0">Ulasan nyata dari klien atau mitra bisnis untuk memperkuat kepercayaan enterprise</p>
				</div>
				<button class="btn btn-primary d-flex align-items-center px-4" onclick="openAddTestimonialModal('<%= service.id %>')">
					<i class="bi bi-plus-lg me-2"></i> Tambah Testimoni
				</button>
			</div>

			<% if (testimonials && testimonials.length > 0) { %>
				<div class="row g-4">
					<% testimonials.forEach(function(testi, idx) { %>
						<div class="col-md-6">
							<div class="card h-100 border rounded-4 p-4 bg-light bg-opacity-50">
								<div class="card-body p-0 d-flex flex-column justify-content-between">
									<blockquote class="blockquote small mb-4 text-dark fst-italic">
										"<%= testi.quote %>"
									</blockquote>
									<div class="d-flex justify-content-between align-items-center pt-3 border-top">
										<div>
											<div class="fw-bold small text-dark"><%= testi.name %></div>
											<div class="text-muted" style="font-size: 0.75rem;"><%= testi.company %></div>
										</div>
										<div class="d-flex gap-1">
											<button class="btn btn-sm btn-light border" title="Edit Testimoni" onclick="openEditTestimonialModal('<%= service.id %>', '<%= testi.id || idx %>', `<%= testi.name %>`, `<%= testi.company || '' %>`, `<%= testi.quote || '' %>`)">
												<i class="bi bi-pencil text-primary"></i>
											</button>
											<button class="btn btn-sm btn-light border" title="Hapus Testimoni" onclick="deleteTestimonialAction('<%= service.id %>', '<%= testi.id || idx %>', `<%= testi.name %>`)">
												<i class="bi bi-trash text-danger"></i>
											</button>
										</div>
									</div>
								</div>
							</div>
						</div>
					<% }); %>
				</div>
			<% } else { %>
				<div class="text-center py-5 text-muted">
					<i class="bi bi-chat-quote fs-1 mb-3 d-block text-secondary"></i>
					<p class="mb-0">Belum ada testimoni klien untuk divisi ini.</p>
				</div>
			<% } %>
		</div>
	</div>
</div>

<!-- ========================
     ALL INTERACTIVE MODALS
======================== -->

<!-- Modal Edit Info & Keunggulan Divisi -->
<div class="modal fade" id="editServiceModal" tabindex="-1">
	<div class="modal-dialog modal-lg modal-dialog-centered">
		<div class="modal-content">
			<div class="modal-header bg-white border-bottom">
				<h5 class="modal-title fw-bold">Edit Info & Keunggulan Divisi</h5>
				<button type="button" class="btn-close" data-bs-dismiss="modal"></button>
			</div>
			<div class="modal-body p-4">
				<input type="hidden" id="editSvcId">
				<div class="row">
					<div class="col-md-6 mb-3">
						<label class="form-label fw-medium">Judul Divisi <span class="text-danger">*</span></label>
						<input type="text" class="form-control" id="editSvcTitle" required>
					</div>
					<div class="col-md-6 mb-3">
						<label class="form-label fw-medium">Pilihan Ikon</label>
						<select class="form-select" id="editSvcIcon">
							<option value="FaLaptopCode">FaLaptopCode (Software/Web)</option>
							<option value="FaWifi">FaWifi (Jaringan/ISP)</option>
							<option value="FaRegNewspaper">FaRegNewspaper (Media/Berita)</option>
							<option value="FaCloud">FaCloud (Cloud Server)</option>
							<option value="FaShieldAlt">FaShieldAlt (Cyber Security)</option>
							<option value="FaServer">FaServer (Data Center)</option>
						</select>
					</div>
					<div class="col-12 mb-3">
						<label class="form-label fw-medium">Subjudul / Tagline Divisi</label>
						<input type="text" class="form-control" id="editSvcSubtitle">
					</div>
					<div class="col-12 mb-3">
						<label class="form-label fw-medium">Deskripsi Singkat <span class="text-danger">*</span></label>
						<textarea class="form-control" id="editSvcDescription" rows="2" required></textarea>
					</div>
					<div class="col-12 mb-3">
						<label class="form-label fw-medium">Deskripsi Hero & Detail Lengkap</label>
						<textarea class="form-control" id="editSvcFullDesc" rows="3"></textarea>
					</div>
					<div class="col-12 mb-3">
						<label class="form-label fw-medium">Key Features / Keunggulan Divisi</label>
						<textarea class="form-control" id="editSvcFeaturesInput" rows="4" placeholder="Satu fitur per baris"></textarea>
						<small class="text-muted">Setiap baris akan menjadi poin keunggulan divisi ini.</small>
					</div>
				</div>
			</div>
			<div class="modal-footer bg-light">
				<button type="button" class="btn btn-light border" data-bs-dismiss="modal">Batal</button>
				<button type="button" class="btn btn-primary px-4" onclick="submitEditService()">Simpan Perubahan</button>
			</div>
		</div>
	</div>
</div>

<!-- Modal Tambah Paket Harga -->
<div class="modal fade" id="addPackageModal" tabindex="-1">
	<div class="modal-dialog modal-dialog-centered">
		<div class="modal-content">
			<div class="modal-header bg-white border-bottom">
				<h5 class="modal-title fw-bold">Tambah Paket Harga Baru</h5>
				<button type="button" class="btn-close" data-bs-dismiss="modal"></button>
			</div>
			<div class="modal-body p-4">
				<input type="hidden" id="pkgServiceId" value="<%= service.id %>">
				<div class="mb-3">
					<label class="form-label fw-medium">Nama Paket <span class="text-danger">*</span></label>
					<input type="text" class="form-control" id="addPkgName" required placeholder="Contoh: BUSINESS PRO">
				</div>
				<div class="mb-3">
					<label class="form-label fw-medium">Harga Display <span class="text-danger">*</span></label>
					<input type="text" class="form-control" id="addPkgPrice" required placeholder="Contoh: Rp 850.000 / bln">
				</div>
				<div class="mb-3">
					<label class="form-label fw-medium">Key Features Paket Harga (Satu per baris)</label>
					<textarea class="form-control" id="addPkgFeaturesInput" rows="4" placeholder="Contoh:&#10;Speed Up to 150 Mbps&#10;Unlimited Quota FUP Free"></textarea>
				</div>
				<div class="form-check form-switch mb-2">
					<input class="form-check-input" type="checkbox" id="addPkgIsPopularSwitch">
					<label class="form-check-label fw-medium" for="addPkgIsPopularSwitch">Tandai sebagai Paket Rekomendasi (Popular Badge)</label>
				</div>
			</div>
			<div class="modal-footer bg-light">
				<button type="button" class="btn btn-light border" data-bs-dismiss="modal">Batal</button>
				<button type="button" class="btn btn-primary px-4" onclick="submitCreatePackage()">Simpan Paket</button>
			</div>
		</div>
	</div>
</div>

