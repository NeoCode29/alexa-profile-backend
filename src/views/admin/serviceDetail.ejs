			<div class="modal-footer bg-light">
				<button type="button" class="btn btn-light border" data-bs-dismiss="modal">Batal</button>
				<button type="button" class="btn btn-primary px-4" onclick="submitEditPackage()">Simpan Perubahan</button>
			</div>
		</div>
	</div>
</div>

<!-- Modal Tambah Showcase Proyek -->
<div class="modal fade" id="addPortfolioModal" tabindex="-1">
	<div class="modal-dialog modal-dialog-centered">
		<div class="modal-content">
			<div class="modal-header bg-white border-bottom">
				<h5 class="modal-title fw-bold">Tambah Showcase Proyek</h5>
				<button type="button" class="btn-close" data-bs-dismiss="modal"></button>
			</div>
			<div class="modal-body p-4">
