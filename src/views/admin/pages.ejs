              <input type="text" class="form-control" name="heroTitleHighlight" value="<%= pagesData.home.heroTitleHighlight %>" required>
            </div>
            <div class="col-12 mb-3">
              <label class="form-label fw-medium">Deskripsi Hero</label>
              <textarea class="form-control" name="heroDesc" rows="3" required><%= pagesData.home.heroDesc %></textarea>
            </div>
            <div class="col-md-6 mb-3">
              <label class="form-label fw-medium">Teks Tombol CTA Utama</label>
              <input type="text" class="form-control" name="ctaPrimaryText" value="<%= pagesData.home.ctaPrimaryText %>" required>
            </div>
            <div class="col-md-6 mb-3">
              <label class="form-label fw-medium">Teks Tombol CTA Sekunder</label>
              <input type="text" class="form-control" name="ctaSecondaryText" value="<%= pagesData.home.ctaSecondaryText %>" required>
            </div>
          </div>
        </div>
      </div>

      <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white py-3 border-bottom d-flex align-items-center">
          <i class="ti ti-info-circle text-primary fs-4 me-2"></i>
          <h5 class="card-title fw-bold mb-0">Intro Section (Fundamen Solid & Statistik)</h5>
        </div>
        <div class="card-body p-4">
          <div class="mb-3">
            <label class="form-label fw-medium">Judul Intro</label>
            <input type="text" class="form-control" name="introTitle" value="<%= pagesData.home.introTitle %>" required>
          </div>
          <div class="mb-3">
            <label class="form-label fw-medium">Deskripsi Intro Perusahaan</label>
            <textarea class="form-control" name="introDesc" rows="3" required><%= pagesData.home.introDesc %></textarea>
          </div>

          <h6 class="fw-bold mt-4 mb-3 border-top pt-3">3 Kotak Statistik Pencapaian</h6>
