      </div>

      <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white py-3 border-bottom">
          <h5 class="card-title fw-bold mb-0">Sejarah Perusahaan</h5>
        </div>
        <div class="card-body p-4">
          <div class="mb-3">
            <label class="form-label fw-medium">Judul Bagian Sejarah</label>
            <input type="text" class="form-control" name="historyTitle" value="<%= pagesData.about.historyTitle %>" required>
          </div>
          <div class="mb-3">
            <label class="form-label fw-medium">Paragraf Sejarah 1</label>
            <textarea class="form-control" name="historyPar1" rows="3" required><%= pagesData.about.historyPar1 %></textarea>
          </div>
          <div class="mb-3">
            <label class="form-label fw-medium">Paragraf Sejarah 2</label>
            <textarea class="form-control" name="historyPar2" rows="3" required><%= pagesData.about.historyPar2 %></textarea>
          </div>

          <h6 class="fw-bold mt-4 mb-3 border-top pt-3">Kartu Timeline Sejarah (Kanan)</h6>
          <div class="row">
            <% const timelines = pagesData.about.timelineList || [
                 { year: '2018', title: 'PENDIRIAN WEBMEDIA', desc: 'Fokus awal pada arsitektur sistem informasi enterprise.' },
                 { year: '2020', title: 'EKSPANSI INETMEDIA', desc: 'Memperoleh lisensi ISP nasional untuk infrastruktur jaringan.' },
                 { year: '2023', title: 'AKUISISI MEDIAKAMPUNG', desc: 'Membentuk pilar media digital yang kuat.' }
               ]; %>
            <% timelines.forEach(function(tl, index) { %>
              <div class="col-md-4 mb-3">
                <div class="p-3 border rounded bg-light">
                  <label class="form-label fw-bold">Tahun Timeline <%= index + 1 %></label>
                  <input type="text" class="form-control mb-2" name="timelineYear_<%= index %>" value="<%= tl.year %>" required>
                  <label class="form-label fw-medium small">Judul Timeline</label>
                  <input type="text" class="form-control mb-2" name="timelineTitle_<%= index %>" value="<%= tl.title %>" required>
                  <label class="form-label fw-medium small">Deskripsi Singkat</label>
                  <textarea class="form-control" name="timelineDesc_<%= index %>" rows="2" required><%= tl.desc %></textarea>
                </div>
              </div>
            <% }); %>
          </div>
        </div>
      </div>

      <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white py-3 border-bottom">
          <h5 class="card-title fw-bold mb-0">Visi & Misi Perusahaan</h5>
        </div>
        <div class="card-body p-4">
          <div class="mb-4">
            <label class="form-label fw-medium">Visi Perusahaan</label>
            <textarea class="form-control" name="visionText" rows="3" required><%= pagesData.about.visionText %></textarea>
          </div>
          <div class="mb-3">
            <label class="form-label fw-medium">Misi 1</label>
            <input type="text" class="form-control mb-2" name="mission0" value="<%= pagesData.about.missionList[0] || '' %>">
            <label class="form-label fw-medium">Misi 2</label>
            <input type="text" class="form-control mb-2" name="mission1" value="<%= pagesData.about.missionList[1] || '' %>">
            <label class="form-label fw-medium">Misi 3</label>
            <input type="text" class="form-control" name="mission2" value="<%= pagesData.about.missionList[2] || '' %>">
          </div>
        </div>
      </div>

      <div class="text-end mb-5">
        <button type="submit" class="btn btn-primary px-4 py-2 fw-semibold">
          <i class="ti ti-device-floppy me-2"></i>Simpan Perubahan Halaman About
        </button>
      </div>
    </form>
  </div>

  <!-- ========================================== -->
  <!-- TAB 3: HALAMAN LAYANAN (SERVICES) -->
  <!-- ========================================== -->
  <div class="tab-pane fade" id="tab-services" role="tabpanel">
    <form id="form-services" onsubmit="savePageContent(event, 'services')">
      <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white py-3 border-bottom">
          <h5 class="card-title fw-bold mb-0">Hero Halaman Layanan</h5>
        </div>
        <div class="card-body p-4">
          <div class="mb-3">
            <label class="form-label fw-medium">Judul Utama Layanan</label>
