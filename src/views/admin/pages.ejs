<!-- Quill Rich Text Editor CSS -->
<link href="https://cdn.jsdelivr.net/npm/quill@2.0.2/dist/quill.snow.css" rel="stylesheet" />

<!-- Custom Clean & Minimalist Styling (Konsisten dengan manajemen detail layanan / serviceDetail.ejs) -->
<style>
	.ql-toolbar.ql-snow {
		border-top-left-radius: 8px;
		border-top-right-radius: 8px;
		border-color: #e2e8f0 !important;
		background: #f8fafc;
	}
	.ql-container.ql-snow {
		border-bottom-left-radius: 8px;
		border-bottom-right-radius: 8px;
		border-color: #e2e8f0 !important;
		background: #ffffff;
		font-family: inherit;
		font-size: 0.95rem;
	}
	.clean-card {
		background: #ffffff;
		border: 1px solid #e2e8f0;
		border-radius: 12px;
		box-shadow: 0 1px 3px rgba(15, 23, 42, 0.04);
		overflow: hidden;
		margin-bottom: 24px;
	}
	.clean-card-header {
		padding: 16px 20px;
		border-bottom: 1px solid #f1f5f9;
		background: #fafbfc;
		font-weight: 600;
		color: #1e293b;
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	.header-card {
		background: #ffffff;
		border: 1px solid #e2e8f0;
		border-radius: 12px;
		box-shadow: 0 1px 3px rgba(15, 23, 42, 0.03);
		overflow: hidden;
	}
	.nav-simple {
		gap: 16px;
		padding: 0 20px;
	}
	.nav-simple .nav-link {
		color: #64748b;
		font-weight: 600;
		padding: 14px 12px;
		border: none;
		border-bottom: 3px solid transparent;
		margin-bottom: -1px;
		background: transparent;
		display: inline-flex;
		align-items: center;
		font-size: 0.95rem;
		transition: all 0.15s ease;
	}
	.nav-simple .nav-link:hover {
		color: #1e293b;
	}
	.nav-simple .nav-link.active {
		color: #3BAE7C !important;
		border-bottom-color: #3BAE7C !important;
	}
	.seo-badge {
		font-size: 0.72rem;
		font-weight: 600;
		padding: 3px 8px;
		border-radius: 6px;
	}
	.seo-preview-box {
		background: #ffffff;
		border: 1px solid #e2e8f0;
		border-radius: 10px;
		padding: 16px;
		box-shadow: 0 1px 2px rgba(0,0,0,0.03);
	}
	.google-preview-title {
		color: #1a0dab;
		font-size: 1.1rem;
		font-weight: 500;
		margin-bottom: 2px;
		line-height: 1.3;
	}
	.google-preview-url {
		color: #006621;
		font-size: 0.85rem;
		margin-bottom: 4px;
	}
	.google-preview-desc {
		color: #4d5156;
		font-size: 0.875rem;
		line-height: 1.4;
	}
	.form-label-desc {
		font-size: 0.8rem;
		color: #64748b;
		margin-top: 2px;
	}
</style>

<!-- Unified Header Card with Navigation Tabs -->
<div class="header-card mb-4">
	<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 p-4 pb-3">
		<div>
			<div class="d-flex align-items-center gap-2 mb-1">
				<h4 class="fw-bold mb-0 text-dark">Manajemen Halaman & SEO Frontend</h4>
			</div>
			<p class="text-muted mb-0 small">Kelola teks konten, deskripsi halaman, dan pengaturan SEO (Title, Meta Description, OpenGraph) untuk setiap halaman website secara real-time.</p>
		</div>
	</div>

	<!-- Simple Tabs Navigation -->
	<ul class="nav nav-simple border-top" id="pageCMSNav" role="tablist">
		<li class="nav-item" role="presentation">
			<button class="nav-link active" id="home-tab" data-bs-toggle="tab" data-bs-target="#tab-home" type="button" role="tab">
				<i class="ti ti-home me-2"></i>Beranda (Home)
			</button>
		</li>
		<li class="nav-item" role="presentation">
			<button class="nav-link" id="about-tab" data-bs-toggle="tab" data-bs-target="#tab-about" type="button" role="tab">
				<i class="ti ti-building me-2"></i>Tentang Kami (About)
			</button>
		</li>
		<li class="nav-item" role="presentation">
			<button class="nav-link" id="services-tab" data-bs-toggle="tab" data-bs-target="#tab-services" type="button" role="tab">
				<i class="ti ti-briefcase me-2"></i>Layanan & Divisi (Services)
			</button>
		</li>
		<li class="nav-item" role="presentation">
			<button class="nav-link" id="contact-tab" data-bs-toggle="tab" data-bs-target="#tab-contact" type="button" role="tab">
				<i class="ti ti-phone me-2"></i>Kontak (Contact)
			</button>
		</li>
	</ul>
</div>

<div class="tab-content" id="pageCMSContent">

	<!-- ========================================== -->
	<!-- TAB 1: BERANDA (HOME) -->
	<!-- ========================================== -->
	<div class="tab-pane fade show active" id="tab-home" role="tabpanel">
		<form id="form-home" onsubmit="savePageContent(event, 'home')">

			<!-- SEO & Meta Tags Card -->
			<div class="clean-card">
				<div class="clean-card-header">
					<div class="d-flex align-items-center">
						<i class="ti ti-seo text-primary fs-5 me-2"></i>
						<span>Pengaturan SEO & Meta Tags — Halaman Beranda</span>
					</div>
					<span class="badge bg-primary-subtle text-primary seo-badge">SEO OPTIMIZATION</span>
				</div>
				<div class="p-4">
					<div class="row g-3">
						<div class="col-md-7">
							<div class="mb-3">
								<label class="form-label fw-medium text-dark">Meta Title (Judul Tab & Hasil Pencarian)</label>
								<input type="text" class="form-control" name="seoTitle" id="home-seoTitle" value="<%= pagesData.home.seoTitle || '' %>" oninput="updateGooglePreview('home')" placeholder="Contoh: Beranda — PT. Alexa Computindo Group">
								<div class="form-label-desc">Disarankan 50-60 karakter agar tampil sempurna di Google.</div>
							</div>
							<div class="mb-3">
								<label class="form-label fw-medium text-dark">Meta Description (Deskripsi Singkat SEO)</label>
								<textarea class="form-control" name="seoDescription" id="home-seoDesc" rows="3" oninput="updateGooglePreview('home')" placeholder="Deskripsi halaman yang muncul di bawah judul Google..."><%= pagesData.home.seoDescription || '' %></textarea>
								<div class="form-label-desc">Disarankan 140-160 karakter untuk menarik klik pengunjung.</div>
							</div>
							<div class="mb-3">
								<label class="form-label fw-medium text-dark">Meta Keywords (Kata Kunci)</label>
								<input type="text" class="form-control chip-input" name="seoKeywords" value="<%= pagesData.home.seoKeywords || '' %>" placeholder="alexa computindo, isp, software enterprise">
							</div>
							<div class="mb-3">
								<label class="form-label fw-medium text-dark">OpenGraph Image URL</label>
								<input type="text" class="form-control" name="seoOgImage" value="<%= pagesData.home.seoOgImage || '' %>" placeholder="/assets/img/og-home.png">
							</div>
						</div>
						<div class="col-md-5">
							<label class="form-label fw-medium text-dark mb-2">Simulasi Tampilan Pencarian Google:</label>
							<div class="seo-preview-box">
								<div class="google-preview-url">https://alexagroup.com/</div>
								<div class="google-preview-title" id="home-preview-title"><%= pagesData.home.seoTitle || 'PT. Alexa Computindo Group' %></div>
								<div class="google-preview-desc" id="home-preview-desc"><%= pagesData.home.seoDescription || 'Solusi teknologi terintegrasi untuk perusahaan dan infrastruktur digital.' %></div>
							</div>
						</div>
					</div>
				</div>
			</div>

			<!-- Hero Section Card -->
			<div class="clean-card">
				<div class="clean-card-header">
					<div class="d-flex align-items-center">
						<i class="ti ti-layout-navbar text-primary fs-5 me-2"></i>
						<span>Hero Section Utama (Banner Beranda)</span>
					</div>
				</div>
				<div class="p-4">
					<div class="row g-3">
						<div class="col-md-6">
							<label class="form-label fw-medium text-dark">Judul Hero Baris 1</label>
							<input type="text" class="form-control" name="heroTitleLine1" value="<%= pagesData.home.heroTitleLine1 || '' %>" required>
						</div>
						<div class="col-md-6">
							<label class="form-label fw-medium text-dark">Judul Hero Baris 2 <span class="text-success fw-bold">(Sorotan Warna Hijau)</span></label>
							<input type="text" class="form-control" name="heroTitleHighlight" value="<%= pagesData.home.heroTitleHighlight || '' %>" required>
						</div>
						<div class="col-12">
							<label class="form-label fw-medium text-dark">Deskripsi Utama Hero</label>
							<textarea class="form-control" name="heroDesc" rows="3" required><%= pagesData.home.heroDesc || '' %></textarea>
						</div>
					</div>
				</div>
			</div>

			<!-- Intro & Statistik Card -->
			<div class="clean-card">
				<div class="clean-card-header">
					<div class="d-flex align-items-center">
						<i class="ti ti-chart-bar text-primary fs-5 me-2"></i>
						<span>Intro & Pencapaian Statistik Perusahaan</span>
					</div>
				</div>
				<div class="p-4">
					<div class="row g-3 mb-4">
						<div class="col-md-6">
							<label class="form-label fw-medium text-dark">Judul Bagian Intro</label>
							<input type="text" class="form-control" name="introTitle" value="<%= pagesData.home.introTitle || '' %>" required>
						</div>
						<div class="col-md-6">
							<label class="form-label fw-medium text-dark">Deskripsi Bagian Intro</label>
							<textarea class="form-control" name="introDesc" rows="2" required><%= pagesData.home.introDesc || '' %></textarea>
						</div>
					</div>
					<h6 class="fw-bold mb-3 text-dark border-top pt-3">3 Pilar Statistik Pencapaian</h6>
					<div class="row g-3">
						<div class="col-md-4">
							<div class="p-3 border rounded-3 bg-light">
								<label class="form-label fw-bold small text-muted">STATISTIK 1</label>
								<input type="text" class="form-control mb-2" name="stat1Number" value="<%= pagesData.home.stat1Number || '' %>" placeholder="8+">
								<input type="text" class="form-control form-control-sm" name="stat1Label" value="<%= pagesData.home.stat1Label || '' %>" placeholder="Tahun Pengalaman">
							</div>
						</div>
						<div class="col-md-4">
							<div class="p-3 border rounded-3 bg-light">
								<label class="form-label fw-bold small text-muted">STATISTIK 2</label>
								<input type="text" class="form-control mb-2" name="stat2Number" value="<%= pagesData.home.stat2Number || '' %>" placeholder="99.9%">
								<input type="text" class="form-control form-control-sm" name="stat2Label" value="<%= pagesData.home.stat2Label || '' %>" placeholder="Uptime Server">
							</div>
						</div>
						<div class="col-md-4">
							<div class="p-3 border rounded-3 bg-light">
								<label class="form-label fw-bold small text-muted">STATISTIK 3</label>
								<input type="text" class="form-control mb-2" name="stat3Number" value="<%= pagesData.home.stat3Number || '' %>" placeholder="200+">
								<input type="text" class="form-control form-control-sm" name="stat3Label" value="<%= pagesData.home.stat3Label || '' %>" placeholder="Klien Enterprise">
							</div>
						</div>
					</div>
				</div>
			</div>

			<!-- Divisi Section Card -->
			<div class="clean-card">
				<div class="clean-card-header">
					<div class="d-flex align-items-center">
						<i class="ti ti-sitemap text-primary fs-5 me-2"></i>
						<span>Pengaturan Bagian Divisi Layanan (Services Section)</span>
					</div>
				</div>
				<div class="p-4">
					<div class="row g-3">
						<div class="col-md-6">
							<label class="form-label fw-medium text-dark">Judul Bagian Divisi</label>
							<input type="text" class="form-control" name="servicesSectionTitle" value="<%= pagesData.home.servicesSectionTitle || '' %>" required>
						</div>
						<div class="col-md-6">
							<label class="form-label fw-medium text-dark">Subjudul Bagian Divisi</label>
							<input type="text" class="form-control" name="servicesSectionSubtitle" value="<%= pagesData.home.servicesSectionSubtitle || '' %>" required>
						</div>
					</div>
				</div>
			</div>

			<!-- Klien & Berita Section Card -->
			<div class="clean-card">
				<div class="clean-card-header">
					<div class="d-flex align-items-center">
						<i class="ti ti-briefcase text-primary fs-5 me-2"></i>
						<span>Pengaturan Bagian Klien & Berita Insight</span>
					</div>
				</div>
				<div class="p-4">
					<div class="row g-3">
						<div class="col-md-6">
							<label class="form-label fw-medium text-dark">Judul Bagian Klien Enterprise</label>
							<input type="text" class="form-control" name="clientsSectionTitle" value="<%= pagesData.home.clientsSectionTitle || 'DIPERCAYA OLEH PERUSAHAAN TERKEMUKA' %>" required>
						</div>
						<div class="col-md-6">
							<label class="form-label fw-medium text-dark">Judul Bagian Berita & Insight</label>
							<input type="text" class="form-control" name="articlesSectionTitle" value="<%= pagesData.home.articlesSectionTitle || 'Berita & Insight' %>" required>
						</div>
					</div>
				</div>
			</div>

			<div class="d-flex justify-content-end gap-2 mb-5">
				<button type="submit" class="btn btn-primary px-4 py-2 fw-semibold shadow-sm">
					<i class="ti ti-device-floppy me-2"></i>Simpan Perubahan Beranda
				</button>
			</div>
		</form>
	</div>

	<!-- ========================================== -->
	<!-- TAB 2: TENTANG KAMI (ABOUT) -->
	<!-- ========================================== -->
	<div class="tab-pane fade" id="tab-about" role="tabpanel">
		<form id="form-about" onsubmit="savePageContent(event, 'about')">

			<!-- SEO & Meta Tags Card -->
			<div class="clean-card">
				<div class="clean-card-header">
					<div class="d-flex align-items-center">
						<i class="ti ti-seo text-primary fs-5 me-2"></i>
						<span>Pengaturan SEO & Meta Tags — Halaman Tentang Kami</span>
					</div>
					<span class="badge bg-primary-subtle text-primary seo-badge">SEO OPTIMIZATION</span>
				</div>
				<div class="p-4">
					<div class="row g-3">
						<div class="col-md-7">
							<div class="mb-3">
								<label class="form-label fw-medium text-dark">Meta Title (Judul Tab Browser)</label>
								<input type="text" class="form-control" name="seoTitle" id="about-seoTitle" value="<%= pagesData.about.seoTitle || '' %>" oninput="updateGooglePreview('about')">
							</div>
							<div class="mb-3">
								<label class="form-label fw-medium text-dark">Meta Description</label>
								<textarea class="form-control" name="seoDescription" id="about-seoDesc" rows="3" oninput="updateGooglePreview('about')"><%= pagesData.about.seoDescription || '' %></textarea>
							</div>
							<div class="mb-3">
								<label class="form-label fw-medium text-dark">Meta Keywords</label>
								<input type="text" class="form-control chip-input" name="seoKeywords" value="<%= pagesData.about.seoKeywords || '' %>">
							</div>
							<div class="mb-3">
								<label class="form-label fw-medium text-dark">OpenGraph Image URL</label>
								<input type="text" class="form-control" name="seoOgImage" value="<%= pagesData.about.seoOgImage || '' %>">
							</div>
						</div>
						<div class="col-md-5">
							<label class="form-label fw-medium text-dark mb-2">Simulasi Tampilan Pencarian Google:</label>
							<div class="seo-preview-box">
								<div class="google-preview-url">https://alexagroup.com/about</div>
								<div class="google-preview-title" id="about-preview-title"><%= pagesData.about.seoTitle || 'Tentang Kami — PT. Alexa Computindo Group' %></div>
								<div class="google-preview-desc" id="about-preview-desc"><%= pagesData.about.seoDescription || 'Profil, sejarah, dan visi misi PT. Alexa Computindo Group.' %></div>
							</div>
						</div>
					</div>
				</div>
			</div>

			<!-- Hero & Sejarah Perusahaan -->
			<div class="clean-card">
				<div class="clean-card-header">
					<div class="d-flex align-items-center">
						<i class="ti ti-building text-primary fs-5 me-2"></i>
						<span>Hero & Sejarah Perusahaan</span>
					</div>
				</div>
				<div class="p-4">
					<div class="row g-3">
						<div class="col-md-4">
							<label class="form-label fw-medium text-dark">Judul Utama Halaman</label>
							<input type="text" class="form-control" name="heroTitle" value="<%= pagesData.about.heroTitle || '' %>" required>
						</div>
						<div class="col-md-8">
							<label class="form-label fw-medium text-dark">Subjudul / Deskripsi Pembuka</label>
							<textarea class="form-control" name="heroDesc" rows="2" required><%= pagesData.about.heroDesc || '' %></textarea>
						</div>
						<div class="col-12 mt-3 border-top pt-3">
							<h6 class="fw-bold text-dark mb-3">Narasi Sejarah Perusahaan (Satu Rich Text Editor)</h6>
						</div>
						<div class="col-md-12 mb-2">
							<label class="form-label fw-medium text-dark">Judul Bagian Sejarah</label>
							<input type="text" class="form-control" name="historyTitle" value="<%= pagesData.about.historyTitle || '' %>" required>
						</div>
						<div class="col-md-12">
							<label class="form-label fw-medium text-dark">Konten Narasi Sejarah Perusahaan</label>
							<% 
								let initialHistory = pagesData.about.historyContent || pagesData.about.historyPar1 || '';
								if (!pagesData.about.historyContent && pagesData.about.historyPar2) {
									initialHistory += ' ' + pagesData.about.historyPar2;
								}
							%>
							<input type="hidden" name="historyContent" id="input-historyContent" value="<%= initialHistory %>">
							<input type="hidden" name="historyPar1" value="<%= initialHistory %>">
							<input type="hidden" name="historyPar2" value="">
							<div id="editor-historyContent" style="height: 220px;"></div>
						</div>
					</div>
				</div>
			</div>

			<!-- Visi & Misi Perusahaan (Rich Text Editor) -->
			<div class="clean-card">
				<div class="clean-card-header">
					<div class="d-flex align-items-center">
						<i class="ti ti-target text-primary fs-5 me-2"></i>
						<span>Visi & Misi Perusahaan (Rich Text Editor)</span>
					</div>
				</div>
				<div class="p-4">
					<div class="mb-4">
						<label class="form-label fw-bold text-dark">Pernyataan Visi Utama</label>
						<input type="hidden" name="visionText" id="input-visionText" value="<%= pagesData.about.visionText || '' %>">
						<div id="editor-visionText" style="height: 120px;"></div>
					</div>
					<div class="mb-2">
						<label class="form-label fw-bold text-dark">Misi Perusahaan</label>
						<% 
							let initialMissionRich = pagesData.about.missionRichText || '';
							if (!initialMissionRich && pagesData.about.missionList && pagesData.about.missionList.length > 0) {
								initialMissionRich = '<ul>' + pagesData.about.missionList.map(m => `<li>${m}</li>`).join('') + '</ul>';
							}
						%>
						<input type="hidden" name="missionRichText" id="input-missionRichText" value="<%= initialMissionRich %>">
						<div id="editor-missionRichText" style="height: 150px;"></div>
					</div>
				</div>
			</div>

			<!-- Timeline Sejarah (Dinamis) -->
			<div class="clean-card">
				<div class="clean-card-header">
					<div class="d-flex align-items-center">
						<i class="ti ti-timeline text-primary fs-5 me-2"></i>
						<span>Milestone / Timeline Sejarah (Dinamis)</span>
					</div>
				</div>
				<div class="p-4">
					<div id="timeline-container" class="row g-3"></div>
					<div class="mt-4 border-top pt-3">
						<button type="button" class="btn btn-primary btn-sm px-3 py-2 fw-semibold d-inline-flex align-items-center shadow-sm" style="font-size: 0.875rem; border-radius: 6px;" onclick="addTimelineItem()">
							<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="me-2"><path d="M12 5l0 14" /><path d="M5 12l14 0" /></svg>
							<span>Tambah Milestone / Timeline Baru</span>
						</button>
					</div>
				</div>
			</div>

			<!-- Manajemen Inti (Tim Manajemen Dinamis) -->
			<div class="clean-card">
				<div class="clean-card-header">
					<div class="d-flex align-items-center">
						<i class="ti ti-users text-primary fs-5 me-2"></i>
						<span>Manajemen Inti (Tim Manajemen Dinamis)</span>
					</div>
				</div>
				<div class="p-4">
					<div class="mb-4">
						<label class="form-label fw-medium text-dark">Judul Bagian Manajemen Inti</label>
						<input type="text" class="form-control" name="teamSectionTitle" value="<%= pagesData.about.teamSectionTitle || 'MANAJEMEN INTI' %>" required>
					</div>
					<div id="team-container" class="row g-3"></div>
					<div class="mt-4 border-top pt-3">
						<button type="button" class="btn btn-primary btn-sm px-3 py-2 fw-semibold d-inline-flex align-items-center shadow-sm" style="font-size: 0.875rem; border-radius: 6px;" onclick="addTeamItem()">
							<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="me-2"><path d="M12 5l0 14" /><path d="M5 12l14 0" /></svg>
							<span>Tambah Anggota Manajemen Inti</span>
						</button>
					</div>
				</div>
			</div>

			<div class="d-flex justify-content-end gap-2 mb-5">
				<button type="submit" class="btn btn-primary px-4 py-2 fw-semibold shadow-sm">
					<i class="ti ti-device-floppy me-2"></i>Simpan Perubahan Tentang Kami
				</button>
			</div>
