<!-- Quill JS -->
<script src="https://cdn.jsdelivr.net/npm/quill@2.0.2/dist/quill.js"></script>

<script>
let quillHistory, quillVision, quillMission;
let timelineItems = <%- JSON.stringify(pagesData.about.timelineList && pagesData.about.timelineList.length > 0 ? pagesData.about.timelineList : [
	{ year: "2018", title: "Pendirian WebMedia", desc: "Fokus awal pada arsitektur sistem informasi enterprise." },
	{ year: "2020", title: "Ekspansi InetMedia", desc: "Memperoleh lisensi ISP nasional untuk infrastruktur jaringan." },
	{ year: "2023", title: "Akuisisi MediaKampung", desc: "Membentuk pilar media digital yang kuat." }
]) %>;

let teamItems = <%- JSON.stringify(pagesData.about.teamList && pagesData.about.teamList.length > 0 ? pagesData.about.teamList : [
	{ name: 'Budi Santoso', role: 'Chief Executive Officer', bio: 'Berpengalaman 15 tahun di industri IT dan manajemen strategis.', image: 'https://images.unsplash.com/photo-1560250097-0b93528c311a?w=400&q=80' },
	{ name: 'Siti Aminah', role: 'Chief Operating Officer', bio: 'Ahli dalam operasional bisnis dan pengembangan produk digital.', image: 'https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?w=400&q=80' },
	{ name: 'Andi Pratama', role: 'CTO / Head of Engineering', bio: 'Pakar arsitektur cloud, keamanan siber, dan jaringan berskala besar.', image: 'https://images.unsplash.com/photo-1519085360753-af0119f7cbe7?w=400&q=80' }
]) %>;

let faqItems = <%- JSON.stringify(pagesData.contact.faqList && pagesData.contact.faqList.length > 0 ? pagesData.contact.faqList : [
	{ q: 'Dimana lokasi operasional PT. Alexa Computindo Group?', a: 'Kantor pusat kami berlokasi di Jl. Teknologi No. 45, Jakarta Selatan. Kami melayani kunjungan klien enterprise pada hari kerja (Senin - Jumat), pukul 09:00 - 17:00 WIB.' },
	{ q: 'Apakah layanan pengembangan software (WebMedia) termasuk maintenance?', a: 'Ya, seluruh proyek perangkat lunak dari WebMedia memiliki SLA dan masa maintenance mulai dari 3 hingga 12 bulan, yang dapat diperpanjang melalui kontrak support enterprise.' },
	{ q: 'Berapa lama proses pemasangan internet corporate InetMedia?', a: 'Proses survei, penarikan kabel fiber optik, dan aktivasi internet khusus corporate rata-rata memakan waktu 3-5 hari kerja setelah SPK disetujui.' }
]) %>;

document.addEventListener("DOMContentLoaded", function() {
	const toolbarOptions = [
		['bold', 'italic', 'underline'],
		[{ 'list': 'ordered'}, { 'list': 'bullet' }],
		['clean']
	];

	if (document.getElementById('editor-historyContent')) {
		quillHistory = new Quill('#editor-historyContent', { theme: 'snow', modules: { toolbar: toolbarOptions } });
		quillHistory.root.innerHTML = document.getElementById('input-historyContent').value;
	}
	if (document.getElementById('editor-visionText')) {
		quillVision = new Quill('#editor-visionText', { theme: 'snow', modules: { toolbar: toolbarOptions } });
		quillVision.root.innerHTML = document.getElementById('input-visionText').value;
	}
	if (document.getElementById('editor-missionRichText')) {
		quillMission = new Quill('#editor-missionRichText', { theme: 'snow', modules: { toolbar: toolbarOptions } });
		quillMission.root.innerHTML = document.getElementById('input-missionRichText').value;
	}

	renderTimelineItems();
	renderTeamItems();
	renderFaqItems();
});

function renderTimelineItems() {
	const container = document.getElementById('timeline-container');
	if (!container) return;
	container.innerHTML = timelineItems.map((item, idx) => `
		<div class="col-md-4 timeline-item-box" data-index="${idx}">
			<div class="p-3 border rounded-3 bg-light position-relative h-100 shadow-sm">
				<div class="d-flex justify-content-between align-items-center mb-2">
					<span class="fw-bold small text-primary">MILESTONE #${idx + 1}</span>
					<button type="button" class="btn btn-sm btn-outline-danger d-inline-flex align-items-center px-2 py-1" onclick="removeTimelineItem(${idx})" title="Hapus Milestone Ini">
						<i class="ti ti-trash me-1"></i>Hapus
					</button>
				</div>
				<div class="mb-2">
					<label class="form-label small mb-1">Tahun</label>
					<input type="text" class="form-control form-control-sm timeline-year" value="${item.year || ''}" placeholder="2018" onchange="updateTimelineArray()">
				</div>
				<div class="mb-2">
					<label class="form-label small mb-1">Judul Pencapaian</label>
					<input type="text" class="form-control form-control-sm timeline-title" value="${item.title || ''}" placeholder="Pendirian WebMedia" onchange="updateTimelineArray()">
				</div>
				<div>
					<label class="form-label small mb-1">Deskripsi Singkat</label>
					<textarea class="form-control form-control-sm timeline-desc" rows="2" placeholder="Jelaskan pencapaian..." onchange="updateTimelineArray()">${item.desc || ''}</textarea>
				</div>
			</div>
		</div>
	`).join('');
}

function updateTimelineArray() {
	const boxes = document.querySelectorAll('#timeline-container .timeline-item-box');
	timelineItems = Array.from(boxes).map(box => ({
		year: box.querySelector('.timeline-year')?.value || '',
		title: box.querySelector('.timeline-title')?.value || '',
		desc: box.querySelector('.timeline-desc')?.value || ''
	}));
}

function addTimelineItem() {
	updateTimelineArray();
	timelineItems.push({ year: '', title: '', desc: '' });
	renderTimelineItems();
}

function removeTimelineItem(idx) {
	updateTimelineArray();
	timelineItems.splice(idx, 1);
	renderTimelineItems();
}

function renderTeamItems() {
	const container = document.getElementById('team-container');
	if (!container) return;
	container.innerHTML = teamItems.map((item, idx) => `
		<div class="col-md-4 team-item-box" data-index="${idx}">
			<div class="p-3 border rounded-3 bg-light position-relative h-100 shadow-sm">
				<div class="d-flex justify-content-between align-items-center mb-2">
					<span class="fw-bold small text-primary">ANGGOTA TIM #${idx + 1}</span>
					<button type="button" class="btn btn-sm btn-outline-danger d-inline-flex align-items-center px-2 py-1" onclick="removeTeamItem(${idx})" title="Hapus Anggota Ini">
						<i class="ti ti-trash me-1"></i>Hapus
					</button>
				</div>
				<div class="mb-2">
					<label class="form-label small mb-1">Nama Lengkap</label>
					<input type="text" class="form-control form-control-sm team-name" value="${item.name || ''}" placeholder="Budi Santoso" onchange="updateTeamArray()">
				</div>
				<div class="mb-2">
					<label class="form-label small mb-1">Jabatan / Role</label>
					<input type="text" class="form-control form-control-sm team-role" value="${item.role || ''}" placeholder="Chief Executive Officer" onchange="updateTeamArray()">
				</div>
				<div class="mb-2">
					<label class="form-label small mb-1">Foto Profil</label>
					<div class="d-flex align-items-center gap-2 mb-2">
						<img src="${item.image || 'https://images.unsplash.com/photo-1560250097-0b93528c311a?w=400&q=80'}" alt="Preview" class="rounded border bg-white shadow-sm" style="width: 52px; height: 52px; object-fit: cover;">
						<div class="flex-grow-1">
							<input type="file" class="form-control form-control-sm mb-1" accept="image/*" onchange="uploadTeamPhoto(event, ${idx})">
							<input type="text" class="form-control form-control-sm team-image" value="${item.image || ''}" placeholder="Atau ketik URL foto..." onchange="updateTeamArray()">
						</div>
					</div>
				</div>
				<div>
					<label class="form-label small mb-1">Bio Singkat</label>
					<textarea class="form-control form-control-sm team-bio" rows="2" placeholder="Bio singkat..." onchange="updateTeamArray()">${item.bio || ''}</textarea>
				</div>
			</div>
		</div>
	`).join('');
}

function updateTeamArray() {
	const boxes = document.querySelectorAll('#team-container .team-item-box');
	teamItems = Array.from(boxes).map(box => ({
		name: box.querySelector('.team-name')?.value || '',
		role: box.querySelector('.team-role')?.value || '',
		image: box.querySelector('.team-image')?.value || '',
		bio: box.querySelector('.team-bio')?.value || ''
	}));
}

function addTeamItem() {
	updateTeamArray();
	teamItems.push({ name: '', role: '', image: '', bio: '' });
	renderTeamItems();
}

function removeTeamItem(idx) {
	updateTeamArray();
	teamItems.splice(idx, 1);
	renderTeamItems();
}

async function uploadTeamPhoto(e, idx) {
	const file = e.target.files[0];
	if (!file) return;
	updateTeamArray();
	const formData = new FormData();
	formData.append('image', file);

	Swal.fire({
		title: 'Mengunggah Foto...',
		allowOutsideClick: false,
		didOpen: () => { Swal.showLoading(); }
	});

	try {
		const res = await fetch('/api/upload', { method: 'POST', body: formData });
		const result = await res.json();
		if (result.success) {
			teamItems[idx].image = result.url;
			renderTeamItems();
			Swal.fire({
				icon: 'success',
				title: 'Foto Terunggah',
				text: 'Foto profil anggota tim berhasil diunggah.',
				timer: 1200,
				showConfirmButton: false
			});
		} else {
			Swal.fire('Gagal Unggah', result.message || 'Gagal mengunggah foto profil', 'error');
		}
	} catch (err) {
		Swal.fire('Error', 'Terjadi gangguan koneksi saat mengunggah foto.', 'error');
	}
}

function renderFaqItems() {
	const container = document.getElementById('faq-container');
	if (!container) return;
	container.innerHTML = faqItems.map((item, idx) => `
		<div class="col-md-12 faq-item-box" data-index="${idx}">
			<div class="p-3 border rounded-3 bg-light position-relative shadow-sm">
				<div class="d-flex justify-content-between align-items-center mb-2">
					<span class="fw-bold small text-primary">PERTANYAAN FAQ #${idx + 1}</span>
					<button type="button" class="btn btn-sm btn-outline-danger d-inline-flex align-items-center px-2 py-1" onclick="removeFaqItem(${idx})" title="Hapus FAQ Ini">
						<i class="ti ti-trash me-1"></i>Hapus
					</button>
				</div>
				<div class="mb-2">
					<label class="form-label small mb-1">Pertanyaan (Question)</label>
					<input type="text" class="form-control form-control-sm faq-q" value="${item.q || ''}" placeholder="Masukkan pertanyaan..." onchange="updateFaqArray()">
				</div>
				<div>
					<label class="form-label small mb-1">Jawaban (Answer)</label>
					<textarea class="form-control form-control-sm faq-a" rows="2" placeholder="Masukkan jawaban..." onchange="updateFaqArray()">${item.a || ''}</textarea>
				</div>
			</div>
		</div>
	`).join('');
}

function updateFaqArray() {
	const boxes = document.querySelectorAll('#faq-container .faq-item-box');
	faqItems = Array.from(boxes).map(box => ({
		q: box.querySelector('.faq-q')?.value || '',
		a: box.querySelector('.faq-a')?.value || ''
	}));
}

function addFaqItem() {
	updateFaqArray();
	faqItems.push({ q: '', a: '' });
	renderFaqItems();
}

function removeFaqItem(idx) {
	updateFaqArray();
	faqItems.splice(idx, 1);
	renderFaqItems();
}

// Live update Google search simulation box
function updateGooglePreview(pageName) {
	const titleInput = document.getElementById(`${pageName}-seoTitle`);
	const descInput = document.getElementById(`${pageName}-seoDesc`);
	const previewTitle = document.getElementById(`${pageName}-preview-title`);
	const previewDesc = document.getElementById(`${pageName}-preview-desc`);

	if (titleInput && previewTitle) {
		previewTitle.textContent = titleInput.value.trim() || 'PT. Alexa Computindo Group';
	}
	if (descInput && previewDesc) {
		previewDesc.textContent = descInput.value.trim() || 'Solusi teknologi terintegrasi untuk perusahaan dan infrastruktur digital.';
	}
}

async function savePageContent(e, pageName) {
	e.preventDefault();
	const form = document.getElementById(`form-${pageName}`);
	const formData = new FormData(form);
	const data = Object.fromEntries(formData.entries());

	if (pageName === 'about') {
		if (quillHistory) {
			data.historyContent = quillHistory.root.innerHTML;
			data.historyPar1 = quillHistory.root.innerHTML;
			data.historyPar2 = "";
		}
		if (quillVision) data.visionText = quillVision.root.innerHTML;
		if (quillMission) data.missionRichText = quillMission.root.innerHTML;

		updateTimelineArray();
		data.timelineList = timelineItems;

		updateTeamArray();
		data.teamList = teamItems;
	}

	if (pageName === 'contact') {
		updateFaqArray();
		data.faqList = faqItems;
	}

	try {
		const res = await fetch(`/api/pages/${pageName}`, {
			method: 'PUT',
			headers: { 'Content-Type': 'application/json' },
			body: JSON.stringify({ content: data })
		});
		const result = await res.json();
		if (result.success) {
			Swal.fire({
				icon: 'success',
				title: 'Berhasil Disimpan!',
				text: result.message || `Konten & SEO halaman ${pageName.toUpperCase()} telah diperbarui.`,
				timer: 1500,
				showConfirmButton: false
			});
		} else {
			Swal.fire('Gagal', result.message || 'Gagal menyimpan data', 'error');
		}
	} catch (err) {
		Swal.fire('Error', 'Terjadi kesalahan koneksi ke server', 'error');
	}
}

document.addEventListener('DOMContentLoaded', () => {
	if (typeof window.initChipInputs === 'function') window.initChipInputs();
	document.querySelectorAll('button[data-bs-toggle="tab"]').forEach(btn => {
		btn.addEventListener('shown.bs.tab', () => {
			if (typeof window.initChipInputs === 'function') window.initChipInputs();
		});
	});
});
</script>
