        <div class="card-body p-4">
          <div class="row">
            <div class="col-md-6 mb-3">
              <label class="form-label fw-medium">Judul Box Alamat</label>
              <input type="text" class="form-control" name="addressTitle" value="<%= pagesData.contact.addressTitle %>" required>
            </div>
            <div class="col-md-6 mb-3">
              <label class="form-label fw-medium">Detail Alamat Kantor (Gunakan Enter untuk baris baru)</label>
              <textarea class="form-control" name="addressText" rows="2" required><%= pagesData.contact.addressText %></textarea>
            </div>
            <div class="col-md-6 mb-3">
              <label class="form-label fw-medium">Judul Box Telepon</label>
              <input type="text" class="form-control" name="phoneTitle" value="<%= pagesData.contact.phoneTitle %>" required>
            </div>
            <div class="col-md-6 mb-3">
              <label class="form-label fw-medium">Nomor Telepon / WhatsApp</label>
              <textarea class="form-control" name="phoneText" rows="2" required><%= pagesData.contact.phoneText %></textarea>
            </div>
            <div class="col-md-6 mb-3">
              <label class="form-label fw-medium">Judul Box Email</label>
              <input type="text" class="form-control" name="emailTitle" value="<%= pagesData.contact.emailTitle %>" required>
            </div>
            <div class="col-md-6 mb-3">
              <label class="form-label fw-medium">Alamat Email Resmi</label>
              <textarea class="form-control" name="emailText" rows="2" required><%= pagesData.contact.emailText %></textarea>
            </div>
          </div>
        </div>
      </div>

      <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white py-3 border-bottom">
          <h5 class="card-title fw-bold mb-0">URL Embed Google Maps</h5>
        </div>
        <div class="card-body p-4">
          <div class="mb-2">
            <label class="form-label fw-medium">Link URL iframe Google Maps (src)</label>
            <input type="url" class="form-control" name="mapEmbedUrl" value="<%= pagesData.contact.mapEmbedUrl %>" required>
          </div>
          <small class="text-muted">Masukkan link URL embed resmi dari Google Maps.</small>
        </div>
      </div>

      <div class="text-end mb-5">
        <button type="submit" class="btn btn-primary px-4 py-2 fw-semibold">
          <i class="ti ti-device-floppy me-2"></i>Simpan Perubahan Halaman Kontak
        </button>
      </div>
    </form>
  </div>

</div>

<script>
async function savePageContent(e, pageName) {
  e.preventDefault();
  const form = document.getElementById(`form-${pageName}`);
  const formData = new FormData(form);
  const data = Object.fromEntries(formData.entries());

  if (pageName === 'about') {
    data.missionList = [data.mission0, data.mission1, data.mission2].filter(Boolean);
    delete data.mission0;
    delete data.mission1;
    delete data.mission2;

    data.timelineList = [
      { year: data.timelineYear_0, title: data.timelineTitle_0, desc: data.timelineDesc_0 },
      { year: data.timelineYear_1, title: data.timelineTitle_1, desc: data.timelineDesc_1 },
      { year: data.timelineYear_2, title: data.timelineTitle_2, desc: data.timelineDesc_2 }
    ];
    delete data.timelineYear_0; delete data.timelineTitle_0; delete data.timelineDesc_0;
    delete data.timelineYear_1; delete data.timelineTitle_1; delete data.timelineDesc_1;
    delete data.timelineYear_2; delete data.timelineTitle_2; delete data.timelineDesc_2;
  }

  try {
    const res = await fetch(`/api/pages/${pageName}`, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ content: data })
    });
    const result = await res.json();
    if (result.success) {
      Swal.fire({
        icon: 'success',
        title: 'Tersimpan!',
        text: result.message || 'Konten halaman berhasil disimpan.',
        confirmButtonColor: '#3BAE7C'
      });
    } else {
      Swal.fire('Gagal', result.message || 'Gagal menyimpan data', 'error');
    }
  } catch (err) {
    Swal.fire('Error', 'Terjadi kesalahan koneksi server', 'error');
  }
}
</script>
