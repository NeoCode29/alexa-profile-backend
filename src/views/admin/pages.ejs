    <form id="form-about" onsubmit="savePageContent(event, 'about')">
      <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white py-3 border-bottom">
          <h5 class="card-title fw-bold mb-0">Hero About & Profil Singkat</h5>
        </div>
        <div class="card-body p-4">
          <div class="mb-3">
            <label class="form-label fw-medium">Judul Halaman</label>
            <input type="text" class="form-control" name="heroTitle" value="<%= pagesData.about.heroTitle %>" required>
          </div>
          <div class="mb-3">
            <label class="form-label fw-medium">Deskripsi Hero Profil</label>
            <textarea class="form-control" name="heroDesc" rows="3" required><%= pagesData.about.heroDesc %></textarea>
