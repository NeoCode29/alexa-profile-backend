                <label class="form-label fw-bold">Statistik 2 - Angka</label>
                <input type="text" class="form-control mb-2" name="stat2Number" value="<%= pagesData.home.stat2Number %>">
                <label class="form-label fw-medium small">Label</label>
                <input type="text" class="form-control" name="stat2Label" value="<%= pagesData.home.stat2Label %>">
              </div>
            </div>
            <div class="col-md-4 mb-3">
