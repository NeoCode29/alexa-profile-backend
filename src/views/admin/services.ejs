<script>
function parseLinesToArray(str) {
	return (str || '')
		.split('\n')
		.map(s => s.trim())
		.filter(Boolean);
}

// Tambah Divisi Layanan
async function submitCreateService() {
	const form = document.getElementById('createServiceForm');
	const formData = new FormData(form);
	const featuresArr = parseLinesToArray(formData.get('featuresInput'));

	const data = {
		id: formData.get('id'),
