// Filter live table divisi layanan berdasarkan input pencarian
function filterServicesTable() {
	const query = (document.getElementById('searchServicesInput')?.value || '').toLowerCase().trim();
	const rows = document.querySelectorAll('#servicesTableBody tr.service-row');
	rows.forEach(row => {
		const textContent = row.textContent.toLowerCase();
		row.style.display = textContent.includes(query) ? '' : 'none';
	});
}
