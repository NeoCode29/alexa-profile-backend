<script>
function parseLinesToArray(str) {
	return (str || '')
		.split('\n')
		.map(s => s.trim())
		.filter(Boolean);
}

// Tambah Divisi Layanan
async function submitCreateService() {
	const form = document.getElementById('createServiceForm');
	const formData = new FormData(form);
	const featuresArr = parseLinesToArray(formData.get('featuresInput'));

	const data = {
		id: formData.get('id'),
		title: formData.get('title'),
		subtitle: formData.get('subtitle'),
		description: formData.get('description'),
		fullDesc: formData.get('fullDesc'),
		icon: formData.get('icon'),
		features: featuresArr
	};

	try {
		const res = await fetch('/api/services', {
			method: 'POST',
			headers: { 'Content-Type': 'application/json' },
			body: JSON.stringify(data)
		});
		const result = await res.json();
		if (result.success) {
			Swal.fire({ icon: 'success', title: 'Berhasil!', text: result.message, confirmButtonColor: '#3BAE7C' })
				.then(() => location.reload());
		} else {
			Swal.fire('Gagal', result.message || 'Gagal menyimpan layanan', 'error');
		}
	} catch (e) {
		Swal.fire('Error', 'Terjadi kesalahan koneksi server', 'error');
	}
}

// Edit Divisi Layanan
function openEditServiceModal(input) {
	const svc = typeof input === 'string' ? JSON.parse(decodeURIComponent(input)) : input;
	document.getElementById('editSvcId').value = svc.id;
	document.getElementById('editSvcTitle').value = svc.title;
	document.getElementById('editSvcSubtitle').value = svc.subtitle || '';
	document.getElementById('editSvcDescription').value = svc.description || '';
	document.getElementById('editSvcFullDesc').value = svc.fullDesc || svc.description || '';
	document.getElementById('editSvcIcon').value = svc.icon || 'FaLaptopCode';

	let featArr = [];
	try { featArr = JSON.parse(svc.features || '[]'); } catch (e) {}
	document.getElementById('editSvcFeaturesInput').value = featArr.join('\n');

	let portArr = [];
	try { portArr = typeof svc.portfolios === 'string' ? JSON.parse(svc.portfolios) : (svc.portfolios || []); } catch (e) {}
	document.getElementById('editSvcPortfoliosInput').value = JSON.stringify(portArr, null, 2);

	let testiArr = [];
	try { testiArr = typeof svc.testimonials === 'string' ? JSON.parse(svc.testimonials) : (svc.testimonials || []); } catch (e) {}
	document.getElementById('editSvcTestimonialsInput').value = JSON.stringify(testiArr, null, 2);

	new bootstrap.Modal(document.getElementById('editServiceModal')).show();
}

async function submitEditService() {
	const id = document.getElementById('editSvcId').value;
	const featuresArr = parseLinesToArray(document.getElementById('editSvcFeaturesInput').value);

	let portfoliosArr = [];
	try { portfoliosArr = JSON.parse(document.getElementById('editSvcPortfoliosInput').value || '[]'); } catch (e) {}

	let testimonialsArr = [];
	try { testimonialsArr = JSON.parse(document.getElementById('editSvcTestimonialsInput').value || '[]'); } catch (e) {}

	const data = {
		title: document.getElementById('editSvcTitle').value,
		subtitle: document.getElementById('editSvcSubtitle').value,
		description: document.getElementById('editSvcDescription').value,
		heroDesc: document.getElementById('editSvcFullDesc').value,
		fullDesc: document.getElementById('editSvcFullDesc').value,
		icon: document.getElementById('editSvcIcon').value,
		features: featuresArr,
		portfolios: portfoliosArr,
		testimonials: testimonialsArr
	};

	try {
		const res = await fetch(`/api/services/${id}`, {
			method: 'PUT',
			headers: { 'Content-Type': 'application/json' },
			body: JSON.stringify(data)
		});
		const result = await res.json();
		if (result.success) {
			Swal.fire({ icon: 'success', title: 'Tersimpan!', text: result.message, confirmButtonColor: '#3BAE7C' })
				.then(() => location.reload());
		} else {
			Swal.fire('Gagal', result.message || 'Gagal memperbarui layanan', 'error');
		}
	} catch (e) {
		Swal.fire('Error', 'Terjadi kesalahan koneksi server', 'error');
	}
}

async function deleteServiceAction(id, title) {
	const confirm = await Swal.fire({
		title: 'Hapus Layanan?',
		text: `Apakah Anda yakin ingin menghapus divisi "${title}"?`,
		icon: 'warning',
		showCancelButton: true,
		confirmButtonColor: '#d33',
		cancelButtonColor: '#6c757d',
		confirmButtonText: 'Ya, Hapus'
	});

	if (confirm.isConfirmed) {
		const res = await fetch(`/api/services/${id}`, { method: 'DELETE' });
		const result = await res.json();
		if (result.success) {
			Swal.fire({ icon: 'success', title: 'Dihapus', confirmButtonColor: '#3BAE7C' })
				.then(() => location.reload());
		}
	}
}

// Tambah Paket
function openAddPackageForService(serviceId) {
	document.getElementById('pkgServiceIdSelect').value = serviceId;
	new bootstrap.Modal(document.getElementById('addPackageModal')).show();
}

async function submitCreatePackage() {
	const form = document.getElementById('createPackageForm');
	const formData = new FormData(form);
	const featuresArr = parseLinesToArray(formData.get('featuresInput'));

	const data = {
		serviceId: formData.get('serviceId'),
		name: formData.get('name'),
		price: formData.get('price'),
		features: featuresArr,
		isPopular: document.getElementById('isPopularSwitch').checked
	};

	try {
		const res = await fetch('/api/services/packages', {
			method: 'POST',
			headers: { 'Content-Type': 'application/json' },
			body: JSON.stringify(data)
		});
		const result = await res.json();
		if (result.success) {
			Swal.fire({
				icon: 'success',
				title: 'Paket Ditambahkan',
				timer: 1500,
				showConfirmButton: false
			}).then(() => location.reload());
		} else {
			Swal.fire('Gagal', result.message || 'Gagal menyimpan paket', 'error');
		}
	} catch (e) {
		Swal.fire('Error', 'Terjadi kesalahan koneksi server', 'error');
	}
}

// Edit Paket
function openEditPackageModal(encodedJson) {
	const pkg = JSON.parse(decodeURIComponent(encodedJson));
	document.getElementById('editPkgId').value = pkg.id;
	document.getElementById('editPkgName').value = pkg.name;
	document.getElementById('editPkgPrice').value = pkg.price;
	document.getElementById('editPkgIsPopularSwitch').checked = !!pkg.isPopular;

	let featArr = [];
	try { featArr = JSON.parse(pkg.features || '[]'); } catch (e) {}
	document.getElementById('editPkgFeaturesInput').value = featArr.join('\n');

	new bootstrap.Modal(document.getElementById('editPackageModal')).show();
}

async function submitEditPackage() {
	const id = document.getElementById('editPkgId').value;
	const featuresArr = parseLinesToArray(document.getElementById('editPkgFeaturesInput').value);

	const data = {
		name: document.getElementById('editPkgName').value,
		price: document.getElementById('editPkgPrice').value,
		features: featuresArr,
		isPopular: document.getElementById('editPkgIsPopularSwitch').checked
	};

	try {
		const res = await fetch(`/api/services/packages/${id}`, {
			method: 'PUT',
			headers: { 'Content-Type': 'application/json' },
			body: JSON.stringify(data)
		});
		const result = await res.json();
		if (result.success) {
			Swal.fire({
				icon: 'success',
				title: 'Paket Diperbarui',
				timer: 1500,
				showConfirmButton: false
			}).then(() => location.reload());
		} else {
			Swal.fire('Gagal', result.message || 'Gagal memperbarui paket', 'error');
		}
	} catch (e) {
		Swal.fire('Error', 'Terjadi kesalahan koneksi server', 'error');
	}
}

async function deletePackageAction(id) {
	const res = await fetch(`/api/services/packages/${id}`, { method: 'DELETE' });
	const result = await res.json();
	if (result.success) {
		location.reload();
	}
}

