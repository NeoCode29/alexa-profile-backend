		title: 'Hapus Layanan?',
		text: `Apakah Anda yakin ingin menghapus divisi "${title}"?`,
		icon: 'warning',
		showCancelButton: true,
		confirmButtonColor: '#d33',
		cancelButtonColor: '#6c757d',
