<!-- Page Header -->
<div class="page-header mb-4">
	<div class="row align-items-center">
		<div class="col">
			<h3 class="page-title fw-bold text-dark">Manajemen Konten Divisi Layanan & Paket Harga</h3>
			<ul class="breadcrumb mb-0">
				<li class="breadcrumb-item"><a href="/admin">Dashboard</a></li>
				<li class="breadcrumb-item active">Layanan & Paket</li>
			</ul>
		</div>
		<div class="col-auto d-flex gap-2">
			<button class="btn btn-outline-primary d-inline-flex align-items-center fw-semibold" data-bs-toggle="modal" data-bs-target="#addServiceModal">
				<i class="ti ti-briefcase me-2"></i>+ Tambah Divisi Layanan
			</button>
			<button class="btn btn-primary d-inline-flex align-items-center fw-semibold" data-bs-toggle="modal" data-bs-target="#addPackageModal">
				<i class="ti ti-plus me-2"></i>+ Tambah Paket Harga
			</button>
		</div>
	</div>
</div>
<!-- /Page Header -->

<div class="row">
	<% if (services && services.length > 0) { %>
		<% services.forEach(function(svc) { 
			let svcFeatures = [];
			let svcPortfolios = [];
			let svcTestimonials = [];
			try { svcFeatures = typeof svc.features === 'string' ? JSON.parse(svc.features) : (svc.features || []); } catch (e) {}
			try { svcPortfolios = typeof svc.portfolios === 'string' ? JSON.parse(svc.portfolios) : (svc.portfolios || []); } catch (e) {}
			try { svcTestimonials = typeof svc.testimonials === 'string' ? JSON.parse(svc.testimonials) : (svc.testimonials || []); } catch (e) {}
		%>
			<div class="col-md-6 d-flex mb-4">
				<div class="card flex-fill shadow-sm border-0 rounded-4 overflow-hidden h-100">
					<div class="card-body p-4 d-flex flex-column justify-content-between">
						<div>
							<div class="d-flex align-items-center justify-content-between mb-3">
								<span class="badge bg-primary bg-opacity-10 text-primary fw-bold px-3 py-2 text-uppercase rounded-pill"><%= svc.id %> DIVISION</span>
								<div class="d-flex gap-1">
									<button class="btn btn-sm btn-light border" onclick='openEditServiceModal(<%= JSON.stringify(svc) %>)' title="Edit Info Dasar">
										<i class="bi bi-pencil text-primary"></i> Edit Info
									</button>
									<button class="btn btn-sm btn-light border" onclick="deleteServiceAction('<%= svc.id %>', '<%= svc.title %>')" title="Hapus Divisi">
										<i class="bi bi-trash text-danger"></i>
									</button>
								</div>
							</div>

							<div class="d-flex align-items-center mb-2">
								<h4 class="card-title fw-bold text-dark mb-0 me-2"><%= svc.title %></h4>
							</div>
							<h6 class="text-primary fw-semibold mb-3"><%= svc.subtitle || 'Divisi Layanan Alexa' %></h6>
							<p class="text-muted small mb-4"><%= svc.description %></p>

							<!-- Summary Counters Badge List -->
							<div class="d-flex flex-wrap gap-2 mb-4">
								<span class="badge bg-light text-dark border px-3 py-2">
									<i class="bi bi-tag-fill text-primary me-1"></i> <%= svc.packages ? svc.packages.length : 0 %> Paket Harga
								</span>
								<span class="badge bg-light text-dark border px-3 py-2">
									<i class="bi bi-images text-success me-1"></i> <%= svcPortfolios.length %> Showcase Proyek
								</span>
								<span class="badge bg-light text-dark border px-3 py-2">
									<i class="bi bi-chat-quote-fill text-warning me-1"></i> <%= svcTestimonials.length %> Testimoni
								</span>
							</div>
						</div>

						<div class="pt-3 border-top mt-auto">
							<a href="/admin/services/<%= svc.id %>" class="btn btn-primary w-100 py-2 fw-bold d-flex align-items-center justify-content-center">
								<span>Kelola Detail Lengkap Divisi Ini</span>
								<i class="bi bi-arrow-right-circle ms-2"></i>
							</a>
						</div>
					</div>
				</div>
			</div>
		<% }); %>
	<% } else { %>
		<div class="col-12">
			<div class="card p-5 text-center text-muted border-0 shadow-sm">Belum ada layanan yang dimuat. Klik tombol "+ Tambah Divisi Layanan" di kanan atas.</div>
		</div>
	<% } %>
</div>

<!-- Modal Tambah Divisi Layanan -->
<div class="modal fade" id="addServiceModal" tabindex="-1">
	<div class="modal-dialog modal-lg modal-dialog-centered">
		<div class="modal-content">
			<div class="modal-header bg-white border-bottom">
				<h5 class="modal-title fw-bold">Tambah Divisi Layanan Baru</h5>
				<button type="button" class="btn-close" data-bs-dismiss="modal"></button>
			</div>
			<div class="modal-body p-4">
				<form id="createServiceForm">
					<div class="row">
						<div class="col-md-6 mb-3">
							<label class="form-label fw-medium">ID / Kode Slug <span class="text-danger">*</span></label>
							<input type="text" class="form-control" name="id" required placeholder="Contoh: cloudmedia (tanpa spasi)">
						</div>
						<div class="col-md-6 mb-3">
							<label class="form-label fw-medium">Pilihan Ikon Divisi <span class="text-danger">*</span></label>
							<select class="form-select" name="icon" required>
								<option value="FaLaptopCode">FaLaptopCode (Software/Web)</option>
								<option value="FaWifi">FaWifi (Jaringan/ISP)</option>
								<option value="FaRegNewspaper">FaRegNewspaper (Media/Berita)</option>
								<option value="FaCloud">FaCloud (Cloud Server)</option>
								<option value="FaShieldAlt">FaShieldAlt (Cyber Security)</option>
								<option value="FaServer">FaServer (Data Center)</option>
								<option value="FaDatabase">FaDatabase (Database Solutions)</option>
								<option value="FaMobileAlt">FaMobileAlt (Mobile App)</option>
							</select>
						</div>
						<div class="col-md-6 mb-3">
							<label class="form-label fw-medium">Judul Divisi <span class="text-danger">*</span></label>
							<input type="text" class="form-control" name="title" required placeholder="Contoh: CloudMedia">
						</div>
						<div class="col-md-6 mb-3">
							<label class="form-label fw-medium">Subjudul / Tagline Divisi</label>
							<input type="text" class="form-control" name="subtitle" placeholder="Contoh: Enterprise Cloud & DevOps">
						</div>
						<div class="col-12 mb-3">
							<label class="form-label fw-medium">Deskripsi Singkat (Kartu di Halaman Beranda) <span class="text-danger">*</span></label>
							<textarea class="form-control" name="description" rows="2" required placeholder="Jelaskan secara ringkas keunggulan layanan ini..."></textarea>
						</div>
						<div class="col-12 mb-3">
							<label class="form-label fw-medium">Deskripsi Lengkap (Untuk Halaman Detail Layanan)</label>
							<textarea class="form-control" name="fullDesc" rows="3" placeholder="Paragraf pengantar lengkap yang akan tampil saat pengguna membuka halaman detail divisi ini..."></textarea>
						</div>
						<div class="col-12 mb-3">
							<label class="form-label fw-medium">Key Features / Fitur Unggulan Layanan</label>
							<textarea class="form-control" name="featuresInput" rows="3" placeholder="Satu fitur per baris (Tekan Enter untuk baris baru)&#10;Contoh:&#10;SLA Support 24/7 & Uptime 99.9%&#10;Arsitektur Cloud High Availability&#10;Dukungan Engineer Tersertifikasi"></textarea>
						</div>
					</div>
				</form>
			</div>
			<div class="modal-footer bg-light">
				<button type="button" class="btn btn-light border" data-bs-dismiss="modal">Batal</button>
				<button type="button" class="btn btn-primary px-4" onclick="submitCreateService()">Simpan Layanan Baru</button>
			</div>
		</div>
	</div>
</div>

