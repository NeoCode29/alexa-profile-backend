<!-- Page Header -->
<div class="page-header mb-4">
	<div class="row align-items-center">
		<div class="col">
			<h3 class="page-title fw-bold text-dark">Dashboard Admin CMS</h3>
			<ul class="breadcrumb">
				<li class="breadcrumb-item"><a href="/admin">Alexa Computindo</a></li>
				<li class="breadcrumb-item active">Ringkasan Sistem</li>
			</ul>
		</div>
	</div>
</div>
<!-- /Page Header -->

<!-- Overview Cards Row -->
<div class="row">
	<div class="col-xl-3 col-sm-6 col-12 mb-4">
		<div class="card shadow-sm border-0 h-100">
			<div class="card-body d-flex align-items-center justify-content-between">
				<div>
					<span class="text-muted d-block small fw-medium mb-1">TOTAL ARTIKEL BLOG</span>
					<h2 class="mb-0 fw-bold text-dark"><%= stats.totalArticles %></h2>
				</div>
				<div class="avatar avatar-lg bg-primary text-white rounded-circle d-flex align-items-center justify-content-center shadow-sm" style="width: 54px; height: 54px;">
					<i class="ti ti-article fs-3"></i>
				</div>
			</div>
		</div>
	</div>

	<div class="col-xl-3 col-sm-6 col-12 mb-4">
		<div class="card shadow-sm border-0 h-100">
			<div class="card-body d-flex align-items-center justify-content-between">
				<div>
					<span class="text-muted d-block small fw-medium mb-1">DIVISI & LAYANAN</span>
					<h2 class="mb-0 fw-bold text-dark"><%= stats.totalServices %></h2>
				</div>
				<div class="avatar avatar-lg bg-success text-white rounded-circle d-flex align-items-center justify-content-center shadow-sm" style="width: 54px; height: 54px;">
					<i class="ti ti-briefcase fs-3"></i>
				</div>
			</div>
		</div>
	</div>

	<div class="col-xl-3 col-sm-6 col-12 mb-4">
		<div class="card shadow-sm border-0 h-100">
			<div class="card-body d-flex align-items-center justify-content-between">
				<div>
					<span class="text-muted d-block small fw-medium mb-1">PESAN MASUK (BARU)</span>
					<h2 class="mb-0 fw-bold text-dark"><%= stats.totalInquiries %></h2>
				</div>
				<div class="avatar avatar-lg bg-warning text-white rounded-circle d-flex align-items-center justify-content-center shadow-sm" style="width: 54px; height: 54px;">
					<i class="ti ti-mail fs-3"></i>
				</div>
			</div>
		</div>
	</div>

	<div class="col-xl-3 col-sm-6 col-12 mb-4">
		<div class="card shadow-sm border-0 h-100">
			<div class="card-body d-flex align-items-center justify-content-between">
				<div>
					<span class="text-muted d-block small fw-medium mb-1">TOTAL MITRA KLIEN</span>
					<h2 class="mb-0 fw-bold text-dark"><%= stats.totalClients %></h2>
				</div>
				<div class="avatar avatar-lg bg-info text-white rounded-circle d-flex align-items-center justify-content-center shadow-sm" style="width: 54px; height: 54px;">
					<i class="ti ti-users fs-3"></i>
				</div>
			</div>
		</div>
	</div>
</div>

<div class="row">
	<!-- Artikel Terbaru -->
	<div class="col-lg-7 d-flex">
		<div class="card shadow-sm border-0 flex-fill">
			<div class="card-header bg-white py-3 d-flex justify-content-between align-items-center border-bottom">
				<h5 class="card-title fw-bold mb-0">Artikel Blog Terbaru</h5>
				<a href="/admin/articles" class="btn btn-sm btn-outline-primary">Lihat Semua</a>
			</div>
			<div class="card-body p-0">
				<div class="table-responsive">
					<table class="table table-hover align-middle mb-0">
						<thead class="table-light">
							<tr>
								<th>Judul Artikel</th>
								<th>Kategori</th>
								<th>Views</th>
								<th>Status</th>
							</tr>
						</thead>
						<tbody>
							<% if (recentArticles && recentArticles.length > 0) { %>
								<% recentArticles.forEach(function(article) { %>
									<tr>
										<td class="fw-bold text-dark text-truncate" style="max-width: 260px;">
											<%= article.title %>
										</td>
										<td><span class="badge bg-primary-subtle text-primary"><%= article.category %></span></td>
										<td><i class="ti ti-eye me-1"></i><%= article.views %></td>
										<td>
											<span class="badge bg-success">Published</span>
										</td>
									</tr>
								<% }); %>
							<% } else { %>
								<tr>
									<td colspan="4" class="text-center text-muted py-5">
										<i class="ti ti-file-text fs-1 d-block mb-2 text-secondary"></i>
										Belum ada artikel yang dipublikasikan.
									</td>
								</tr>
							<% } %>
						</tbody>
					</table>
				</div>
			</div>
		</div>
	</div>

	<!-- Pesan Masuk Terbaru -->
	<div class="col-lg-5 d-flex">
		<div class="card shadow-sm border-0 flex-fill">
			<div class="card-header bg-white py-3 d-flex justify-content-between align-items-center border-bottom">
				<h5 class="card-title fw-bold mb-0">Pesan Kontak Masuk</h5>
				<a href="/admin/inquiries" class="btn btn-sm btn-outline-primary">Lihat Semua</a>
			</div>
			<div class="card-body">
				<% if (recentInquiries && recentInquiries.length > 0) { %>
					<div class="list-group list-group-flush">
						<% recentInquiries.forEach(function(inq) { %>
							<div class="list-group-item px-0 py-3 border-bottom">
								<div class="d-flex justify-content-between align-items-center mb-1">
									<h6 class="mb-0 fw-bold text-dark"><%= inq.name %></h6>
									<span class="badge <%= inq.status === 'NEW' ? 'bg-danger' : 'bg-secondary' %>"><%= inq.status %></span>
								</div>
								<p class="text-primary small mb-1"><%= inq.subject %> — <span class="text-muted"><%= inq.email %></span></p>
								<p class="mb-0 text-truncate small text-muted"><%= inq.message %></p>
							</div>
						<% }); %>
					</div>
				<% } else { %>
					<div class="text-center text-muted py-5">
						<i class="ti ti-mail fs-1 d-block mb-2 text-secondary"></i>
						Belum ada pesan kontak baru.
					</div>
				<% } %>
			</div>
		</div>
	</div>
</div>
