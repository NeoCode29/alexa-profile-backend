<!-- Responsive Dashboard Styles -->
<style>
	@media (max-width: 767.98px) {
		.page-header-actions {
			width: 100%;
		}
		.page-header-actions .btn {
			flex: 1 1 auto;
			justify-content: center;
		}
		.dashboard-stat-card .card-body {
			padding: 1rem !important;
		}
		.article-title-cell {
			max-width: 150px !important;
		}
		.table th, .table td {
			padding: 0.75rem 0.5rem !important;
		}
	}
	@media (min-width: 768px) and (max-width: 1199.98px) {
		.article-title-cell {
			max-width: 210px !important;
		}
	}
	@media (min-width: 1200px) {
		.article-title-cell {
			max-width: 270px !important;
		}
	}
	.dashboard-stat-card {
		transition: transform 0.18s ease, box-shadow 0.18s ease;
	}
	.dashboard-stat-card:hover {
		transform: translateY(-2px);
		box-shadow: 0 6px 16px rgba(29, 42, 53, 0.075) !important;
	}
</style>

<!-- Page Header -->
<div class="page-header mb-4">
	<div class="row align-items-center justify-content-between g-3">
		<div class="col-12 col-md-auto">
			<h4 class="fw-bold text-dark mb-1">Ringkasan Dashboard</h4>
			<p class="text-muted small mb-0">Pantau aktivitas konten, layanan, dan pesan kontak masuk</p>
		</div>
		<div class="col-12 col-md-auto d-flex flex-wrap align-items-center gap-2 page-header-actions">
			<% if (hasPerm('articles.manage')) { %>
				<a href="/admin/articles" class="btn btn-primary btn-sm px-3 py-2 rounded-pill shadow-sm d-inline-flex align-items-center">
					<i class="ti ti-plus me-1"></i>Tulis Artikel
				</a>
			<% } %>
			<a href="http://localhost:5173" target="_blank" rel="noopener noreferrer" class="btn btn-outline-secondary btn-sm px-3 py-2 rounded-pill d-inline-flex align-items-center">
				<i class="ti ti-external-link me-1"></i>Lihat Website
			</a>
		</div>
	</div>
</div>
<!-- /Page Header -->

<!-- Overview Cards -->
<div class="row g-3 mb-4">
	<div class="col-12 col-sm-6 col-xl-3">
		<div class="card dashboard-stat-card border-0 shadow-sm rounded-3 h-100">
			<div class="card-body p-3 d-flex align-items-center justify-content-between">
				<div class="me-3" style="min-width: 0;">
					<span class="text-muted small fw-semibold d-block mb-1 text-truncate">TOTAL ARTIKEL</span>
					<h3 class="mb-0 fw-bold text-dark"><%= stats.totalArticles %></h3>
					<small class="text-muted d-block text-truncate"><i class="ti ti-eye me-1"></i><%= stats.totalArticleViews ? stats.totalArticleViews.toLocaleString('id-ID') : 0 %> tayangan</small>
				</div>
				<div class="avatar bg-primary-subtle text-primary rounded-3 d-flex align-items-center justify-content-center flex-shrink-0" style="width: 48px; height: 48px;">
					<i class="ti ti-article" style="font-size: 24px;"></i>
				</div>
			</div>
		</div>
	</div>

	<div class="col-12 col-sm-6 col-xl-3">
		<div class="card dashboard-stat-card border-0 shadow-sm rounded-3 h-100">
			<div class="card-body p-3 d-flex align-items-center justify-content-between">
				<div class="me-3" style="min-width: 0;">
					<span class="text-muted small fw-semibold d-block mb-1 text-truncate">LAYANAN AKTIF</span>
					<h3 class="mb-0 fw-bold text-dark"><%= stats.totalServices %></h3>
					<small class="text-muted d-block text-truncate">Divisi & portfolio</small>
				</div>
				<div class="avatar bg-success-subtle text-success rounded-3 d-flex align-items-center justify-content-center flex-shrink-0" style="width: 48px; height: 48px;">
					<i class="ti ti-briefcase" style="font-size: 24px;"></i>
				</div>
			</div>
		</div>
	</div>

	<div class="col-12 col-sm-6 col-xl-3">
		<div class="card dashboard-stat-card border-0 shadow-sm rounded-3 h-100">
			<div class="card-body p-3 d-flex align-items-center justify-content-between">
				<div class="me-3" style="min-width: 0;">
					<span class="text-muted small fw-semibold d-block mb-1 text-truncate">PESAN BARU</span>
					<h3 class="mb-0 fw-bold text-dark"><%= stats.totalInquiries %></h3>
					<% if (stats.totalInquiries > 0) { %>
						<small class="text-danger fw-semibold d-block text-truncate"><i class="ti ti-alert-circle me-1"></i>Perlu ditindaklanjuti</small>
					<% } else { %>
						<small class="text-muted d-block text-truncate">Semua sudah dibaca</small>
					<% } %>
				</div>
				<div class="avatar bg-warning-subtle text-warning rounded-3 d-flex align-items-center justify-content-center flex-shrink-0" style="width: 48px; height: 48px;">
					<i class="ti ti-mail" style="font-size: 24px;"></i>
				</div>
			</div>
		</div>
	</div>

	<div class="col-12 col-sm-6 col-xl-3">
		<div class="card dashboard-stat-card border-0 shadow-sm rounded-3 h-100">
			<div class="card-body p-3 d-flex align-items-center justify-content-between">
				<div class="me-3" style="min-width: 0;">
					<span class="text-muted small fw-semibold d-block mb-1 text-truncate">MITRA KLIEN</span>
					<h3 class="mb-0 fw-bold text-dark"><%= stats.totalClients %></h3>
					<small class="text-muted d-block text-truncate">Klien terdaftar</small>
				</div>
				<div class="avatar bg-info-subtle text-info rounded-3 d-flex align-items-center justify-content-center flex-shrink-0" style="width: 48px; height: 48px;">
					<i class="ti ti-users" style="font-size: 24px;"></i>
				</div>
			</div>
		</div>
	</div>
</div>

<!-- Main Section: Responsive 2 Columns Clean Grid -->
<div class="row g-4">
	<% if (hasPerm('articles.manage')) { %>
		<div class="col-12 col-lg-7">
			<div class="card border-0 shadow-sm rounded-3 h-100">
				<div class="card-header bg-white py-3 px-3 px-md-4 d-flex justify-content-between align-items-center border-bottom">
					<h6 class="fw-bold mb-0 text-dark">Artikel Blog Terbaru</h6>
					<a href="/admin/articles" class="text-primary small text-decoration-none fw-semibold text-nowrap">Lihat Semua &rarr;</a>
				</div>
				<div class="card-body p-0">
					<div class="table-responsive">
						<table class="table table-hover align-middle mb-0">
							<thead class="table-light">
								<tr>
									<th class="ps-3 ps-md-4 border-0 text-muted small">JUDUL ARTIKEL</th>
									<th class="border-0 text-muted small">KATEGORI</th>
									<th class="border-0 text-muted small">VIEWS</th>
									<th class="text-end pe-3 pe-md-4 border-0"></th>
								</tr>
							</thead>
							<tbody>
								<% if (recentArticles && recentArticles.length > 0) { %>
									<% recentArticles.forEach(function(article) { %>
										<tr>
											<td class="ps-3 ps-md-4 py-3">
												<div class="fw-semibold text-dark text-truncate article-title-cell">
													<%= article.title %>
												</div>
												<small class="text-muted"><%= article.author || 'Redaksi' %></small>
											</td>
											<td><span class="badge bg-light text-dark border px-2 py-1 text-nowrap"><%= article.category %></span></td>
											<td><span class="text-muted small text-nowrap"><%= article.views.toLocaleString('id-ID') %></span></td>
											<td class="text-end pe-3 pe-md-4">
												<a href="/admin/articles/<%= article.slug %>" class="btn btn-sm btn-light px-3 py-1 rounded-pill text-nowrap">
													Edit
												</a>
											</td>
										</tr>
									<% }); %>
								<% } else { %>
									<tr>
										<td colspan="4" class="text-center text-muted py-5">
											Belum ada artikel yang dipublikasikan.
										</td>
									</tr>
								<% } %>
							</tbody>
						</table>
					</div>
				</div>
			</div>
		</div>
	<% } %>

	<% if (hasPerm('inquiries.manage')) { %>
		<div class="<%= hasPerm('articles.manage') ? 'col-12 col-lg-5' : 'col-12' %>">
			<div class="card border-0 shadow-sm rounded-3 h-100">
				<div class="card-header bg-white py-3 px-3 px-md-4 d-flex justify-content-between align-items-center border-bottom">
					<h6 class="fw-bold mb-0 text-dark">Pesan Kontak Masuk</h6>
					<a href="/admin/inquiries" class="text-primary small text-decoration-none fw-semibold text-nowrap">Lihat Semua &rarr;</a>
				</div>
				<div class="card-body p-0">
					<% if (recentInquiries && recentInquiries.length > 0) { %>
						<div class="list-group list-group-flush">
							<% recentInquiries.forEach(function(inq) { %>
								<div class="list-group-item p-3 px-3 px-md-4 border-bottom">
									<div class="d-flex justify-content-between align-items-center gap-2 mb-1">
										<span class="fw-semibold text-dark small text-truncate"><%= inq.name %></span>
										<span class="badge <%= inq.status === 'NEW' ? 'bg-danger-subtle text-danger' : 'bg-light text-muted border' %> flex-shrink-0">
											<%= inq.status %>
										</span>
									</div>
									<div class="text-dark small fw-medium mb-1 text-truncate"><%= inq.subject %></div>
									<p class="mb-2 text-muted small" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;"><%= inq.message %></p>
									<div class="d-flex flex-wrap justify-content-end gap-2">
										<a href="mailto:<%= inq.email %>?subject=Re: <%= encodeURIComponent(inq.subject) %>" class="btn btn-xs btn-light small py-1 px-2 border rounded d-inline-flex align-items-center">
											<i class="ti ti-mail me-1"></i>Balas Email
										</a>
										<a href="/admin/inquiries" class="btn btn-xs btn-light small py-1 px-2 border rounded">
											Detail
										</a>
									</div>
								</div>
							<% }); %>
						</div>
					<% } else { %>
						<div class="text-center text-muted py-5">
							Belum ada pesan kontak masuk.
						</div>
					<% } %>
				</div>
			</div>
		</div>
	<% } %>
</div>
