<!-- Page Header -->
<div class="page-header mb-4">
	<div class="row align-items-center">
		<div class="col">
			<h3 class="page-title fw-bold text-dark">Profil Saya & Keamanan Akun</h3>
			<ul class="breadcrumb">
				<li class="breadcrumb-item"><a href="/admin">Dashboard</a></li>
				<li class="breadcrumb-item active">Profil Saya</li>
			</ul>
		</div>
	</div>
</div>
<!-- /Page Header -->

<div class="row">
	<!-- Profil Singkat & Role -->
	<div class="col-lg-4 mb-4">
		<div class="card shadow-sm border-0 rounded-4 h-100">
			<div class="card-body text-center p-4 d-flex flex-column justify-content-between">
				<div>
					<div class="avatar avatar-xxl bg-primary-subtle text-primary rounded-circle d-inline-flex align-items-center justify-content-center fw-bold mb-3 shadow-sm" style="width: 90px; height: 90px; font-size: 2rem;">
						<%= userDetail ? userDetail.name.charAt(0).toUpperCase() : 'A' %>
					</div>
					<h4 class="fw-bold text-dark mb-1"><%= userDetail ? userDetail.name : 'Administrator' %></h4>
					<p class="text-muted small mb-3"><%= userDetail ? userDetail.email : '-' %></p>
					
					<div class="mb-3">
						<% if (userDetail && userDetail.roles && userDetail.roles.length > 0) { %>
							<% userDetail.roles.forEach(function(ur) { %>
								<span class="badge bg-primary text-primary px-3 py-2 rounded-pill me-1 mb-1">
									<i class="ti ti-shield-check me-1"></i><%= ur.role.name %>
								</span>
							<% }); %>
						<% } else { %>
							<span class="badge bg-secondary text-secondary px-3 py-2 rounded-pill">Staf Umum</span>
						<% } %>
					</div>

					<hr class="my-3">

					<div class="text-start">
						<p class="small text-muted mb-1 fw-medium"><i class="ti ti-calendar me-2"></i>Bergabung Sejak</p>
						<p class="fw-semibold text-dark mb-3">
							<%= userDetail ? new Date(userDetail.createdAt).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' }) : '-' %>
						</p>

						<p class="small text-muted mb-1 fw-medium"><i class="ti ti-circle-check me-2"></i>Status Akun</p>
						<div>
							<% if (userDetail && userDetail.isActive) { %>
								<span class="badge bg-success text-success"><i class="ti ti-check me-1"></i>Aktif</span>
							<% } else { %>
								<span class="badge bg-danger text-danger">Non-aktif</span>
							<% } %>
						</div>
					</div>
				</div>

				<div class="mt-4 pt-3 border-top text-muted small">
					Alexa Computindo Group CMS & RBAC
				</div>
			</div>
		</div>
	</div>

	<!-- Form Update Profil & Ganti Password -->
	<div class="col-lg-8 mb-4">
		<!-- Update Profil -->
		<div class="card shadow-sm border-0 rounded-4 mb-4">
			<div class="card-header bg-white border-bottom p-4">
				<h5 class="fw-bold mb-0 text-dark"><i class="ti ti-user-edit text-primary me-2"></i>Informasi Akun Saya</h5>
			</div>
			<div class="card-body p-4">
				<form id="profileForm" onsubmit="handleUpdateProfile(event)">
					<div class="row">
						<div class="col-md-6 mb-3">
							<label class="form-label fw-medium">Nama Lengkap <span class="text-danger">*</span></label>
							<input type="text" class="form-control" id="profileName" value="<%= userDetail ? userDetail.name : '' %>" required placeholder="Nama lengkap Anda">
						</div>
						<div class="col-md-6 mb-3">
							<label class="form-label fw-medium">Email Admin <span class="text-danger">*</span></label>
							<input type="email" class="form-control" id="profileEmail" value="<%= userDetail ? userDetail.email : '' %>" required placeholder="alamat@email.com">
						</div>
					</div>
					<div class="d-flex justify-content-end mt-2">
						<button type="submit" class="btn btn-primary px-4 py-2 fw-medium" id="btnProfileSubmit">
							<i class="ti ti-device-floppy me-2"></i>Simpan Perubahan Profil
						</button>
					</div>
				</form>
			</div>
		</div>

		<!-- Ganti Password -->
		<div class="card shadow-sm border-0 rounded-4">
			<div class="card-header bg-white border-bottom p-4">
				<h5 class="fw-bold mb-0 text-dark"><i class="ti ti-lock text-primary me-2"></i>Keamanan & Ganti Password</h5>
			</div>
			<div class="card-body p-4">
				<form id="passwordForm" onsubmit="handleChangePassword(event)">
					<div class="mb-3">
						<label class="form-label fw-medium">Password Saat Ini <span class="text-danger">*</span></label>
						<input type="password" class="form-control" id="currentPassword" required placeholder="Masukkan password lama Anda">
					</div>
					<div class="row">
						<div class="col-md-6 mb-3">
							<label class="form-label fw-medium">Password Baru <span class="text-danger">*</span></label>
							<input type="password" class="form-control" id="newPassword" required minlength="6" placeholder="Minimal 6 karakter">
						</div>
						<div class="col-md-6 mb-3">
							<label class="form-label fw-medium">Konfirmasi Password Baru <span class="text-danger">*</span></label>
							<input type="password" class="form-control" id="confirmNewPassword" required minlength="6" placeholder="Ulangi password baru">
						</div>
					</div>
					<div class="d-flex justify-content-end mt-2">
						<button type="submit" class="btn btn-dark px-4 py-2 fw-medium" id="btnPasswordSubmit">
							<i class="ti ti-key me-2"></i>Perbarui Password
						</button>
					</div>
				</form>
			</div>
		</div>

		<!-- Integrasi API Backend -->
		<div class="card shadow-sm border-0 rounded-4 mt-4">
			<div class="card-header bg-white border-bottom p-4 d-flex justify-content-between align-items-center flex-wrap">
				<div>
					<h5 class="fw-bold mb-1 text-dark"><i class="ti ti-api-app text-primary me-2"></i>Token API Integrasi Backend</h5>
					<p class="text-muted small mb-0">Gunakan rahasia API Token ini untuk menghubungkan aplikasi eksternal, frontend, atau mobile app ke REST API</p>
				</div>
				<span class="badge bg-success-subtle text-success border border-success-subtle px-3 py-2 rounded-pill mt-2 mt-sm-0">
					<i class="ti ti-circle-check me-1"></i>Aktif & Siap Pakai
				</span>
			</div>
			<div class="card-body p-4">
				<div class="mb-4">
					<label class="form-label fw-medium text-dark">Secret API Token Anda</label>
					<div class="input-group">
						<span class="input-group-text bg-light border-end-0 text-muted">
							<i class="ti ti-key"></i>
						</span>
						<input type="password" id="apiTokenInput" class="form-control bg-light border-start-0 border-end-0 font-monospace text-primary fw-bold" readonly value="<%= typeof apiToken !== 'undefined' ? apiToken : 'alexa_live_secret_api_token_2026' %>">
						<button class="btn btn-outline-secondary bg-white" type="button" onclick="toggleApiTokenVisibility()" title="Tampilkan/Sembunyikan Token">
							<i class="ti ti-eye" id="toggleApiTokenIcon"></i>
						</button>
						<button class="btn btn-primary fw-medium px-3" type="button" onclick="copyApiToken()">
							<i class="ti ti-copy me-1"></i>Salin Token
						</button>
						<button class="btn btn-dark fw-medium px-3" type="button" onclick="testApiTokenConnection()">
							<i class="ti ti-plug me-1"></i>Uji Token
						</button>
					</div>
					<small class="text-muted d-block mt-2">
						<i class="ti ti-shield-lock me-1 text-warning"></i>Jaga kerahasiaan token ini. Token ini memberikan izin integrasi penuh (Super Admin Integration) pada seluruh endpoint REST API.
					</small>
				</div>

				<!-- Cara Penggunaan -->
				<div class="bg-light p-3 rounded-3 border">
					<h6 class="fw-bold text-dark mb-2"><i class="ti ti-code me-2 text-primary"></i>Cara Menggunakan Token API pada Header HTTP</h6>
					<p class="small text-muted mb-2">Sertakan header <code class="text-danger fw-bold">X-API-KEY</code> atau <code class="text-danger fw-bold">Authorization: Bearer</code> pada setiap request ke endpoint <code class="text-dark">/api/*</code>:</p>
					
					<div class="bg-dark text-light p-3 rounded-2 font-monospace small overflow-auto mb-0" style="max-height: 140px;">
						<span class="text-secondary"># Contoh request cURL ke backend API:</span><br>
						curl -X GET http://localhost:4000/api/articles \<br>
						&nbsp;&nbsp;-H <span class="text-warning">"X-API-KEY: <%= typeof apiToken !== 'undefined' ? apiToken : 'alexa_live_secret_api_token_2026' %>"</span> \<br>
						&nbsp;&nbsp;-H "Content-Type: application/json"
					</div>
				</div>
			</div>
		</div>
	</div>
</div>

<script>
async function handleUpdateProfile(e) {
	e.preventDefault();
	const name = document.getElementById('profileName').value.trim();
	const email = document.getElementById('profileEmail').value.trim();
	const btn = document.getElementById('btnProfileSubmit');

	btn.disabled = true;
	btn.innerHTML = `<span class="spinner-border spinner-border-sm me-2"></span>Menyimpan...`;

	try {
		const res = await fetch('/api/auth/profile', {
			method: 'PUT',
			headers: { 'Content-Type': 'application/json' },
			body: JSON.stringify({ name, email })
		});
		const result = await res.json();
		btn.disabled = false;
		btn.innerHTML = `<i class="ti ti-device-floppy me-2"></i>Simpan Perubahan Profil`;

		if (result.success) {
			Swal.fire({
				icon: 'success',
				title: 'Berhasil',
				text: result.message || 'Profil berhasil diperbarui.',
				timer: 1500,
				showConfirmButton: false
			}).then(() => location.reload());
		} else {
			Swal.fire('Gagal', result.message || 'Gagal memperbarui profil.', 'error');
		}
	} catch (err) {
		btn.disabled = false;
		btn.innerHTML = `<i class="ti ti-device-floppy me-2"></i>Simpan Perubahan Profil`;
		Swal.fire('Error', 'Terjadi kesalahan koneksi ke server.', 'error');
	}
}

async function handleChangePassword(e) {
	e.preventDefault();
	const currentPassword = document.getElementById('currentPassword').value;
	const newPassword = document.getElementById('newPassword').value;
	const confirmNewPassword = document.getElementById('confirmNewPassword').value;
	const btn = document.getElementById('btnPasswordSubmit');

	if (newPassword !== confirmNewPassword) {
		return Swal.fire('Gagal', 'Konfirmasi password baru tidak cocok.', 'warning');
	}

	btn.disabled = true;
	btn.innerHTML = `<span class="spinner-border spinner-border-sm me-2"></span>Memproses...`;

	try {
		const res = await fetch('/api/auth/change-password', {
			method: 'PUT',
			headers: { 'Content-Type': 'application/json' },
			body: JSON.stringify({ currentPassword, newPassword })
		});
		const result = await res.json();
		btn.disabled = false;
		btn.innerHTML = `<i class="ti ti-key me-2"></i>Perbarui Password`;

		if (result.success) {
			document.getElementById('passwordForm').reset();
			Swal.fire({
				icon: 'success',
				title: 'Password Diperbarui',
				text: result.message || 'Password Anda berhasil diubah.',
				timer: 1800,
				showConfirmButton: false
			});
		} else {
			Swal.fire('Gagal', result.message || 'Gagal mengubah password.', 'error');
		}
	} catch (err) {
		btn.disabled = false;
		btn.innerHTML = `<i class="ti ti-key me-2"></i>Perbarui Password`;
		Swal.fire('Error', 'Terjadi kesalahan koneksi ke server.', 'error');
	}
}

function toggleApiTokenVisibility() {
	const input = document.getElementById('apiTokenInput');
	const icon = document.getElementById('toggleApiTokenIcon');
	if (input.type === 'password') {
		input.type = 'text';
		icon.className = 'ti ti-eye-off text-primary';
	} else {
		input.type = 'password';
		icon.className = 'ti ti-eye';
	}
}

function copyApiToken() {
	const input = document.getElementById('apiTokenInput');
	navigator.clipboard.writeText(input.value).then(() => {
		Swal.fire({
			icon: 'success',
			title: 'Tersalin!',
			text: 'API Token berhasil disalin ke clipboard.',
			timer: 1500,
			showConfirmButton: false
		});
	});
}

async function testApiTokenConnection() {
	const apiToken = document.getElementById('apiTokenInput').value;
	Swal.fire({
		title: 'Menguji Koneksi...',
		allowOutsideClick: false,
		didOpen: () => { Swal.showLoading(); }
	});

	try {
		const res = await fetch('/api/auth/verify-api-token', {
			method: 'POST',
			headers: {
				'Content-Type': 'application/json',
				'X-API-KEY': apiToken
			},
			body: JSON.stringify({ apiToken })
		});
		const data = await res.json();
		if (data.success && data.valid) {
			Swal.fire({
				icon: 'success',
				title: 'Koneksi API Valid!',
				html: `<b>Identitas:</b> ${data.identity.name}<br><b>Hak Akses:</b> ${data.identity.access}`,
				confirmButtonColor: '#3BAE7C'
			});
		} else {
			Swal.fire('Koneksi Gagal', data.message || 'Token tidak valid.', 'error');
		}
	} catch (err) {
		Swal.fire('Error', 'Gagal menghubungi server.', 'error');
	}
}
</script>
