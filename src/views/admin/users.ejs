<!-- Page Header -->
<div class="page-header mb-4">
	<div class="row align-items-center">
		<div class="col">
			<h3 class="page-title fw-bold text-dark">Manajemen Pengguna Admin</h3>
			<ul class="breadcrumb">
				<li class="breadcrumb-item"><a href="/admin">Dashboard</a></li>
				<li class="breadcrumb-item active">Pengguna Admin</li>
			</ul>
		</div>
	</div>
</div>
<!-- /Page Header -->

<div class="card shadow-sm border-0 rounded-4">
	<div class="card-header bg-white border-bottom p-4 d-flex justify-content-between align-items-center flex-wrap gap-3">
		<h5 class="fw-bold mb-0 text-dark">Daftar Akun Admin</h5>
		<div class="d-flex align-items-center gap-2 flex-wrap">
			<div class="position-relative" style="width: 300px;">
				<i class="ti ti-search position-absolute text-muted" style="left: 16px; top: 50%; transform: translateY(-50%); font-size: 1.05rem; pointer-events: none;"></i>
				<input type="text" id="searchAdminInput" class="form-control ps-5 py-2 rounded-pill border shadow-none" placeholder="Cari nama atau email admin..." style="border-color: #E5E7EB; font-size: 0.88rem; background-color: #F8FAFC;" onkeyup="filterAdminTable()">
			</div>
			<button class="btn btn-primary d-inline-flex align-items-center px-4 py-2 fw-semibold rounded-pill shadow-sm" data-bs-toggle="modal" data-bs-target="#addUserModal">
				<i class="ti ti-plus me-2"></i>Tambah Admin Baru
			</button>
		</div>
	</div>
	<div class="card-body p-0">
		<div class="table-responsive">
			<table class="table table-hover align-middle mb-0" id="adminUsersTable">
				<thead class="table-light">
					<tr>
						<th class="ps-4">Nama & Email Admin</th>
						<th>Peran / Role</th>
						<th>Status Akun</th>
						<th>Tanggal Bergabung</th>
						<th class="text-end pe-4">Aksi</th>
					</tr>
				</thead>
				<tbody>
					<% if (users && users.length > 0) { %>
						<% users.forEach(function(item) { %>
							<tr class="admin-row">
								<td class="ps-4">
									<div class="d-flex align-items-center">
										<div class="avatar avatar-md bg-primary-subtle text-primary rounded-circle d-flex align-items-center justify-content-center me-3 fw-bold" style="width: 40px; height: 40px;">
											<%= item.name.charAt(0).toUpperCase() %>
										</div>
										<div>
											<div class="fw-bold text-dark admin-name"><%= item.name %></div>
											<div class="text-muted small admin-email"><%= item.email %></div>
										</div>
									</div>
								</td>
								<td>
									<% if (item.roles && item.roles.length > 0) { %>
										<% item.roles.forEach(function(ur) { %>
											<span class="badge bg-primary text-primary me-1 px-3 py-1 fw-semibold" style="background-color: rgba(59, 174, 124, 0.15) !important; color: #1a6342 !important; border: 1px solid rgba(59, 174, 124, 0.35) !important;">
												<i class="ti ti-shield-check me-1"></i><%= ur.role.name %>
											</span>
										<% }); %>
									<% } else { %>
										<span class="badge bg-secondary text-secondary px-3 py-1 fw-semibold" style="background-color: rgba(108, 117, 125, 0.15) !important; color: #3d4246 !important; border: 1px solid rgba(108, 117, 125, 0.35) !important;">
											Staf Umum
										</span>
									<% } %>
								</td>
								<td>
									<% if (item.isActive) { %>
										<span class="badge bg-success text-success px-3 py-1 fw-semibold" style="background-color: rgba(40, 167, 69, 0.15) !important; color: #145823 !important; border: 1px solid rgba(40, 167, 69, 0.35) !important;">
											<i class="ti ti-check me-1"></i>Aktif
										</span>
									<% } else { %>
										<span class="badge bg-danger text-danger px-3 py-1 fw-semibold" style="background-color: rgba(220, 53, 69, 0.15) !important; color: #8a1f2b !important; border: 1px solid rgba(220, 53, 69, 0.35) !important;">
											<i class="ti ti-lock-off me-1"></i>Non-aktif / Diblokir
										</span>
									<% } %>
								</td>
								<td class="text-muted small"><%= new Date(item.createdAt).toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' }) %></td>
								<td class="text-end pe-4">
									<button class="btn btn-icon btn-sm btn-light me-1" 
										title="Edit Data Admin" 
										onclick="openEditModal('<%= item.id %>')">
										<i class="ti ti-edit text-primary"></i>
									</button>
									<button class="btn btn-icon btn-sm btn-light me-1" 
										title="<%= item.isActive ? 'Non-aktifkan akun' : 'Aktifkan akun' %>" 
										onclick="toggleActive('<%= item.id %>', <%= !item.isActive %>, '<%= item.name %>')">
										<i class="ti ti-power <%= item.isActive ? 'text-warning' : 'text-success' %>"></i>
									</button>
									<button class="btn btn-icon btn-sm btn-danger-subtle text-danger" 
										title="Hapus akun" 
										onclick="deleteAdminUser('<%= item.id %>', '<%= item.name %>')">
										<i class="ti ti-trash"></i>
									</button>
								</td>
							</tr>
						<% }); %>
					<% } else { %>
						<tr>
							<td colspan="5" class="text-center text-muted py-5">Belum ada pengguna admin lain.</td>
						</tr>
					<% } %>
				</tbody>
			</table>
		</div>
	</div>
</div>

<!-- Modal Tambah Admin -->
<div class="modal fade" id="addUserModal" tabindex="-1">
	<div class="modal-dialog modal-dialog-centered">
		<div class="modal-content">
			<div class="modal-header">
				<h5 class="modal-title fw-bold">Tambah Pengguna Admin Baru</h5>
				<button type="button" class="btn-close" data-bs-dismiss="modal"></button>
			</div>
			<div class="modal-body">
				<form id="createUserForm">
					<div class="mb-3">
						<label class="form-label fw-medium">Nama Lengkap <span class="text-danger">*</span></label>
						<input type="text" class="form-control" name="name" required placeholder="Contoh: Budi Santoso">
					</div>
					<div class="mb-3">
						<label class="form-label fw-medium">Email Admin <span class="text-danger">*</span></label>
						<input type="email" class="form-control" name="email" required placeholder="budi@alexagroup.co.id">
					</div>
					<div class="mb-3">
						<label class="form-label fw-medium">Password <span class="text-danger">*</span></label>
						<input type="password" class="form-control" name="password" required placeholder="Minimal 6 karakter">
					</div>
					<div class="mb-3">
						<label class="form-label fw-medium">Pilih Peran (Role)</label>
						<select class="form-select" name="roleId">
							<% if (roles && roles.length > 0) { %>
								<% roles.forEach(function(r) { %>
									<option value="<%= r.id %>"><%= r.name %></option>
								<% }); %>
							<% } %>
						</select>
					</div>
				</form>
			</div>
			<div class="modal-footer d-flex justify-content-end align-items-center gap-3 py-3 px-4">
				<button type="button" class="btn btn-light px-4 py-2 rounded-pill fw-semibold" data-bs-dismiss="modal">Batal</button>
				<button type="button" class="btn btn-primary px-4 py-2 rounded-pill fw-semibold" onclick="submitCreateUser()">Simpan Admin</button>
			</div>
		</div>
	</div>
</div>

<!-- Modal Edit Admin -->
<div class="modal fade" id="editUserModal" tabindex="-1">
	<div class="modal-dialog modal-dialog-centered">
		<div class="modal-content">
			<div class="modal-header">
				<h5 class="modal-title fw-bold">Edit Pengguna Admin</h5>
				<button type="button" class="btn-close" data-bs-dismiss="modal"></button>
			</div>
			<div class="modal-body">
				<form id="editUserForm">
					<input type="hidden" name="id" id="editUserId">
					<div class="mb-3">
						<label class="form-label fw-medium">Nama Lengkap <span class="text-danger">*</span></label>
						<input type="text" class="form-control" name="name" id="editUserName" required>
					</div>
					<div class="mb-3">
						<label class="form-label fw-medium">Email Admin <span class="text-danger">*</span></label>
						<input type="email" class="form-control" name="email" id="editUserEmail" required>
					</div>
					<div class="mb-3">
						<label class="form-label fw-medium">Password Baru (Opsional)</label>
						<input type="password" class="form-control" name="password" id="editUserPassword" placeholder="Kosongkan jika tidak ingin diubah">
						<small class="text-muted">Isi hanya jika ingin me-reset password admin ini (min. 6 karakter).</small>
					</div>
					<div class="mb-3">
						<label class="form-label fw-medium">Pilih Peran (Role)</label>
						<select class="form-select" name="roleId" id="editUserRole">
							<% if (roles && roles.length > 0) { %>
								<% roles.forEach(function(r) { %>
									<option value="<%= r.id %>"><%= r.name %></option>
								<% }); %>
							<% } %>
						</select>
					</div>
					<div class="mb-3">
						<label class="form-label fw-medium">Status Akun</label>
						<select class="form-select" name="isActive" id="editUserIsActive">
							<option value="true">Aktif</option>
							<option value="false">Non-aktif</option>
						</select>
					</div>
				</form>
			</div>
			<div class="modal-footer d-flex justify-content-end align-items-center gap-3 py-3 px-4">
				<button type="button" class="btn btn-light px-4 py-2 rounded-pill fw-semibold" data-bs-dismiss="modal">Batal</button>
				<button type="button" class="btn btn-primary px-4 py-2 rounded-pill fw-semibold" onclick="submitEditUser()">Simpan Perubahan</button>
			</div>
		</div>
	</div>
</div>

<script>
function filterAdminTable() {
	const keyword = document.getElementById('searchAdminInput').value.toLowerCase();
	const rows = document.querySelectorAll('.admin-row');
	rows.forEach(row => {
		const nameText = row.querySelector('.admin-name').textContent.toLowerCase();
		const emailText = row.querySelector('.admin-email').textContent.toLowerCase();
		if (nameText.includes(keyword) || emailText.includes(keyword)) {
			row.style.display = '';
		} else {
			row.style.display = 'none';
		}
	});
}

async function openEditModal(id) {
	try {
		const res = await fetch(`/api/users/${id}`);
		const result = await res.json();
		if (result.success && result.data) {
			const u = result.data;
			document.getElementById('editUserId').value = u.id;
			document.getElementById('editUserName').value = u.name;
			document.getElementById('editUserEmail').value = u.email;
			document.getElementById('editUserPassword').value = '';
			document.getElementById('editUserIsActive').value = u.isActive ? 'true' : 'false';
			
			if (u.roleIds && u.roleIds.length > 0) {
				document.getElementById('editUserRole').value = u.roleIds[0];
			}

			const modal = new bootstrap.Modal(document.getElementById('editUserModal'));
			modal.show();
		} else {
			Swal.fire('Gagal', result.message || 'Gagal mengambil data admin.', 'error');
		}
	} catch (e) {
		Swal.fire('Error', 'Terjadi kesalahan koneksi server.', 'error');
	}
}

async function submitEditUser() {
	const id = document.getElementById('editUserId').value;
	const name = document.getElementById('editUserName').value.trim();
	const email = document.getElementById('editUserEmail').value.trim();
	const password = document.getElementById('editUserPassword').value;
	const roleId = document.getElementById('editUserRole').value;
	const isActive = document.getElementById('editUserIsActive').value === 'true';

	const payload = {
		name,
		email,
		roleIds: [roleId],
		isActive
	};

	if (password && password.trim() !== '') {
		payload.password = password;
	}

	try {
		const res = await fetch(`/api/users/${id}`, {
			method: 'PUT',
			headers: { 'Content-Type': 'application/json' },
			body: JSON.stringify(payload)
		});
		const result = await res.json();
		if (result.success) {
			Swal.fire({
				icon: 'success',
				title: 'Berhasil',
				text: 'Data admin berhasil diperbarui.',
				timer: 1500,
				showConfirmButton: false
			}).then(() => location.reload());
		} else {
			Swal.fire('Gagal', result.message || 'Gagal memperbarui admin.', 'error');
		}
	} catch (e) {
		Swal.fire('Error', 'Terjadi kesalahan koneksi server.', 'error');
	}
}

async function submitCreateUser() {
	const form = document.getElementById('createUserForm');
	const formData = new FormData(form);
	const data = {
		name: formData.get('name'),
		email: formData.get('email'),
		password: formData.get('password'),
		roleIds: [formData.get('roleId')]
	};

	try {
		const res = await fetch('/api/users', {
			method: 'POST',
			headers: { 'Content-Type': 'application/json' },
			body: JSON.stringify(data)
		});
		const result = await res.json();
		if (result.success) {
			Swal.fire({
				icon: 'success',
				title: 'Berhasil',
				text: 'Admin baru berhasil ditambahkan.',
				timer: 1500,
				showConfirmButton: false
			}).then(() => location.reload());
		} else {
			Swal.fire('Gagal', result.message || 'Gagal menambahkan admin', 'error');
		}
	} catch (e) {
		Swal.fire('Error', 'Terjadi kesalahan koneksi server', 'error');
	}
}

async function toggleActive(id, isActive, name) {
	const actionText = isActive ? 'aktifkan' : 'non-aktifkan';
	Swal.fire({
		title: 'Ubah Status Akun?',
		text: `Apakah Anda yakin ingin me-${actionText} akun admin "${name}"?`,
		icon: 'question',
		showCancelButton: true,
		confirmButtonColor: '#0d6efd',
		cancelButtonColor: '#6c757d',
		confirmButtonText: 'Ya, Ubah',
		cancelButtonText: 'Batal'
	}).then(async (result) => {
		if (result.isConfirmed) {
			try {
				const res = await fetch(`/api/users/${id}`, {
					method: 'PUT',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({ isActive })
				});
				const resultData = await res.json();
				if (resultData.success) {
					Swal.fire({
						icon: 'success',
						title: 'Status Diperbarui',
						text: `Akun ${name} telah berhasil di-${actionText}.`,
						timer: 1500,
						showConfirmButton: false
					}).then(() => location.reload());
				} else {
					Swal.fire('Gagal', resultData.message || 'Gagal mengubah status akun.', 'error');
				}
			} catch (e) {
				Swal.fire('Error', 'Terjadi kesalahan koneksi server.', 'error');
			}
		}
	});
}

async function deleteAdminUser(id, name) {
	Swal.fire({
		title: 'Hapus Akun Admin?',
		text: `Apakah Anda yakin ingin menghapus akun admin "${name}"? Tindakan ini tidak dapat dikembalikan.`,
		icon: 'warning',
		showCancelButton: true,
		confirmButtonColor: '#dc3545',
		cancelButtonColor: '#6c757d',
		confirmButtonText: 'Ya, Hapus',
		cancelButtonText: 'Batal'
	}).then(async (result) => {
		if (result.isConfirmed) {
			try {
				const res = await fetch(`/api/users/${id}`, {
					method: 'DELETE'
				});
				const resultData = await res.json();
				if (resultData.success) {
					Swal.fire({
						icon: 'success',
						title: 'Berhasil Dihapus',
						text: 'Akun admin telah berhasil dihapus.',
						timer: 1500,
						showConfirmButton: false
					}).then(() => location.reload());
				} else {
					Swal.fire('Gagal', resultData.message || 'Gagal menghapus admin', 'error');
				}
			} catch (e) {
				Swal.fire('Error', 'Terjadi kesalahan koneksi server.', 'error');
			}
		}
	});
}
</script>
