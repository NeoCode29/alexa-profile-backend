<!-- Page Header -->
<div class="page-header mb-4">
	<div class="row align-items-center">
		<div class="col">
			<h3 class="page-title fw-bold text-dark">Manajemen Lowongan Pekerjaan (Karir)</h3>
			<ul class="breadcrumb">
				<li class="breadcrumb-item"><a href="/admin">Dashboard</a></li>
				<li class="breadcrumb-item active">Karir</li>
			</ul>
		</div>
		<div class="col-auto">
			<button class="btn btn-primary d-inline-flex align-items-center" data-bs-toggle="modal" data-bs-target="#addCareerModal">
				<i class="ti ti-plus me-2"></i>Buka Lowongan
			</button>
		</div>
	</div>
</div>
<!-- /Page Header -->

<div class="card shadow-sm border-0">
	<div class="card-body">
		<div class="table-responsive">
			<table class="table table-hover align-middle mb-0">
				<thead class="table-light">
					<tr>
						<th>Posisi / Judul</th>
						<th>Divisi / Departemen</th>
						<th>Lokasi & Tipe</th>
						<th>Status</th>
						<th class="text-end">Aksi</th>
					</tr>
				</thead>
				<tbody>
					<% if (careers && careers.length > 0) { %>
						<% careers.forEach(function(item) { %>
							<tr>
								<td>
									<div class="fw-bold text-dark"><%= item.title %></div>
									<div class="text-muted small text-truncate" style="max-width: 300px;"><%= item.description %></div>
								</td>
								<td><span class="badge bg-primary text-primary"><%= item.department %></span></td>
								<td>
									<div class="fw-medium text-dark"><%= item.location %></div>
									<small class="text-muted"><%= item.type %></small>
								</td>
								<td>
									<span class="badge <%= item.isActive ? 'bg-success text-success' : 'bg-secondary text-secondary' %>">
										<%= item.isActive ? 'Aktif' : 'Ditutup' %>
									</span>
								</td>
								<td class="text-end">
									<button class="btn btn-icon btn-sm btn-danger-subtle text-danger" title="Tutup lowongan" onclick="deleteCareer('<%= item.id %>', '<%= item.title %>')">
										<i class="ti ti-trash"></i>
									</button>
								</td>
							</tr>
						<% }); %>
					<% } else { %>
						<tr>
							<td colspan="5" class="text-center text-muted py-5">
								<i class="ti ti-briefcase fs-1 d-block mb-2 text-secondary"></i>
								Belum ada lowongan pekerjaan dibuka.
							</td>
						</tr>
					<% } %>
				</tbody>
			</table>
		</div>
	</div>
</div>

<!-- Modal Tambah Lowongan -->
<div class="modal fade" id="addCareerModal" tabindex="-1">
	<div class="modal-dialog modal-lg modal-dialog-centered">
		<div class="modal-content">
			<div class="modal-header">
				<h5 class="modal-title fw-bold">Buka Lowongan Pekerjaan Baru</h5>
				<button type="button" class="btn-close" data-bs-dismiss="modal"></button>
			</div>
			<div class="modal-body">
				<form id="createCareerForm">
					<div class="mb-3">
						<label class="form-label fw-medium">Posisi Pekerjaan <span class="text-danger">*</span></label>
						<input type="text" class="form-control" name="title" required placeholder="Contoh: Senior Frontend Developer">
					</div>
					<div class="row">
						<div class="col-md-4 mb-3">
							<label class="form-label fw-medium">Divisi <span class="text-danger">*</span></label>
							<select class="form-select" name="department" required>
								<option value="WebMedia">WebMedia</option>
								<option value="InetMedia">InetMedia</option>
								<option value="MediaKampung">MediaKampung</option>
							</select>
						</div>
						<div class="col-md-4 mb-3">
							<label class="form-label fw-medium">Lokasi Kerja</label>
							<input type="text" class="form-control" name="location" value="Jakarta, Hybrid">
						</div>
						<div class="col-md-4 mb-3">
							<label class="form-label fw-medium">Tipe Pekerjaan</label>
							<select class="form-select" name="type">
								<option value="Full-time">Full-time</option>
								<option value="Contract">Contract</option>
								<option value="Remote">Remote</option>
							</select>
						</div>
					</div>
					<div class="mb-3">
						<label class="form-label fw-medium">Deskripsi Pekerjaan & Kualifikasi <span class="text-danger">*</span></label>
						<textarea class="form-control" name="description" rows="4" required placeholder="Jelaskan deskripsi dan syarat posisi..."></textarea>
					</div>
				</form>
			</div>
			<div class="modal-footer">
				<button type="button" class="btn btn-light" data-bs-dismiss="modal">Batal</button>
				<button type="button" class="btn btn-primary" onclick="submitCreateCareer()">Simpan Lowongan</button>
			</div>
		</div>
	</div>
</div>

<script>
async function submitCreateCareer() {
	const form = document.getElementById('createCareerForm');
	const formData = new FormData(form);
	const data = Object.fromEntries(formData.entries());

	if (!data.title || !data.department || !data.description) {
		Swal.fire('Peringatan', 'Harap isi semua kolom wajib (*).', 'warning');
		return;
	}

	try {
		const res = await fetch('/api/careers', {
			method: 'POST',
			headers: { 'Content-Type': 'application/json' },
			body: JSON.stringify(data)
		});
		const result = await res.json();
		if (result.success) {
			Swal.fire({
				icon: 'success',
				title: 'Berhasil',
				text: 'Lowongan pekerjaan baru berhasil diterbitkan.',
				timer: 1500,
				showConfirmButton: false
			}).then(() => location.reload());
		} else {
			Swal.fire('Gagal', result.message || 'Gagal menyimpan lowongan.', 'error');
		}
	} catch (e) {
		Swal.fire('Error', 'Terjadi kesalahan koneksi server.', 'error');
	}
}

async function deleteCareer(id, title) {
	Swal.fire({
		title: 'Hapus Lowongan?',
		text: `Apakah Anda yakin ingin menutup dan menghapus lowongan "${title}"?`,
		icon: 'warning',
		showCancelButton: true,
		confirmButtonColor: '#dc3545',
		cancelButtonColor: '#6c757d',
		confirmButtonText: 'Ya, Hapus',
		cancelButtonText: 'Batal'
	}).then(async (result) => {
		if (result.isConfirmed) {
			try {
				const res = await fetch(`/api/careers/${id}`, { method: 'DELETE' });
				const result = await res.json();
				if (result.success) {
					Swal.fire({
						icon: 'success',
						title: 'Terhapus',
						text: 'Lowongan pekerjaan telah dihapus.',
						timer: 1500,
						showConfirmButton: false
					}).then(() => location.reload());
				} else {
					Swal.fire('Gagal', result.message, 'error');
				}
			} catch (e) {
				Swal.fire('Error', 'Gagal memproses penghapusan.', 'error');
			}
		}
	});
}
</script>
