<!-- Page Header -->
<div class="page-header mb-4">
	<div class="row align-items-center">
		<div class="col">
			<h3 class="page-title fw-bold text-dark">Role & Permission (RBAC)</h3>
			<ul class="breadcrumb">
				<li class="breadcrumb-item"><a href="/admin">Dashboard</a></li>
				<li class="breadcrumb-item active">Role & Permission</li>
			</ul>
		</div>
	</div>
</div>
<!-- /Page Header -->

<div class="row">
	<!-- Daftar Role (Kiri) -->
	<div class="col-lg-4 mb-4">
		<div class="card shadow-sm border-0 rounded-4">
			<div class="card-header bg-white py-3 px-3 border-bottom d-flex justify-content-between align-items-center flex-wrap gap-2">
				<h5 class="card-title fw-bold mb-0 text-dark">Daftar Peran (Roles)</h5>
				<button class="btn btn-primary btn-sm d-inline-flex align-items-center px-3 py-2 fw-semibold rounded-pill shadow-sm" data-bs-toggle="modal" data-bs-target="#addRoleModal">
					<i class="ti ti-plus me-1"></i>Tambah Role
				</button>
			</div>
			<div class="card-body p-0">
				<div class="list-group list-group-flush" id="rolesListGroup">
					<% if (roles && roles.length > 0) { %>
						<% roles.forEach(function(role, idx) { %>
							<a href="javascript:void(0);" 
								class="list-group-item list-group-item-action p-3 d-flex justify-content-between align-items-center role-item-link <%= idx === 0 ? 'active-role bg-primary-subtle text-primary fw-semibold' : '' %>"
								onclick="selectRole('<%= role.id %>', '<%= role.name %>', '<%= role.description %>', '<%= encodeURIComponent(JSON.stringify(role.permissions.map(p => p.permission.name))) %>')">
								<div>
									<h6 class="mb-1 fw-bold role-name-title text-dark"><%= role.name %></h6>
									<small class="text-muted"><%= role.description || 'Tidak ada deskripsi' %></small>
								</div>
								<div class="d-flex align-items-center gap-2">
									<span class="badge bg-primary rounded-pill">
										<%= role.permissions ? role.permissions.length : 0 %> Hak
									</span>
									<% if (role.name !== 'Super Admin') { %>
										<button class="btn btn-icon btn-sm text-danger hover-danger border-0 bg-transparent p-0" onclick="event.stopPropagation(); deleteRole('<%= role.id %>', '<%= role.name %>')">
											<i class="ti ti-trash"></i>
										</button>
									<% } %>
								</div>
							</a>
						<% }); %>
					<% } else { %>
						<div class="p-4 text-center text-muted">Belum ada role.</div>
					<% } %>
				</div>
			</div>
		</div>
	</div>

	<!-- Matriks Permission (Kanan) -->
	<div class="col-lg-8 mb-4">
		<div class="card shadow-sm border-0 rounded-4">
			<div class="card-header bg-white py-3 px-3 border-bottom d-flex justify-content-between align-items-center flex-wrap gap-2">
				<div>
					<h5 class="card-title fw-bold mb-0 text-dark" id="permissionMatrixTitle">Hak Akses Role</h5>
					<p class="text-muted small mb-0" id="permissionMatrixSub">-</p>
				</div>
				<button class="btn btn-primary btn-sm d-inline-flex align-items-center px-4 py-2 fw-semibold rounded-pill shadow-sm" id="btnSavePermissions" onclick="savePermissions()">
					<i class="ti ti-device-floppy me-1"></i>Simpan Perubahan
				</button>
			</div>
			<div class="card-body">
				<div class="table-responsive">
					<table class="table table-hover align-middle">
						<thead class="table-light">
							<tr>
								<th style="width: 70%;">Modul & Izin Akses</th>
								<th class="text-center" style="width: 30%;">Status Izin</th>
							</tr>
						</thead>
						<tbody id="permissionsTableBody">
							<% if (permissions && permissions.length > 0) { %>
								<% permissions.forEach(function(perm) { %>
									<tr>
										<td>
											<div class="fw-bold text-dark"><%= perm.name %></div>
											<small class="text-muted"><%= perm.description %> (Modul: <%= perm.module %>)</small>
										</td>
										<td class="text-center">
											<div class="form-check form-switch d-inline-block">
												<input class="form-check-input permission-checkbox" 
													type="checkbox" 
													value="<%= perm.id %>" 
													data-perm-name="<%= perm.name %>"
													id="check-<%= perm.id %>">
											</div>
										</td>
									</tr>
								<% }); %>
							<% } else { %>
								<tr>
									<td colspan="2" class="text-center text-muted py-4">Belum ada daftar permission di database.</td>
								</tr>
							<% } %>
						</tbody>
					</table>
				</div>
			</div>
		</div>
	</div>
</div>

<!-- Modal Tambah Role -->
<div class="modal fade" id="addRoleModal" tabindex="-1">
	<div class="modal-dialog modal-dialog-centered">
		<div class="modal-content">
			<div class="modal-header">
				<h5 class="modal-title fw-bold">Tambah Peran (Role) Baru</h5>
				<button type="button" class="btn-close" data-bs-dismiss="modal"></button>
			</div>
			<div class="modal-body">
				<form id="createRoleForm">
					<div class="mb-3">
						<label class="form-label fw-medium">Nama Peran <span class="text-danger">*</span></label>
						<input type="text" class="form-control" name="name" required placeholder="Contoh: Content Writer">
					</div>
					<div class="mb-3">
						<label class="form-label fw-medium">Deskripsi Peran</label>
						<textarea class="form-control" name="description" rows="3" placeholder="Jelaskan cakupan akses peran ini..."></textarea>
					</div>
				</form>
			</div>
			<div class="modal-footer d-flex justify-content-end align-items-center gap-3 py-3 px-4">
				<button type="button" class="btn btn-light px-4 py-2 rounded-pill fw-semibold" data-bs-dismiss="modal">Batal</button>
				<button type="button" class="btn btn-primary px-4 py-2 rounded-pill fw-semibold" onclick="submitCreateRole()">Simpan Role</button>
			</div>
		</div>
	</div>
</div>

<style>
	/* Custom styles specifically for dynamic active role styling */
	.active-role {
		border-left: 4px solid var(--alexa-primary) !important;
		background-color: #f1f5f9 !important;
	}
</style>

<script>
let currentRoleId = null;
let currentRoleName = "";

// Ambil list permissions pertama saat halaman selesai dimuat
document.addEventListener("DOMContentLoaded", function() {
	const firstRoleLink = document.querySelector(".role-item-link");
	if (firstRoleLink) {
		firstRoleLink.click();
	}
});

function selectRole(id, name, desc, encodedPerms) {
	currentRoleId = id;
	currentRoleName = name;

	// Update styling list-group item
	document.querySelectorAll('.role-item-link').forEach(link => {
		link.classList.remove('active-role', 'bg-primary-subtle');
	});
	const activeLink = event.currentTarget || document.querySelector(`[onclick*="${id}"]`);
	if (activeLink) {
		activeLink.classList.add('active-role', 'bg-primary-subtle');
	}

	// Update judul panel kanan
	document.getElementById('permissionMatrixTitle').innerText = `Hak Akses Peran: ${name}`;
	document.getElementById('permissionMatrixSub').innerText = desc || 'Tidak ada deskripsi';

	// Parse permissions list untuk role terpilih
	const activePerms = JSON.parse(decodeURIComponent(encodedPerms));

	// Update status checkbox
	const checkboxes = document.querySelectorAll('.permission-checkbox');
	const isSuperAdmin = (name === 'Super Admin');

	checkboxes.forEach(cb => {
		const permName = cb.getAttribute('data-perm-name');
		if (isSuperAdmin) {
			cb.checked = true;
			cb.disabled = true;
		} else {
			cb.checked = activePerms.includes(permName);
			cb.disabled = false;
		}
	});

	// Sembunyikan/nonaktifkan tombol simpan jika Super Admin
	const saveBtn = document.getElementById('btnSavePermissions');
	if (isSuperAdmin) {
		saveBtn.classList.add('disabled');
		saveBtn.disabled = true;
	} else {
		saveBtn.classList.remove('disabled');
		saveBtn.disabled = false;
	}
}

async function savePermissions() {
	if (!currentRoleId || currentRoleName === 'Super Admin') return;

	// Kumpulkan ID permission yang dicentang
	const checkedPermissionIds = [];
	document.querySelectorAll('.permission-checkbox:checked').forEach(cb => {
		checkedPermissionIds.push(cb.value);
	});

	Swal.fire({
		title: 'Menyimpan...',
		text: 'Memperbarui hak akses role ' + currentRoleName,
		allowOutsideClick: false,
		didOpen: () => { Swal.showLoading(); }
	});

	try {
		const res = await fetch(`/api/rbac/roles/${currentRoleId}/permissions`, {
			method: 'PUT',
			headers: { 'Content-Type': 'application/json' },
			body: JSON.stringify({ permissionIds: checkedPermissionIds })
		});
		const result = await res.json();
		if (result.success) {
			Swal.fire({
				icon: 'success',
				title: 'Berhasil',
				text: 'Hak akses berhasil diperbarui!',
				timer: 1500,
				showConfirmButton: false
			}).then(() => location.reload());
		} else {
			Swal.fire('Gagal', result.message || 'Gagal menyimpan perubahan.', 'error');
		}
	} catch (err) {
		Swal.fire('Error', 'Terjadi kesalahan koneksi server.', 'error');
	}
}

async function submitCreateRole() {
	const form = document.getElementById('createRoleForm');
	const formData = new FormData(form);
	const data = {
		name: formData.get('name'),
		description: formData.get('description')
	};

	try {
		const res = await fetch('/api/rbac/roles', {
			method: 'POST',
			headers: { 'Content-Type': 'application/json' },
			body: JSON.stringify(data)
		});
		const result = await res.json();
		if (result.success) {
			Swal.fire({
				icon: 'success',
				title: 'Berhasil',
				text: 'Role baru berhasil ditambahkan.',
				timer: 1500,
				showConfirmButton: false
			}).then(() => location.reload());
		} else {
			Swal.fire('Gagal', result.message || 'Gagal menambahkan role.', 'error');
		}
	} catch (e) {
		Swal.fire('Error', 'Gagal menghubungi server.', 'error');
	}
}

async function deleteRole(id, name) {
	Swal.fire({
		title: 'Hapus Role?',
		text: `Apakah Anda yakin ingin menghapus peran "${name}"? Tindakan ini tidak dapat dibatalkan.`,
		icon: 'warning',
		showCancelButton: true,
		confirmButtonColor: '#dc3545',
		cancelButtonColor: '#6c757d',
		confirmButtonText: 'Ya, Hapus',
		cancelButtonText: 'Batal'
	}).then(async (result) => {
		if (result.isConfirmed) {
			try {
				const res = await fetch(`/api/rbac/roles/${id}`, { method: 'DELETE' });
				const resultData = await res.json();
				if (resultData.success) {
					Swal.fire({
						icon: 'success',
						title: 'Terhapus',
						text: 'Role berhasil dihapus.',
						timer: 1500,
						showConfirmButton: false
					}).then(() => location.reload());
				} else {
					Swal.fire('Gagal', resultData.message || 'Gagal menghapus role.', 'error');
				}
			} catch (e) {
				Swal.fire('Error', 'Gagal memproses penghapusan.', 'error');
			}
		}
	});
}
</script>
