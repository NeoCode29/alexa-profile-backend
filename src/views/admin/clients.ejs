<!-- Custom Clean Table & Page Styling -->
<style>
	.client-card {
		background: #ffffff;
		border: 1px solid #e2e8f0;
		border-radius: 14px;
		box-shadow: 0 1px 3px rgba(15, 23, 42, 0.035);
		transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
		overflow: hidden;
		display: flex;
		flex-direction: column;
		height: 100%;
	}
	.client-card:hover {
		transform: translateY(-4px);
		box-shadow: 0 12px 24px -6px rgba(15, 23, 42, 0.08);
		border-color: #cbd5e1;
	}
	.client-logo-box {
		height: 130px;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 18px;
		background-color: #f8fafc;
		background-image: radial-gradient(#cbd5e1 1px, transparent 1px);
		background-size: 14px 14px;
		border-bottom: 1px solid #f1f5f9;
		position: relative;
	}
	.client-logo-img {
		max-height: 84px;
		max-width: 90%;
		object-fit: contain;
		transition: transform 0.25s ease;
	}
	.client-card:hover .client-logo-img {
		transform: scale(1.05);
	}
	.client-order-badge {
		position: absolute;
		top: 10px;
		left: 10px;
		background: rgba(255, 255, 255, 0.9);
		backdrop-filter: blur(4px);
		border: 1px solid #e2e8f0;
		color: #475569;
		font-size: 0.75rem;
		font-weight: 600;
		padding: 3px 8px;
		border-radius: 6px;
	}
	.toolbar-card {
		background: #ffffff;
		border: 1px solid #e2e8f0;
		border-radius: 14px;
		box-shadow: 0 1px 3px rgba(15, 23, 42, 0.035);
		padding: 16px 20px;
		margin-bottom: 24px;
	}
	.view-toggle-btn {
		border: 1px solid #e2e8f0;
		background: #ffffff;
		color: #64748b;
		padding: 8px 14px;
		font-size: 0.875rem;
		font-weight: 500;
		transition: all 0.15s ease;
	}
	.view-toggle-btn:first-child {
		border-top-left-radius: 8px;
		border-bottom-left-radius: 8px;
	}
	.view-toggle-btn:last-child {
		border-top-right-radius: 8px;
		border-bottom-right-radius: 8px;
		border-left: none;
	}
	.view-toggle-btn.active {
		background: #3BAE7C;
		border-color: #3BAE7C;
		color: #ffffff;
	}
	.clean-table {
		margin-bottom: 0;
	}
	.clean-table thead th {
		background: #fafbfc;
		font-size: 0.75rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.6px;
		color: #64748b;
		padding: 14px 20px;
		border-bottom: 1px solid #e2e8f0;
	}
	.clean-table tbody td {
		padding: 16px 20px;
		vertical-align: middle;
		border-bottom: 1px solid #f1f5f9;
		font-size: 0.925rem;
	}
	.clean-table tbody tr:last-child td {
		border-bottom: none;
	}
	.clean-table tbody tr {
		transition: background-color 0.15s ease;
	}
	.clean-table tbody tr:hover {
		background-color: #f8fafc;
	}
	.table-logo-thumb {
		width: 76px;
		height: 46px;
		border-radius: 8px;
		background-color: #f8fafc;
		background-image: radial-gradient(#cbd5e1 1px, transparent 1px);
		background-size: 8px 8px;
		border: 1px solid #e2e8f0;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 4px;
	}
	.table-logo-thumb img {
		max-height: 36px;
		max-width: 66px;
		object-fit: contain;
	}
	.preview-box {
		height: 110px;
		border: 2px dashed #cbd5e1;
		border-radius: 10px;
		display: flex;
		align-items: center;
		justify-content: center;
		background-color: #f8fafc;
		background-image: radial-gradient(#cbd5e1 1px, transparent 1px);
		background-size: 12px 12px;
		overflow: hidden;
		padding: 10px;
	}
</style>

<!-- Page Header -->
<div class="page-header mb-4">
	<div>
		<h3 class="page-title fw-bold text-dark mb-1">Manajemen Klien & Mitra</h3>
		<p class="text-muted mb-0 small">Kelola daftar logo klien, mitra bisnis, dan brand partner yang ditampilkan pada marquee beranda situs.</p>
	</div>
</div>
<!-- /Page Header -->

<!-- Toolbar & Search Bar -->
<div class="toolbar-card">
	<div class="row align-items-center g-3">
		<div class="col-lg-5 col-md-5">
			<div class="input-group">
				<span class="input-group-text bg-light border-end-0 text-muted">
					<i class="ti ti-search"></i>
				</span>
				<input type="text" class="form-control border-start-0 ps-0" id="searchClientInput" placeholder="Cari nama klien atau perusahaan..." oninput="filterClients()">
			</div>
		</div>
		<div class="col-lg-3 col-md-3">
			<div class="d-flex align-items-center gap-2">
				<label class="form-label mb-0 small fw-medium text-muted text-nowrap">Urutkan:</label>
				<select class="form-select form-select-sm" id="sortClientSelect" onchange="filterClients()">
					<option value="order-asc">Urutan Tampil (0 - 99)</option>
					<option value="name-asc">Nama Klien (A - Z)</option>
					<option value="name-desc">Nama Klien (Z - A)</option>
				</select>
			</div>
		</div>
		<div class="col-lg-4 col-md-4 text-md-end d-flex align-items-center justify-content-md-end gap-3 flex-wrap">
			<div class="d-inline-flex" role="group">
				<button type="button" class="view-toggle-btn active" id="btnGridView" onclick="switchView('grid')" title="Tampilan Grid">
					<i class="ti ti-layout-grid me-1"></i>Grid
				</button>
				<button type="button" class="view-toggle-btn" id="btnTableView" onclick="switchView('table')" title="Tampilan Tabel">
					<i class="ti ti-list me-1"></i>Tabel
				</button>
			</div>
			<button class="btn btn-primary d-inline-flex align-items-center px-4 py-2 shadow-sm text-nowrap" data-bs-toggle="modal" data-bs-target="#addClientModal">
				<i class="ti ti-plus me-2"></i>Tambah Mitra
			</button>
		</div>
	</div>
</div>

<!-- Grid View Container -->
<div id="gridViewContainer">
	<div class="row" id="clientsGridRow">
		<% if (clients && clients.length > 0) { %>
			<% clients.forEach(function(item) { %>
				<div class="col-xl-3 col-lg-4 col-md-6 col-sm-6 col-12 mb-4 client-item" 
					data-name="<%= item.name.toLowerCase() %>" 
					data-order="<%= item.order || 0 %>" 
					data-id="<%= item.id %>">
					<div class="client-card">
						<div class="client-logo-box">
							<span class="client-order-badge" title="Urutan tampil pada marquee">
								<i class="ti ti-hash me-1"></i><%= item.order || 0 %>
							</span>
							<img src="<%= item.image %>" alt="<%= item.name %>" class="client-logo-img" onerror="this.src='/assets/img/logo.png'">
						</div>
						<div class="p-3 flex-grow-1 d-flex flex-column justify-content-between">
							<div class="mb-3">
								<h6 class="fw-bold mb-1 text-dark text-truncate" title="<%= item.name %>"><%= item.name %></h6>
								<span class="small text-muted text-truncate d-block" title="<%= item.image %>">
									<i class="ti ti-link me-1"></i><%= item.image %>
								</span>
							</div>
							<div class="d-flex gap-2 pt-2 border-top">
								<button class="btn btn-sm btn-light border flex-grow-1 text-dark fw-medium d-inline-flex align-items-center justify-content-center" 
									onclick="openEditClientModal('<%= item.id %>', '<%= encodeURIComponent(item.name) %>', '<%= encodeURIComponent(item.image) %>', '<%= item.order || 0 %>')">
									<i class="ti ti-edit me-1 text-primary"></i>Edit
								</button>
								<button class="btn btn-sm btn-danger-subtle text-danger px-3 d-inline-flex align-items-center justify-content-center" 
									onclick="deleteClient('<%= item.id %>', '<%= encodeURIComponent(item.name) %>')" title="Hapus Klien">
									<i class="ti ti-trash"></i>
								</button>
							</div>
						</div>
					</div>
				</div>
			<% }); %>
		<% } else { %>
			<div class="col-12 text-center py-5">
				<div class="card shadow-sm border-0 py-5">
					<div class="card-body">
						<i class="ti ti-users-group fs-1 d-block mb-3 text-muted"></i>
						<h5 class="fw-bold text-dark">Belum Ada Klien Ditambahkan</h5>
						<p class="text-muted mb-4">Tambahkan logo klien atau mitra pertama Anda untuk menampilkannya pada marquee beranda.</p>
						<button class="btn btn-primary px-4" data-bs-toggle="modal" data-bs-target="#addClientModal">
							<i class="ti ti-plus me-2"></i>Tambah Mitra Pertama
						</button>
					</div>
				</div>
			</div>
		<% } %>
	</div>
	<!-- Empty state filter search -->
	<div id="gridEmptySearch" class="text-center py-5 d-none">
		<i class="ti ti-search-off fs-1 d-block mb-2 text-muted"></i>
		<h6 class="fw-bold text-dark">Klien Tidak Ditemukan</h6>
		<p class="text-muted small">Coba gunakan kata kunci pencarian yang lain.</p>
	</div>
</div>

<!-- Table View Container (Hidden by default) -->
<div id="tableViewContainer" class="d-none">
	<div class="card shadow-sm border-0" style="border-radius: 14px; overflow: hidden;">
		<div class="table-responsive">
			<table class="table clean-table align-middle">
				<thead>
					<tr>
						<th style="width: 80px;" class="text-center">Urutan</th>
						<th style="width: 100px;">Logo</th>
						<th>Nama Klien & Mitra</th>
						<th>URL / Path Logo</th>
						<th>Format</th>
						<th class="text-end" style="width: 150px;">Aksi</th>
					</tr>
				</thead>
				<tbody id="clientsTableBody">
					<% if (clients && clients.length > 0) { %>
						<% clients.forEach(function(item) { %>
							<% 
								let ext = 'IMG';
								if (item.image && item.image.includes('.')) {
									ext = item.image.split('.').pop().split('?')[0].toUpperCase();
								}
							%>
							<tr class="table-client-row" 
								data-name="<%= item.name.toLowerCase() %>" 
								data-order="<%= item.order || 0 %>">
								<td class="text-center">
									<span class="badge bg-light text-dark border fw-bold px-2 py-1"><%= item.order || 0 %></span>
								</td>
								<td>
									<div class="table-logo-thumb">
										<img src="<%= item.image %>" alt="<%= item.name %>" onerror="this.src='/assets/img/logo.png'">
									</div>
								</td>
								<td>
									<div class="fw-bold text-dark"><%= item.name %></div>
								</td>
								<td>
									<span class="text-muted small text-truncate d-inline-block" style="max-width: 250px;" title="<%= item.image %>">
										<%= item.image %>
									</span>
								</td>
								<td>
									<span class="badge bg-secondary-subtle text-secondary fw-medium"><%= ext %></span>
								</td>
								<td class="text-end">
									<button class="btn btn-sm btn-light border text-dark me-1" title="Edit Klien"
										onclick="openEditClientModal('<%= item.id %>', '<%= encodeURIComponent(item.name) %>', '<%= encodeURIComponent(item.image) %>', '<%= item.order || 0 %>')">
										<i class="ti ti-edit text-primary"></i>
									</button>
									<button class="btn btn-sm btn-danger-subtle text-danger" title="Hapus Klien"
										onclick="deleteClient('<%= item.id %>', '<%= encodeURIComponent(item.name) %>')">
										<i class="ti ti-trash"></i>
									</button>
								</td>
							</tr>
						<% }); %>
					<% } else { %>
						<tr>
							<td colspan="6" class="text-center py-5 text-muted">
								Belum ada data klien yang tersedia.
							</td>
						</tr>
					<% } %>
				</tbody>
			</table>
		</div>
	</div>
	<div id="tableEmptySearch" class="text-center py-5 d-none">
		<i class="ti ti-search-off fs-1 d-block mb-2 text-muted"></i>
		<h6 class="fw-bold text-dark">Klien Tidak Ditemukan</h6>
		<p class="text-muted small">Coba gunakan kata kunci pencarian yang lain.</p>
	</div>
</div>

<!-- Modal Tambah Klien -->
<div class="modal fade" id="addClientModal" tabindex="-1">
	<div class="modal-dialog modal-dialog-centered">
		<div class="modal-content border-0 shadow" style="border-radius: 16px;">
			<div class="modal-header border-bottom px-4 py-3">
				<h5 class="modal-title fw-bold text-dark d-flex align-items-center">
					<i class="ti ti-plus me-2 text-primary"></i>Tambah Klien / Mitra Baru
				</h5>
				<button type="button" class="btn-close" data-bs-dismiss="modal"></button>
			</div>
			<div class="modal-body p-4">
				<form id="createClientForm" onsubmit="event.preventDefault(); submitCreateClient();">
					<div class="row g-3">
						<div class="col-md-8">
							<label class="form-label fw-medium text-dark">Nama Klien / Perusahaan <span class="text-danger">*</span></label>
							<input type="text" class="form-control" name="name" required placeholder="Contoh: PT. Teknologi Nusantara">
						</div>
						<div class="col-md-4">
							<label class="form-label fw-medium text-dark">Urutan Tampil</label>
							<input type="number" class="form-control" name="order" value="0" min="0" placeholder="0">
						</div>
						<div class="col-12">
							<label class="form-label fw-medium text-dark">Unggah File Logo dari PC</label>
							<input type="file" class="form-control" id="clientLogoFile" accept="image/*" onchange="uploadClientLogo(event, 'clientLogoUrl', 'addLogoPreview')">
							<small class="text-muted">Format disarankan: PNG (Transparan) atau SVG. Ukuran maksimal 2MB.</small>
						</div>
						<div class="col-12">
							<label class="form-label fw-medium text-dark">URL Logo <span class="text-danger">*</span></label>
							<input type="text" class="form-control" name="image" id="clientLogoUrl" required placeholder="/uploads/... atau https://..." oninput="updateLogoPreview(this.value, 'addLogoPreview')">
						</div>
						<div class="col-12">
							<label class="form-label fw-medium text-dark small mb-1">Pratinjau Logo:</label>
							<div class="preview-box">
								<img id="addLogoPreview" src="/assets/img/logo.png" alt="Preview Logo" style="max-height: 80px; max-width: 90%; object-fit: contain;">
							</div>
						</div>
					</div>
				</form>
			</div>
			<div class="modal-footer border-top px-4 py-3 bg-light" style="border-bottom-left-radius: 16px; border-bottom-right-radius: 16px;">
				<button type="button" class="btn btn-light border px-4" data-bs-dismiss="modal">Batal</button>
				<button type="button" class="btn btn-primary px-4" onclick="submitCreateClient()">
					<i class="ti ti-device-floppy me-1"></i>Simpan Klien
				</button>
			</div>
		</div>
	</div>
</div>

<!-- Modal Edit Klien -->
<div class="modal fade" id="editClientModal" tabindex="-1">
	<div class="modal-dialog modal-dialog-centered">
		<div class="modal-content border-0 shadow" style="border-radius: 16px;">
			<div class="modal-header border-bottom px-4 py-3">
				<h5 class="modal-title fw-bold text-dark d-flex align-items-center">
					<i class="ti ti-edit me-2 text-primary"></i>Edit Data Klien / Mitra
				</h5>
				<button type="button" class="btn-close" data-bs-dismiss="modal"></button>
			</div>
			<div class="modal-body p-4">
				<form id="editClientForm" onsubmit="event.preventDefault(); submitUpdateClient();">
					<input type="hidden" id="editClientId">
					<div class="row g-3">
						<div class="col-md-8">
							<label class="form-label fw-medium text-dark">Nama Klien / Perusahaan <span class="text-danger">*</span></label>
							<input type="text" class="form-control" id="editClientName" name="name" required placeholder="Nama Klien">
						</div>
						<div class="col-md-4">
							<label class="form-label fw-medium text-dark">Urutan Tampil</label>
							<input type="number" class="form-control" id="editClientOrder" name="order" value="0" min="0">
						</div>
						<div class="col-12">
							<label class="form-label fw-medium text-dark">Ganti Logo dari PC (Opsional)</label>
							<input type="file" class="form-control" accept="image/*" onchange="uploadClientLogo(event, 'editClientLogoUrl', 'editLogoPreview')">
						</div>
						<div class="col-12">
							<label class="form-label fw-medium text-dark">URL Logo <span class="text-danger">*</span></label>
							<input type="text" class="form-control" id="editClientLogoUrl" name="image" required oninput="updateLogoPreview(this.value, 'editLogoPreview')">
						</div>
						<div class="col-12">
							<label class="form-label fw-medium text-dark small mb-1">Pratinjau Logo:</label>
							<div class="preview-box">
								<img id="editLogoPreview" src="/assets/img/logo.png" alt="Preview Logo" style="max-height: 80px; max-width: 90%; object-fit: contain;">
							</div>
						</div>
					</div>
				</form>
			</div>
			<div class="modal-footer border-top px-4 py-3 bg-light" style="border-bottom-left-radius: 16px; border-bottom-right-radius: 16px;">
				<button type="button" class="btn btn-light border px-4" data-bs-dismiss="modal">Batal</button>
				<button type="button" class="btn btn-primary px-4" onclick="submitUpdateClient()">
					<i class="ti ti-check me-1"></i>Simpan Perubahan
				</button>
			</div>
		</div>
	</div>
</div>

<script>
// Switch between Grid and Table View
function switchView(viewType) {
	const gridContainer = document.getElementById('gridViewContainer');
	const tableContainer = document.getElementById('tableViewContainer');
	const btnGrid = document.getElementById('btnGridView');
	const btnTable = document.getElementById('btnTableView');

	if (viewType === 'grid') {
		gridContainer.classList.remove('d-none');
		tableContainer.classList.add('d-none');
		btnGrid.classList.add('active');
		btnTable.classList.remove('active');
	} else {
		gridContainer.classList.add('d-none');
		tableContainer.classList.remove('d-none');
		btnGrid.classList.remove('active');
		btnTable.classList.add('active');
	}
}

// Search and Filter clients live
function filterClients() {
	const query = document.getElementById('searchClientInput').value.toLowerCase().trim();
	const sortBy = document.getElementById('sortClientSelect').value;

	// Filter and sort Grid items
	const gridRow = document.getElementById('clientsGridRow');
	const gridItems = Array.from(gridRow.querySelectorAll('.client-item'));
	let gridVisibleCount = 0;

	// Sort grid items
	gridItems.sort((a, b) => {
		const orderA = parseInt(a.getAttribute('data-order') || '0');
		const orderB = parseInt(b.getAttribute('data-order') || '0');
		const nameA = a.getAttribute('data-name');
		const nameB = b.getAttribute('data-name');

		if (sortBy === 'order-asc') return orderA - orderB;
		if (sortBy === 'name-asc') return nameA.localeCompare(nameB);
		if (sortBy === 'name-desc') return nameB.localeCompare(nameA);
		return 0;
	});

	gridItems.forEach(item => {
		const name = item.getAttribute('data-name');
		const isMatch = name.includes(query);
		item.style.display = isMatch ? '' : 'none';
		if (isMatch) gridVisibleCount++;
		gridRow.appendChild(item);
	});

	const gridEmpty = document.getElementById('gridEmptySearch');
	if (gridVisibleCount === 0 && gridItems.length > 0) {
		gridEmpty.classList.remove('d-none');
	} else {
		gridEmpty.classList.add('d-none');
	}

	// Filter and sort Table rows
	const tableBody = document.getElementById('clientsTableBody');
	if (tableBody) {
		const tableRows = Array.from(tableBody.querySelectorAll('.table-client-row'));
		let tableVisibleCount = 0;

		tableRows.sort((a, b) => {
			const orderA = parseInt(a.getAttribute('data-order') || '0');
			const orderB = parseInt(b.getAttribute('data-order') || '0');
			const nameA = a.getAttribute('data-name');
			const nameB = b.getAttribute('data-name');

			if (sortBy === 'order-asc') return orderA - orderB;
			if (sortBy === 'name-asc') return nameA.localeCompare(nameB);
			if (sortBy === 'name-desc') return nameB.localeCompare(nameA);
			return 0;
		});

		tableRows.forEach(row => {
			const name = row.getAttribute('data-name');
			const isMatch = name.includes(query);
			row.style.display = isMatch ? '' : 'none';
			if (isMatch) tableVisibleCount++;
			tableBody.appendChild(row);
		});

		const tableEmpty = document.getElementById('tableEmptySearch');
		if (tableVisibleCount === 0 && tableRows.length > 0) {
			tableEmpty.classList.remove('d-none');
		} else {
			tableEmpty.classList.add('d-none');
		}
	}
}

// Update image preview dynamically
function updateLogoPreview(url, previewImgId) {
	const img = document.getElementById(previewImgId);
	if (!img) return;
	if (url && url.trim() !== '') {
		img.src = url;
	} else {
		img.src = '/assets/img/logo.png';
	}
}

// Upload Client Logo Helper
async function uploadClientLogo(e, targetUrlInputId, previewImgId) {
	const file = e.target.files[0];
	if (!file) return;
	const formData = new FormData();
	formData.append('image', file);
	try {
		const res = await fetch('/api/upload', { method: 'POST', body: formData });
		const result = await res.json();
		if (result.success) {
			document.getElementById(targetUrlInputId).value = result.url;
			updateLogoPreview(result.url, previewImgId);
			Swal.fire({
				icon: 'success',
				title: 'Logo Terunggah',
				text: 'File gambar berhasil diunggah ke server.',
				timer: 1200,
				showConfirmButton: false
			});
		} else {
			Swal.fire('Gagal Unggah', result.message || 'Gagal mengunggah logo', 'error');
		}
	} catch (err) {
		Swal.fire('Error', 'Terjadi gangguan koneksi saat mengunggah logo.', 'error');
	}
}

// Submit Create Client
async function submitCreateClient() {
	const form = document.getElementById('createClientForm');
	const formData = new FormData(form);
	const data = Object.fromEntries(formData.entries());
	
	if (!data.name || !data.image) {
		Swal.fire('Peringatan', 'Harap lengkapi nama klien dan gambar logo.', 'warning');
		return;
	}

	try {
		const res = await fetch('/api/clients', {
			method: 'POST',
			headers: { 'Content-Type': 'application/json' },
			body: JSON.stringify(data)
		});
		const result = await res.json();
		if (result.success) {
			Swal.fire({
				icon: 'success',
				title: 'Berhasil Ditambahkan',
				text: 'Klien baru berhasil ditambahkan ke daftar marquee.',
				timer: 1500,
				showConfirmButton: false
			}).then(() => location.reload());
		} else {
			Swal.fire('Gagal', result.message || 'Gagal menyimpan klien', 'error');
		}
	} catch (e) {
		Swal.fire('Error', 'Terjadi kesalahan koneksi server.', 'error');
	}
}

// Open Edit Client Modal
function openEditClientModal(id, encodedName, encodedImage, order) {
	const name = decodeURIComponent(encodedName);
	const image = decodeURIComponent(encodedImage);

	document.getElementById('editClientId').value = id;
	document.getElementById('editClientName').value = name;
	document.getElementById('editClientLogoUrl').value = image;
	document.getElementById('editClientOrder').value = order || 0;
	updateLogoPreview(image, 'editLogoPreview');

	const editModal = new bootstrap.Modal(document.getElementById('editClientModal'));
	editModal.show();
}

// Submit Update Client
async function submitUpdateClient() {
	const id = document.getElementById('editClientId').value;
	const name = document.getElementById('editClientName').value.trim();
	const image = document.getElementById('editClientLogoUrl').value.trim();
	const order = document.getElementById('editClientOrder').value;

	if (!name || !image) {
		Swal.fire('Peringatan', 'Harap lengkapi nama klien dan URL logo.', 'warning');
		return;
	}

	try {
		const res = await fetch(`/api/clients/${id}`, {
			method: 'PUT',
			headers: { 'Content-Type': 'application/json' },
			body: JSON.stringify({ name, image, order })
		});
		const result = await res.json();
		if (result.success) {
			Swal.fire({
				icon: 'success',
				title: 'Diperbarui',
				text: 'Data klien berhasil diperbarui.',
				timer: 1500,
				showConfirmButton: false
			}).then(() => location.reload());
		} else {
			Swal.fire('Gagal', result.message || 'Gagal memperbarui data klien', 'error');
		}
	} catch (e) {
		Swal.fire('Error', 'Terjadi kesalahan koneksi ke server.', 'error');
	}
}

// Delete Client
async function deleteClient(id, encodedName) {
	const name = decodeURIComponent(encodedName);
	Swal.fire({
		title: 'Hapus Logo Klien?',
		text: `Apakah Anda yakin ingin menghapus logo klien "${name}"?`,
		icon: 'warning',
		showCancelButton: true,
		confirmButtonColor: '#dc3545',
		cancelButtonColor: '#6c757d',
		confirmButtonText: 'Ya, Hapus',
		cancelButtonText: 'Batal'
	}).then(async (result) => {
		if (result.isConfirmed) {
			try {
				const res = await fetch(`/api/clients/${id}`, { method: 'DELETE' });
				const resultData = await res.json();
				if (resultData.success) {
					Swal.fire({
						icon: 'success',
						title: 'Terhapus',
						text: 'Logo klien berhasil dihapus.',
						timer: 1500,
						showConfirmButton: false
					}).then(() => location.reload());
				} else {
					Swal.fire('Gagal', resultData.message || 'Gagal menghapus klien', 'error');
				}
			} catch (e) {
				Swal.fire('Error', 'Gagal memproses penghapusan dari server.', 'error');
			}
		}
	});
}
</script>
