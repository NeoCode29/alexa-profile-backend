<!DOCTYPE html>
<html lang="id">

<head>
	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=0">
	<title><%= typeof title !== 'undefined' ? title : 'Admin Panel' %> — Alexa Computindo CMS</title>

	<!-- Favicon -->
	<link rel="icon" type="image/svg+xml" href="/assets/img/favicon.svg">
	<link rel="shortcut icon" href="/assets/img/favicon.svg">

	<!-- Theme Settings Js -->
	<script src="/assets/js/theme-script.js"></script>

	<!-- Bootstrap CSS -->
	<link rel="stylesheet" href="/assets/css/bootstrap.min.css">

	<!-- Tabler Icons Webfont CDN & Lokal -->
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/dist/tabler-icons.min.css">
	<link rel="stylesheet" href="/assets/plugins/tabler-icons/tabler-icons.min.css">

	<!-- FontAwesome CSS -->
	<link rel="stylesheet" href="/assets/plugins/fontawesome/css/fontawesome.min.css">
	<link rel="stylesheet" href="/assets/plugins/fontawesome/css/all.min.css">

	<!-- Main CSS (Dreamsrent Reference Style) -->
	<link rel="stylesheet" href="/assets/css/style.css">
	<link rel="stylesheet" href="/assets/css/alexa-theme.css">

	<!-- Custom Style: Warna Utama Hijau Alexa & Override Total Warna Kuning (#FE9F43 / #FFA633) -->
	<style>
		:root {
			--primary: #3BAE7C;
			--primary-hover: #2E9668;
			--bs-primary: #3BAE7C;
			--bs-primary-rgb: 59, 174, 124;
		}
		/* SELECTION HIGHLIGHT & CARET CURSOR: Pada saat menyeleksi teks, sorotan berlatar Hijau Alexa bukan kuning */
		::selection {
			background-color: #3BAE7C !important;
			color: #ffffff !important;
		}
		::-moz-selection {
			background-color: #3BAE7C !important;
			color: #ffffff !important;
		}
		input, textarea, select {
			caret-color: #3BAE7C !important;
		}
		/* OVERRIDE TOTAL: SEMUA TOMBOL & HOVER TOMBOL (Hapus kuning #FE9F43 / #FFA633) */
		.btn-primary, .btn-primary.disabled, .btn-primary:disabled {
			background-color: #3BAE7C !important;
			border-color: #3BAE7C !important;
			color: #ffffff !important;
		}
		.btn-primary:hover, .btn-primary:focus, .btn-primary:active,
		.btn-primary.active, .open > .dropdown-toggle.btn-primary,
		button.btn-primary:hover, a.btn-primary:hover,
		.btn-primary:not(:disabled):not(.disabled):active,
		.btn-primary:not(:disabled):not(.disabled).active,
		.btn-primary:focus-visible {
			background-color: #2E9668 !important;
			border-color: #2E9668 !important;
			color: #ffffff !important;
			box-shadow: 0 4px 10px rgba(59, 174, 124, 0.25) !important;
		}
		.btn:hover, .btn:focus {
			outline: none !important;
			box-shadow: none !important;
		}
		/* PERBAIKAN MODAL FOOTER & TOMBOL: Jarak rapi antar tombol Batal & Simpan di semua modal */
		.modal-footer {
			display: flex !important;
			justify-content: flex-end !important;
			align-items: center !important;
			gap: 14px !important;
			padding: 1.1rem 1.5rem !important;
			border-top: 1px solid #E5E7EB !important;
		}
		.modal-footer .btn {
			margin: 0 !important;
		}
		/* Tombol Outline & Aksi */
		.btn-outline-primary {
			color: #3BAE7C !important;
			border-color: #3BAE7C !important;
		}
		.btn-outline-primary:hover, .btn-outline-primary:focus, .btn-outline-primary:active {
			background-color: #3BAE7C !important;
			border-color: #3BAE7C !important;
			color: #ffffff !important;
		}
		/* Tombol Aksi Tabel / Icon Button saat dihover */
		.btn-icon:hover, .btn-light:hover, .btn-action:hover,
		.table tbody tr td .btn:hover {
			background-color: rgba(59, 174, 124, 0.15) !important;
			color: #2E9668 !important;
			border-color: rgba(59, 174, 124, 0.3) !important;
		}
		/* Link hover & Text Aktif */
		a:hover, .text-primary:hover {
			color: #2E9668 !important;
		}
		.text-primary {
			color: #3BAE7C !important;
		}
		.border-primary {
			border-color: #3BAE7C !important;
		}
		/* Pagination Aktif & Hover */
		.pagination .page-item.active .page-link, .page-link:hover {
			background-color: #3BAE7C !important;
			border-color: #3BAE7C !important;
			color: #ffffff !important;
		}

		/* HILANGKAN GARIS PEMBATAS / BORDER di bawah header atas & di atas footer */
		.header {
			border-bottom: none !important;
			box-shadow: none !important;
		}
		.sidebar-logo-box {
			border-bottom: none !important;
		}
		.footer {
			border-top: none !important;
			background: transparent !important;
		}


		/* PERBAIKAN BADGE: Konsisten soft-pill badge agar teks selalu kontras dan jelas */
		.badge {
			padding: 0.42em 0.82em !important;
			font-size: 0.76rem !important;
			font-weight: 600 !important;
			border-radius: 50rem !important;
			display: inline-flex !important;
			align-items: center !important;
			line-height: 1.2 !important;
		}
		.badge.bg-primary, .badge.bg-primary.text-primary, .badge-soft-primary {
			background-color: rgba(59, 174, 124, 0.15) !important;
			color: #1a6342 !important;
			border: 1px solid rgba(59, 174, 124, 0.35) !important;
		}
		.badge.bg-success, .badge.bg-success.text-success, .badge-soft-success {
			background-color: rgba(40, 167, 69, 0.15) !important;
			color: #145823 !important;
			border: 1px solid rgba(40, 167, 69, 0.35) !important;
		}
		.badge.bg-danger, .badge.bg-danger.text-danger, .badge-soft-danger {
			background-color: rgba(220, 53, 69, 0.15) !important;
			color: #8a1f2b !important;
			border: 1px solid rgba(220, 53, 69, 0.35) !important;
		}
		.badge.bg-warning, .badge.bg-warning.text-warning, .badge-soft-warning {
			background-color: rgba(255, 193, 7, 0.18) !important;
			color: #7a5800 !important;
			border: 1px solid rgba(255, 193, 7, 0.35) !important;
		}
		.badge.bg-info, .badge.bg-info.text-info, .badge-soft-info {
			background-color: rgba(13, 202, 240, 0.15) !important;
			color: #085869 !important;
			border: 1px solid rgba(13, 202, 240, 0.35) !important;
		}
		.badge.bg-secondary, .badge.bg-secondary.text-secondary, .badge-soft-secondary {
			background-color: rgba(108, 117, 125, 0.15) !important;
			color: #3d4246 !important;
			border: 1px solid rgba(108, 117, 125, 0.35) !important;
		}

		/* PASTIKAN SIDEBAR BERWARNA PUTIH BERSIH SEPERTI SEBELUMNYA */
		.sidebar {
			background-color: #FFFFFF !important;
			border-right: 1px solid #E5E7EB !important;
			box-shadow: 0 0 15px rgba(0, 0, 0, 0.04) !important;
		}
		/* PASTIKAN TEKS LOGO "ALEXA GROUP" SELALU TERLIHAT JELAS (TIDAK MEMUTIH) */
		.sidebar-logo-box a span,
		.sidebar .sidebar-logo-box a span {
			color: #1E293B !important;
		}
		.sidebar-logo-box a span span,
		.sidebar .sidebar-logo-box a span span {
			color: #3BAE7C !important;
		}
		/* SIDEBAR MENU PREMIUM UI POLISH */
		.sidebar {
			background-color: #FFFFFF !important;
			border-right: 1px solid #EEF2F6 !important;
		}
		.sidebar .sidebar-menu {
			padding: 12px 16px 40px 16px !important;
		}
		.sidebar-menu ul {
			list-style: none !important;
			padding: 0 !important;
			margin: 0 !important;
		}
		.sidebar-menu ul li a {
			display: flex !important;
			align-items: center !important;
			padding: 8px 12px !important;
			margin: 2px 0 !important;
			border-radius: 8px !important;
			color: #475569 !important;
			font-size: 0.85rem !important;
			font-weight: 500 !important;
			text-decoration: none !important;
			border: 1px solid transparent !important;
			transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1) !important;
		}
		.sidebar-menu ul li a i,
		.sidebar-menu ul li a svg {
			font-size: 1.08rem !important;
			margin-right: 10px !important;
			color: #64748B !important;
			flex-shrink: 0 !important;
			transition: all 0.2s ease !important;
		}
		.sidebar-menu ul li.menu-title {
			padding: 14px 10px 4px 10px !important;
			margin: 0 !important;
			list-style: none !important;
		}
		.sidebar-menu ul li.menu-title span {
			color: #94A3B8 !important;
			font-size: 0.68rem !important;
			font-weight: 700 !important;
			letter-spacing: 0.8px !important;
			text-transform: uppercase !important;
		}

		/* OVERRIDE TOTAL: SIDEBAR ACTIVE (Soft Emerald Card Style) */
		.sidebar .sidebar-menu ul li.active > a,
		.sidebar .sidebar-menu ul li > a.active {
			background-color: rgba(59, 174, 124, 0.12) !important;
			color: #167A4F !important;
			font-weight: 600 !important;
			border: 1px solid rgba(59, 174, 124, 0.2) !important;
			box-shadow: 0 2px 6px rgba(59, 174, 124, 0.08) !important;
		}
		.sidebar .sidebar-menu ul li.active > a span,
		.sidebar .sidebar-menu ul li.active > a i,
		.sidebar .sidebar-menu ul li.active > a svg,
		.sidebar .sidebar-menu ul li > a.active span,
		.sidebar .sidebar-menu ul li > a.active i,
		.sidebar .sidebar-menu ul li > a.active svg {
			color: #167A4F !important;
		}
		.sidebar-menu ul li.active::before {
			display: none !important;
		}

		/* SIDEBAR HOVER */
		.sidebar-menu ul li a:hover:not(.active) {
			background-color: #F8FAFC !important;
			color: #0F172A !important;
			border-color: #E2E8F0 !important;
		}
		.sidebar-menu ul li a:hover:not(.active) i,
		.sidebar-menu ul li a:hover:not(.active) svg {
			color: #3BAE7C !important;
		}

		/* Header-left always visible for toggle button */
		.header-left {
			display: flex !important;
			align-items: center !important;
		}

		/* LAYOUT DESKTOP (Modern Full-Height Sidebar) */
		@media (min-width: 992px) {
			.sidebar {
				top: 0 !important;
				left: 0 !important;
				width: 260px !important;
				height: 100vh !important;
				z-index: 1050 !important;
				transition: all 0.25s ease !important;
			}
			.header {
				left: 260px !important;
				width: calc(100% - 260px) !important;
				transition: all 0.25s ease !important;
			}
			.page-wrapper {
				margin-left: 260px !important;
				transition: all 0.25s ease !important;
			}

			/* Mini Sidebar Mode pada Desktop */
			body.mini-sidebar .sidebar {
				width: 76px !important;
			}
			body.mini-sidebar .header {
				left: 76px !important;
				width: calc(100% - 76px) !important;
			}
			body.mini-sidebar .page-wrapper {
				margin-left: 76px !important;
			}
			body.mini-sidebar .sidebar-logo-box span.logo-text,
			body.mini-sidebar .sidebar-menu ul li a span {
				display: none !important;
			}
			body.mini-sidebar .sidebar-logo-box {
				justify-content: center !important;
				padding: 0 !important;
			}
			/* Ketika mini-sidebar dihover (Expand Menu) */
			body.mini-sidebar.expand-menu .sidebar {
				width: 260px !important;
				box-shadow: 0 0 25px rgba(0, 0, 0, 0.12) !important;
			}
			body.mini-sidebar.expand-menu .sidebar-logo-box span.logo-text,
			body.mini-sidebar.expand-menu .sidebar-menu ul li a span {
				display: inline-block !important;
			}
			body.mini-sidebar.expand-menu .sidebar-logo-box {
				justify-content: space-between !important;
				padding: 0 20px !important;
			}
		}

		/* RESET & OVERRIDE TOTAL STRUKTUR SIDEBAR AGAR ANTI-CONFLICT DENGAN STYLE.CSS */
		.sidebar {
			display: flex !important;
			flex-direction: column !important;
			background-color: #FFFFFF !important;
			border-right: 1px solid #E5E7EB !important;
			box-shadow: 0 0 15px rgba(0, 0, 0, 0.04) !important;
			padding: 0 !important;
			margin: 0 !important;
			box-sizing: border-box !important;
		}
		.sidebar-logo-box {
			width: 100% !important;
			height: 60px !important;
			min-height: 60px !important;
			max-height: 60px !important;
			display: flex !important;
			align-items: center !important;
			justify-content: space-between !important;
			padding: 0 20px !important;
			border-bottom: 1px solid #E5E7EB !important;
			background-color: #ffffff !important;
			flex-shrink: 0 !important;
			box-sizing: border-box !important;
		}
		/* FIX SCROLLBAR: Exactly 1 clean scrollbar on .sidebar-inner */
		.sidebar {
			overflow: hidden !important;
		}
		.sidebar .slimScrollDiv {
			width: 100% !important;
			padding: 0 !important;
			margin: 0 !important;
			top: 0 !important;
			height: calc(100vh - 60px) !important;
			overflow: hidden !important;
			box-sizing: border-box !important;
		}
		.sidebar .sidebar-inner {
			width: 100% !important;
			padding: 0 !important;
			margin: 0 !important;
			top: 0 !important;
			height: calc(100vh - 60px) !important;
			overflow-y: auto !important;
			overflow-x: hidden !important;
			box-sizing: border-box !important;
		}
		/* FIX PADDING: Give generous left & right padding so text never touches the walls */
		.sidebar .sidebar-menu,
		.sidebar .slimScrollDiv .sidebar-menu {
			width: 100% !important;
			margin: 0 !important;
			margin-top: 0 !important;
			padding: 12px 16px 40px 16px !important;
			box-sizing: border-box !important;
		}
		.sidebar .sidebar-menu ul {
			list-style: none !important;
			padding: 0 !important;
			margin: 0 !important;
			width: 100% !important;
		}
		.sidebar .sidebar-menu > ul > li {
			width: 100% !important;
			padding: 0 !important;
			margin: 0 !important;
			border-bottom: none !important;
		}
		.sidebar .sidebar-menu ul li a {
			display: flex !important;
			align-items: center !important;
			width: 100% !important;
			padding: 10px 20px !important;
			color: #374151 !important;
			text-decoration: none !important;
			box-sizing: border-box !important;
		}

		/* Tombol toggle sidebar bergaya Alexa */
		.sidebar-toggle-btn {
			width: 38px;
			height: 38px;
			border-radius: 8px;
			display: flex;
			align-items: center;
			justify-content: center;
			color: #1E293B !important;
			background: #F4F6F8;
			border: 1px solid #E5E7EB;
			transition: all 0.2s ease;
			text-decoration: none !important;
			font-size: 1.25rem;
		}
		.sidebar-toggle-btn:hover {
			background: #E5E7EB;
			color: #3BAE7C !important;
		}

		/* LAYOUT MOBILE & TABLET (< 992px) */
		@media (max-width: 991.98px) {
			/* Header: full width, fixed height */
			.header {
				left: 0 !important;
				width: 100% !important;
				height: 60px !important;
				z-index: 1040 !important;
			}
			/* Override: make header flex instead of template absolute layout */
			.header .main-header {
				display: flex !important;
				align-items: center !important;
				justify-content: space-between !important;
				height: 100% !important;
				padding: 0 12px !important;
			}
			/* Fix header-left: template sets position:absolute+width:100% which covers everything */
			.header .header-left {
				display: flex !important;
				position: relative !important;
				width: auto !important;
				height: auto !important;
				float: none !important;
				flex-shrink: 0 !important;
				border-right: none !important;
			}
			/* Override template's absolute right positioning on #mobile_btn */
			.header #mobile_btn,
			.header .mobile_btn,
			#mobile_btn {
				position: relative !important;
				top: auto !important;
				right: auto !important;
				left: auto !important;
				display: flex !important;
				align-items: center !important;
				justify-content: center !important;
				float: none !important;
				margin: 0 !important;
				padding: 0 !important;
				width: 38px !important;
				height: 38px !important;
			}
			/* Prevent logo distortion from template's forced width: 140px */
			.header .header-left .logo {
				width: auto !important;
				text-align: left !important;
			}
			.header .header-left .logo img {
				width: auto !important;
				height: 32px !important;
				max-height: 32px !important;
			}
			/* User section on the right */
			.header .header-user {
				display: flex !important;
				align-items: center !important;
				position: relative !important;
				flex-shrink: 0 !important;
			}
			/* Template hides .user-menu on mobile (expects .mobile-user-menu instead).
			   Our layout puts hamburger+profile inside .user-menu, so force it visible. */
			.header .header-user .user-menu {
				display: flex !important;
				align-items: center !important;
				padding: 0 !important;
				height: auto !important;
			}
			/* Page wrapper: no margin on mobile */
			.page-wrapper {
				margin-left: 0 !important;
			}

			/* Sidebar: use margin-left (same mechanism as style.css) to avoid conflicts */
			.sidebar {
				top: 0 !important;
				left: 0 !important;
				margin-left: -280px !important;
				width: 260px !important;
				height: 100vh !important;
				transition: all 0.3s ease !important;
				z-index: 1051 !important;
			}
			/* When sidebar is open (.slide-nav on .main-wrapper) */
			.slide-nav .sidebar {
				margin-left: 0 !important;
			}
			/* Overlay */
			.sidebar-overlay {
				position: fixed !important;
				top: 0 !important;
				left: 0 !important;
				width: 100% !important;
				height: 100% !important;
				background-color: rgba(0, 0, 0, 0.5) !important;
				z-index: 1050 !important;
				display: none !important;
			}
			.sidebar-overlay.opened {
				display: block !important;
			}
		}
	</style>

	<!-- SweetAlert2 -->
	<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>

<body>
	<!-- Main Wrapper -->
	<div class="main-wrapper">

		<!-- Header -->
		<div class="header">
			<div class="main-header">
				<div class="header-left d-flex align-items-center gap-2">
					<a href="javascript:void(0);" id="toggle_btn" class="sidebar-toggle-btn d-none d-lg-flex" title="Toggle Sidebar">
						<i class="ti ti-menu-2"></i>
					</a>
					<a href="javascript:void(0);" id="mobile_btn" class="sidebar-toggle-btn d-flex d-lg-none" title="Buka Menu">
						<i class="ti ti-menu-2"></i>
					</a>

					<a href="/admin" class="logo d-flex d-lg-none align-items-center text-decoration-none">
						<img src="/assets/img/logo.png" alt="Alexa Computindo Group" style="max-height: 34px;">
						<span class="ms-2 fw-bolder" style="color: #1E293B !important; font-size: 1.15rem; letter-spacing: 0.5px;">ALEXA <span style="color: #3BAE7C !important;">GROUP</span></span>
					</a>
				</div>

				<div class="header-user">
					<div class="nav user-menu nav-list">
						<div class="d-flex align-items-center header-icons ms-auto">
							<div class="dropdown profile-dropdown">
								<a href="javascript:void(0);" class="d-flex align-items-center text-decoration-none py-1 px-2 rounded-pill hover-bg-light" data-bs-toggle="dropdown" data-bs-auto-close="outside">
									<span class="avatar avatar-sm bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center fw-bold shadow-sm" style="width: 38px; height: 38px; font-size: 0.95rem;">
										<%= typeof user !== 'undefined' && user && user.name ? user.name.charAt(0).toUpperCase() : 'A' %>
									</span>
									<span class="ms-2 d-none d-md-inline-block fw-semibold text-dark fs-14">
										<%= typeof user !== 'undefined' && user && user.name ? user.name : 'Administrator' %>
									</span>
									<i class="ti ti-chevron-down ms-1 text-muted small"></i>
								</a>
								<div class="dropdown-menu dropdown-menu-end shadow-sm border-0 rounded-4 p-2 mt-2" style="min-width: 240px;">
									<div class="profileset d-flex align-items-center p-3 border-bottom">
										<span class="avatar avatar-md bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center fw-bold me-3 shadow-sm" style="width: 44px; height: 44px; font-size: 1.2rem;">
											<%= typeof user !== 'undefined' && user && user.name ? user.name.charAt(0).toUpperCase() : 'A' %>
										</span>
										<div>
											<h6 class="fw-bold mb-1 text-dark"><%= typeof user !== 'undefined' && user && user.name ? user.name : 'Administrator' %></h6>
											<p class="fs-13 text-muted mb-0"><%= typeof user !== 'undefined' && user && user.email ? user.email : 'admin@alexagroup.co.id' %></p>
										</div>
									</div>
									<a class="dropdown-item d-flex align-items-center py-2 mt-1 rounded-3" href="/admin">
										<i class="ti ti-layout-dashboard me-2 text-primary"></i>Dashboard
									</a>
									<a class="dropdown-item d-flex align-items-center py-2 rounded-3" href="/admin/profile">
										<i class="ti ti-user-shield me-2 text-primary"></i>Profil Saya & Keamanan
									</a>
									<div class="dropdown-divider my-1"></div>
									<a class="dropdown-item d-flex align-items-center py-2 text-danger rounded-3" href="/admin/logout" onclick="confirmLogout(event)">
										<i class="ti ti-logout me-2"></i>Keluar Sesi
									</a>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
		<!-- /Header -->

		<!-- Helper Izin Akses RBAC -->
		<% const hasPerm = (permName) => {
			if (typeof user === 'undefined' || !user) return false;
			if (user.roles && user.roles.includes('Super Admin')) return true;
			const perms = Array.isArray(permName) ? permName : [permName];
			return perms.some(p => user.permissions && user.permissions.includes(p));
		}; %>

		<!-- Sidebar -->
		<div class="sidebar" id="sidebar">
			<!-- Logo Box di Atas Sidebar (Tetap diam saat menu diskrol) -->
			<div class="sidebar-logo-box">
				<a href="/admin" class="d-flex align-items-center text-decoration-none overflow-hidden">
					<img src="/assets/img/logo.png" alt="Alexa Computindo Group" style="max-height: 36px; min-width: 36px;">
					<span class="ms-2 fw-bolder logo-text" style="color: #1E293B !important; font-size: 1.15rem; letter-spacing: 0.5px; white-space: nowrap;">ALEXA <span style="color: #3BAE7C !important;">GROUP</span></span>
				</a>
				<a href="javascript:void(0);" id="close_sidebar" class="d-lg-none btn btn-sm btn-light border d-flex align-items-center justify-content-center text-muted" style="width: 32px; height: 32px; border-radius: 8px;" title="Tutup Menu">
					<i class="fas fa-times"></i>
				</a>
			</div>
			<div class="sidebar-inner slimscroll">
				<div id="sidebar-menu" class="sidebar-menu">
					<ul>
						<li class="menu-title"><span>UTAMA</span></li>
						<li class="<%= typeof activeMenu !== 'undefined' && activeMenu === 'dashboard' ? 'active' : '' %>">
							<a href="/admin">
								<i class="ti ti-layout-dashboard"></i><span>Dashboard</span>
							</a>
						</li>

						<li class="menu-title"><span>MANAJEMEN KONTEN</span></li>
						<% if (hasPerm('articles.manage')) { %>
							<li class="<%= typeof activeMenu !== 'undefined' && activeMenu === 'articles' ? 'active' : '' %>">
								<a href="/admin/articles">
									<i class="ti ti-article"></i><span>Artikel & Blog</span>
								</a>
							</li>
						<% } %>

						<% if (hasPerm('services.manage')) { %>
							<li class="<%= typeof activeMenu !== 'undefined' && activeMenu === 'services' ? 'active' : '' %>">
								<a href="/admin/services">
									<i class="ti ti-briefcase"></i><span>Layanan & Harga</span>
								</a>
							</li>
							<li class="<%= typeof activeMenu !== 'undefined' && activeMenu === 'clients' ? 'active' : '' %>">
								<a href="/admin/clients">
									<i class="ti ti-users-group"></i><span>Klien & Mitra</span>
								</a>
							</li>
						<% } %>

						<% if (hasPerm('frontend.manage')) { %>
							<li class="<%= typeof activeMenu !== 'undefined' && activeMenu === 'pages' ? 'active' : '' %>">
								<a href="/admin/pages">
									<i class="ti ti-layout-board-split"></i><span>Halaman Frontend</span>
								</a>
							</li>
						<% } %>

						<% if (hasPerm('inquiries.manage')) { %>
							<li class="<%= typeof activeMenu !== 'undefined' && activeMenu === 'inquiries' ? 'active' : '' %>">
								<a href="/admin/inquiries">
									<i class="ti ti-mail"></i><span>Pesan Masuk</span>
								</a>
							</li>
						<% } %>

						<% if (hasPerm('users.manage') || hasPerm('roles.manage')) { %>
							<li class="menu-title"><span>PENGATURAN & RBAC</span></li>
							<% if (hasPerm('users.manage')) { %>
								<li class="<%= typeof activeMenu !== 'undefined' && activeMenu === 'users' ? 'active' : '' %>">
									<a href="/admin/users">
										<i class="ti ti-users"></i><span>Pengguna Admin</span>
									</a>
								</li>
							<% } %>

							<% if (hasPerm('roles.manage')) { %>
								<li class="<%= typeof activeMenu !== 'undefined' && activeMenu === 'roles' ? 'active' : '' %>">
									<a href="/admin/roles">
										<i class="ti ti-shield-lock"></i><span>Role & Permission</span>
									</a>
								</li>
							<% } %>
						<% } %>
					</ul>
				</div>
			</div>
		</div>
		<!-- /Sidebar -->

		<!-- Page Wrapper -->
		<div class="page-wrapper">
			<div class="content pb-0">
				<%- body %>
			</div>

			<!-- Footer -->
			<div class="footer d-sm-flex align-items-center justify-content-between border-top bg-white p-3">
				<p class="mb-0 text-muted small">2026 &copy; PT. Alexa Computindo Group. CMS Admin Panel.</p>
				<p class="mb-0 text-muted small">Powered by <span class="text-primary fw-medium">Dreamsrent UI & Express.js</span></p>
			</div>
			<!-- /Footer -->
		</div>
		<!-- /Page Wrapper -->

	</div>
	<!-- /Main Wrapper -->

	<!-- jQuery -->
	<script src="/assets/js/jquery-3.7.1.min.js"></script>

	<!-- Bootstrap Core JS -->
	<script src="/assets/js/bootstrap.bundle.min.js"></script>

	<!-- Slimscroll JS -->
	<script src="/assets/plugins/slimscroll/jquery.slimscroll.min.js"></script>

	<!-- Custom JS -->
	<script src="/assets/js/script.js"></script>
	<script src="/assets/js/chip-input.js?v=2.2"></script>
	<script>
		function confirmLogout(e) {
			e.preventDefault();
			Swal.fire({
				title: 'Keluar dari Sesi?',
				text: 'Anda akan keluar dari Admin Panel.',
				icon: 'question',
				showCancelButton: true,
				confirmButtonColor: '#d33',
				cancelButtonColor: '#6c757d',
				confirmButtonText: 'Ya, Keluar',
				cancelButtonText: 'Batal'
			}).then((result) => {
				if (result.isConfirmed) {
					localStorage.removeItem('alexa_admin_token');
					window.location.href = '/admin/logout';
				}
			});
		}

		// ============================================================
		// Sidebar Toggle Handler (fixes conflicts with script.js)
		// script.js uses jQuery delegated event on #mobile_btn and
		// appends its own .sidebar-overlay. We must work WITH it,
		// not duplicate it.
		// ============================================================
		document.addEventListener('DOMContentLoaded', function() {
			var toggleBtn = document.getElementById('toggle_btn');
			var closeSidebarBtn = document.getElementById('close_sidebar');
			var mainWrapper = document.querySelector('.main-wrapper');

			// 1. Desktop Toggle Handler (#toggle_btn) -> mini-sidebar
			if (toggleBtn) {
				toggleBtn.addEventListener('click', function(e) {
					e.preventDefault();
					document.body.classList.toggle('mini-sidebar');
				});
			}

			// 2. Mobile: script.js already handles #mobile_btn click
			//    (toggles .slide-nav on .main-wrapper and .opened on overlay).
			//    We only need to handle the close button inside the sidebar.
			function closeMobileSidebar(e) {
				if (e) e.preventDefault();
				if (mainWrapper) mainWrapper.classList.remove('slide-nav');
				document.querySelectorAll('.sidebar-overlay').forEach(function(el) {
					el.classList.remove('opened');
				});
				document.documentElement.classList.remove('menu-opened');
			}

			if (closeSidebarBtn) {
				closeSidebarBtn.addEventListener('click', closeMobileSidebar);
			}
		});
	</script>

</body>

</html>
